---
import Layout from '~/layouts/Layout.astro';

const packages = [
  { name: 'Starter Automation', price: '14,900', monthly: '4,900', tag: 'เริ่มแทนงานแอดมินซ้ำ', items: ['AI ตอบ FAQ/สินค้า/จัดส่ง', 'ฐานข้อมูลสินค้า 30 SKU', 'ส่งต่อแอดมินเมื่อไม่มั่นใจ', 'สรุปคำถามซ้ำที่ทำให้เสียเวลา', 'เทรนทีม 1 รอบ'] },
  { name: 'Growth Automation', price: '29,000', monthly: '9,900', tag: 'แนะนำ', highlight: true, items: ['ทุกอย่างใน Starter', 'AI แนะนำไซซ์/สินค้าเบื้องต้น', 'ช่วยลดแชทซ้ำก่อนต้องจ้างแอดมินเพิ่ม', 'AI เสนอ caption จากคำถามลูกค้าจริง', 'LINE OA หรือ Facebook Inbox 1 ช่องทาง'] },
  { name: 'Scale Automation', price: '49,000', monthly: '19,900', tag: 'ร้านที่กำลังจะเพิ่มทีม', items: ['เชื่อมหลายช่องทาง', 'หน้าสรุปลดต้นทุน/แชทที่ AI ช่วยตอบ', 'ระบบช่วยทีมขายติดตามลูกค้า', 'workflow แจ้งเตือนแอดมิน', 'ปรับระบบ/คำตอบทุกเดือน'] },
];

const flow = [
  ['ลูกค้าทักมา', 'ถามไซซ์ สี ราคา ส่งของ หรือสินค้าแนะนำผ่าน LINE/Facebook'],
  ['AI ตอบจากข้อมูลร้าน', 'ตอบจากสินค้า/FAQ/นโยบายจริง ไม่มั่ว และถามข้อมูลเพิ่มเมื่อจำเป็น'],
  ['ส่งต่อแอดมินเมื่อเสี่ยง', 'เคสคืนสินค้า ต่อรองหนัก หรือข้อมูลไม่ครบ จะส่งต่อคนจริงพร้อมสรุปบริบท'],
  ['เก็บ insight อัตโนมัติ', 'คำถามยอดฮิต สินค้าที่คนสนใจ ปัญหาที่ลูกค้าถามซ้ำ ถูกเก็บเข้า dashboard'],
  ['สร้าง action ต่อ', 'ระบบเสนอ FAQ ใหม่ / caption / post idea จากข้อมูลแชทจริงของร้าน'],
];
---

<Layout title="AI Sales Automation สำหรับร้านเสื้อผ้าออนไลน์ | KORP AI" description="ระบบ AI ตอบแชท แนะนำสินค้า เก็บ insight และสร้างคอนเทนต์จากคำถามลูกค้าจริง สำหรับร้านเสื้อผ้าออนไลน์" canonical="https://korpai.co/fashion-ai-kit">
  <section class="automation-hero">
    <div class="kp-container automation-hero-grid">
      <div>
        <span class="kp-pill">สำหรับร้านเสื้อผ้าออนไลน์ไทย</span>
        <h1>AI ช่วยร้านเสื้อผ้าตอบแชทและขายดีขึ้น</h1>
        <p>ลูกค้าถามไซซ์ สี ส่งของทุกวัน ระบบช่วยตอบเบื้องต้น ส่งต่อแอดมินเมื่อจำเป็น และสรุปคำถามที่เจอบ่อย</p>
        <div class="hero-actions"><a class="kp-btn-primary" href="/fashion-ai-kit/demo">ดูหน้าระบบตัวอย่าง</a><a class="kp-btn-secondary" href="https://lin.ee/Qt6Vri4" target="_blank" rel="noopener">ส่งลิงก์ร้านให้ดูฟรี</a></div>
        <div class="hero-metrics"><div><b>24/7</b><span>ตอบคำถามซ้ำ</span></div><div><b>3–14 วัน</b><span>ขึ้นระบบแรก</span></div><div><b>100K+</b><span>เป้ารายได้/เดือน</span></div></div>
      </div>
      <div class="boutique-card"><img src="/assets/img/fashion-ai-kit/boutique-hero.png" alt="ร้านเสื้อผ้าออนไลน์พร้อมระบบ AI ช่วยตอบแชท" /><div class="automation-console">
        <div class="console-top"><span>Live automation demo</span><b>LINE/Facebook → AI → Dashboard</b></div>
        <div class="phone-chat">
          <div class="msg customer">สูง 160 อก 36 ใส่เดรสรุ่น Linen Straight ไซซ์ไหนดีคะ?</div>
          <div class="msg ai">แนะนำไซซ์ L ค่ะ รุ่นนี้ทรงตรง ถ้าอก 36 จะใส่สบายกว่า M เดี๋ยวส่งรูปเทียบความยาวให้ดูนะคะ</div>
          <div class="msg customer">ส่งวันนี้ได้ไหมคะ?</div>
          <div class="msg ai">ถ้าชำระก่อน 14:00 น. ร้านจัดส่งรอบวันนี้ได้ค่ะ หลังแพ็กเสร็จจะแจ้งเลขพัสดุในแชทนี้ค่ะ</div>
        </div>
        <div class="console-dashboard"><div><small>Top question</small><b>ไซซ์ / ทรง</b></div><div><small>Hot SKU</small><b>Linen Dress</b></div><div><small>Next action</small><b>เพิ่ม size guide</b></div></div>
      </div></div>
    </div>
  </section>

  <section class="section border-t kp-hairline">
    <div class="kp-container">
      <div class="section-head"><span class="kp-pill">ระบบช่วยอะไรบ้าง</span><h2>ระบบนี้ทำงานแทน “งานซ้ำ” ไม่ใช่แทนเจ้าของร้านทั้งหมด</h2><p>AI รับเคสพื้นฐานและเก็บข้อมูลให้ ส่วนเคสที่ต้องตัดสินใจ/มีความเสี่ยง จะส่งต่อคนจริงทันที</p></div>
      <div class="feature-grid">
        {[
          ['AI ช่วยตอบแชท','ตอบคำถามไซซ์ สี ผ้า ราคา การส่ง คืนสินค้า และถามข้อมูลเพิ่มก่อนแนะนำ'],
          ['ข้อมูลสินค้าให้ AI ใช้ตอบ','จัดข้อมูลสินค้า/FAQ/นโยบายร้านให้ AI ใช้อ้างอิง ไม่ตอบจากความจำมั่ว'],
          ['ส่งต่อแอดมิน','เคสยากส่งต่อแอดมินพร้อมสรุปว่าลูกค้าต้องการอะไร ไม่ต้องอ่านแชทย้อนยาว'],
          ['หน้าสรุปคำถามลูกค้า','ดูคำถามยอดฮิต สินค้าที่ถูกถามเยอะ จุดที่หน้าร้านข้อมูลไม่ครบ'],
          ['ไอเดียโพสต์จากคำถามลูกค้า','เอาคำถามจริงของลูกค้ามาแนะนำ caption/post/FAQ ใหม่ให้ร้านโพสต์ต่อ'],
          ['ดูแลและปรับคำตอบรายเดือน','ปรับคำตอบ เพิ่มสินค้าใหม่ และลดจุดที่ AI ตอบไม่ได้ทุกเดือน'],
        ].map((f, i) => <article class="kp-card feature"><span>{String(i+1).padStart(2,'0')}</span><h3>{f[0]}</h3><p>{f[1]}</p></article>)}
      </div>
    </div>
  </section>

  <section class="section border-t kp-hairline">
    <div class="kp-container flow-wrap">
      <div><span class="kp-pill">ขั้นตอนการทำงาน</span><h2>จากแชทลูกค้า → ยอดขาย → insight → คอนเทนต์</h2><p>ทุกบทสนทนาไม่หายไปเฉย ๆ แต่กลายเป็นข้อมูลให้ร้านขายดีขึ้นเรื่อย ๆ</p></div>
      <div class="flow-list">{flow.map((s,i)=><div class="flow-item"><b>{String(i+1).padStart(2,'0')}</b><div><h3>{s[0]}</h3><p>{s[1]}</p></div></div>)}</div>
    </div>
  </section>

  <section class="section border-t kp-hairline">
    <div class="kp-container">
      <div class="section-head"><span class="kp-pill">แพ็กเกจ</span><h2>เริ่มให้ AI ช่วยงานซ้ำ ก่อนต้องจ้างแอดมินเพิ่ม</h2><p>ตั้งราคาให้เทียบกับค่าแรงแอดมินจริง: ลดเวลาตอบคำถามซ้ำ ลดแชทหลุด ลดปัญหาพนักงาน และค่อยขยายเมื่อร้านเห็นผล</p></div>
      <div class="price-grid">{packages.map((p)=><article class={`kp-card price ${p.highlight?'hot':''}`}>{p.highlight && <div class="hot-label">แนะนำ</div>}<span>{p.tag}</span><h3>{p.name}</h3><div class="setup">฿{p.price}<small>setup</small></div><div class="monthly">฿{p.monthly}/เดือน</div><div class="roi-note">ถูกกว่าจ้างแอดมินเพิ่ม 1 คน</div><ul>{p.items.map((it)=><li>{it}</li>)}</ul></article>)}</div>
    </div>
  </section>

  <section class="section border-t kp-hairline">
    <div class="kp-container cta-box"><div><span class="kp-pill">เริ่มยังไง</span><h2>ส่งลิงก์ร้านมา เดี๋ยวเราประเมิน flow ที่ควรออโต้ให้ก่อน</h2><p>เราจะดูว่าร้านควรเริ่มจากตอบแชท, FAQ, แนะนำไซซ์, dashboard หรือ content trigger ก่อน เพื่อให้คุ้มที่สุด</p></div><a class="kp-btn-line" href="https://lin.ee/Qt6Vri4" target="_blank" rel="noopener">ทัก LINE เพื่อประเมินฟรี</a></div>
  </section>
</Layout>

<style>
.automation-hero{padding:140px 0 90px;overflow:hidden}.automation-hero-grid{display:grid;grid-template-columns:.9fr 1.1fr;gap:42px;align-items:center}.automation-hero h1{margin-top:22px;color:white;font-size:clamp(2.8rem,6vw,5.8rem);line-height:1.06;letter-spacing:-.06em;max-width:900px}.automation-hero p{margin-top:22px;color:#8aa0c5;font-size:19px;line-height:1.75;max-width:680px}.hero-actions{display:flex;flex-wrap:wrap;gap:14px;margin-top:30px}.hero-metrics{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-top:30px;max-width:620px}.hero-metrics div{border:1px solid rgba(255,255,255,.09);background:rgba(255,255,255,.04);border-radius:18px;padding:15px}.hero-metrics b{display:block;color:white;font-size:24px}.hero-metrics span{display:block;color:#8aa0c5;font-size:12px;margin-top:4px}.automation-console{border:1px solid rgba(255,255,255,.12);border-radius:32px;background:radial-gradient(circle at 20% 10%,rgba(38,215,246,.17),transparent 34%),rgba(7,12,24,.9);padding:20px;box-shadow:0 30px 90px rgba(0,0,0,.45)}.console-top{display:flex;justify-content:space-between;gap:12px;color:#8aa0c5;font-size:12px}.console-top b{color:white}.phone-chat{margin-top:18px;border-radius:26px;border:1px solid rgba(255,255,255,.09);background:rgba(0,0,0,.22);padding:18px;display:grid;gap:12px}.msg{max-width:82%;padding:13px 15px;border-radius:18px;font-size:14px;line-height:1.65}.msg.customer{background:rgba(255,255,255,.08);color:#dbe6fa}.msg.ai{margin-left:auto;background:rgba(38,215,246,.15);border:1px solid rgba(38,215,246,.22);color:#effcff}.console-dashboard{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-top:14px}.console-dashboard div{border:1px solid rgba(255,255,255,.08);border-radius:18px;background:rgba(255,255,255,.04);padding:14px}.console-dashboard small{color:#26d7f6;font-weight:900}.console-dashboard b{display:block;color:white;margin-top:6px}.section{padding:84px 0}.section-head{text-align:center;max-width:760px;margin:0 auto}.section-head h2,.flow-wrap h2,.cta-box h2{color:white;margin-top:18px;font-size:clamp(2rem,4vw,3.4rem);line-height:1.12;letter-spacing:-.045em}.section-head p,.flow-wrap p,.cta-box p{color:#8aa0c5;margin-top:16px;font-size:17px;line-height:1.7}.feature-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:18px;margin-top:46px}.feature span{color:#26d7f6;font-family:ui-monospace,monospace}.feature h3{color:white;margin-top:14px;font-size:20px}.feature p{color:#8aa0c5;margin-top:10px;line-height:1.65}.flow-wrap{display:grid;grid-template-columns:.8fr 1.2fr;gap:38px}.flow-list{display:grid;gap:14px}.flow-item{display:grid;grid-template-columns:56px 1fr;gap:14px;border:1px solid rgba(255,255,255,.09);border-radius:20px;background:rgba(255,255,255,.035);padding:18px}.flow-item b{color:#26d7f6}.flow-item h3{color:white}.flow-item p{color:#8aa0c5;margin-top:6px}.price-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:18px;margin-top:46px}.price{position:relative}.price.hot{border-color:rgba(38,215,246,.45);background:rgba(38,215,246,.055)}.hot-label{position:absolute;right:18px;top:18px;background:#26d7f6;color:#061018;border-radius:999px;padding:6px 10px;font-size:12px;font-weight:900}.price>span{color:#26d7f6}.price h3{color:white;margin-top:10px;font-size:24px}.setup{color:white;font-size:38px;font-weight:950;margin-top:18px}.setup small{font-size:13px;color:#8aa0c5;margin-left:6px}.monthly{color:#a7f3d0;margin-top:8px;font-weight:800}.price ul{display:grid;gap:10px;margin-top:22px;padding:0;list-style:none}.price li{color:#c8d5ec;font-size:14px;line-height:1.5}.price li:before{content:'✓';color:#26d7f6;margin-right:8px}.cta-box{display:flex;align-items:center;justify-content:space-between;gap:28px;border:1px solid rgba(255,255,255,.10);border-radius:30px;background:rgba(255,255,255,.04);padding:34px}@media(max-width:980px){.automation-hero-grid,.flow-wrap,.feature-grid,.price-grid{grid-template-columns:1fr}.hero-metrics,.console-dashboard{grid-template-columns:1fr}.cta-box{display:block}.cta-box .kp-btn-line{margin-top:24px}.automation-hero{padding-top:115px}}
</style>

<style>
  @media (max-width: 640px) {
    :global(.kp-contact-float) { display: none !important; }
    .automation-hero h1 { font-size: 3rem; line-height: 1.12; letter-spacing: -0.045em; }
    .automation-console { max-width: 100%; overflow: hidden; }
    .console-top { display: block; }
    .phone-chat { padding: 14px; }
    .msg { max-width: 92%; font-size: 13px; }
  }
</style>


<style>
  /* Fashion boutique theme polish */
  .automation-hero {
    background:
      linear-gradient(90deg, rgba(5,7,14,.96) 0%, rgba(9,16,24,.82) 52%, rgba(35,25,18,.72) 100%),
      url('/assets/img/fashion-ai-kit/boutique-hero.png') right center/cover no-repeat;
  }
  .automation-hero h1 { max-width: 760px; }
  .automation-hero p { color:#c3b8ad; }
  .boutique-card { border-radius: 34px; border:1px solid rgba(255,255,255,.13); background:rgba(18,14,12,.72); padding:12px; box-shadow:0 30px 90px rgba(0,0,0,.42); }
  .boutique-card > img { display:block; width:100%; aspect-ratio: 16/9; object-fit:cover; border-radius:26px; border:1px solid rgba(255,255,255,.1); margin-bottom:12px; }
  .automation-console { background:rgba(11,12,18,.88) !important; box-shadow:none !important; }
  .kp-card, .flow-item, .price, .cta-box { background:rgba(255,255,255,.045) !important; border-color:rgba(255,255,255,.10) !important; }
  .feature span, .flow-item b, .console-dashboard small, .price>span { color:#f0c48a !important; }
  .hot-label, .kp-btn-primary { background:#f4d3a1 !important; color:#17110b !important; }
  .price.hot { border-color:rgba(244,211,161,.45) !important; background:rgba(244,211,161,.07) !important; }
  @media (max-width:640px){
    .automation-hero { background:linear-gradient(180deg, rgba(5,7,14,.98), rgba(14,11,12,.94)), url('/assets/img/fashion-ai-kit/boutique-hero.png') center top/cover no-repeat; }
    .automation-hero h1 { font-size:2.55rem !important; }
    .boutique-card > img { aspect-ratio: 4/3; }
  }
</style>

<style>
  :global(html), :global(body) { overflow-x: hidden; }
  .automation-hero-grid > *, .boutique-card, .automation-console { min-width: 0; }
  .automation-hero h1 { overflow-wrap: anywhere; word-break: normal; }
  @media (max-width:640px){
    .automation-hero { padding-top: 96px; }
    .automation-hero h1 { font-size: 2.25rem !important; line-height: 1.18 !important; letter-spacing: -0.035em !important; }
    .automation-hero p { font-size: 16px !important; line-height: 1.75; }
    .hero-actions a { width: 100%; }
  }
</style>

<style>
  @media (max-width: 640px) {
    .kp-container, .automation-hero-grid, .automation-hero-grid > div { width: 100% !important; max-width: 100% !important; }
    .automation-hero-grid { display: block !important; }
    .automation-hero h1 {
      font-size: 1.95rem !important;
      line-height: 1.22 !important;
      max-width: calc(100vw - 40px) !important;
      word-break: keep-all !important;
      overflow-wrap: normal !important;
    }
    .automation-hero p { max-width: calc(100vw - 40px) !important; }
    .boutique-card { width: 100% !important; max-width: calc(100vw - 40px) !important; box-sizing: border-box; }
  }
</style>

<style>
  @media (max-width: 640px) {
    .automation-hero h1 { font-size: 2.05rem !important; max-width: 310px !important; }
    .automation-hero p { max-width: 330px !important; }
  }
</style>

<style>
  .roi-note { color:#f0c48a; font-size:12px; font-weight:900; margin-top:8px; }
</style>
