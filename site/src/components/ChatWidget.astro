---
---

<!-- Floating AI chatbot widget -->
<div id="kp-chat" class="kp-chat-root" aria-live="polite">
  <!-- Bubble -->
  <button
    id="kp-chat-bubble"
    type="button"
    class="kp-chat-bubble group"
    aria-label="เปิดแชทกับ AI"
  >
    <span class="kp-chat-bubble-ring"></span>
    <span class="kp-chat-bubble-ring kp-chat-bubble-ring-2"></span>
    <svg viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <path d="M21 12a9 9 0 11-3.6-7.2L21 3v6h-6" stroke-linecap="round" stroke-linejoin="round" opacity="0"/>
      <path d="M4 5h16a1 1 0 011 1v11a1 1 0 01-1 1h-8l-5 4v-4H4a1 1 0 01-1-1V6a1 1 0 011-1z" stroke-linecap="round" stroke-linejoin="round"/>
      <circle cx="9"  cy="11.5" r="1" fill="currentColor"/>
      <circle cx="12" cy="11.5" r="1" fill="currentColor"/>
      <circle cx="15" cy="11.5" r="1" fill="currentColor"/>
    </svg>
    <span class="kp-chat-bubble-badge">1</span>
  </button>

  <!-- Panel -->
  <div id="kp-chat-panel" class="kp-chat-panel" aria-hidden="true" role="dialog" aria-label="KORP AI chatbot">
    <!-- Header -->
    <div class="kp-chat-header">
      <div class="flex items-center gap-3">
        <div class="relative">
          <div class="h-9 w-9 rounded-full flex items-center justify-center"
               style="background: linear-gradient(135deg, #3C7CFF, #26D7F6);">
            <span class="text-white text-sm font-bold">K</span>
          </div>
          <span class="absolute -bottom-0.5 -right-0.5 h-2.5 w-2.5 rounded-full bg-[#22C55E] ring-2"
                style="ring-color: #0B1426;"></span>
        </div>
        <div>
          <div class="text-sm font-semibold text-white">KORP AI Agent</div>
          <div class="text-[11px]" style="color: #8AA0C5;">ออนไลน์ · ตอบได้ทันที</div>
        </div>
      </div>
      <button id="kp-chat-close" type="button"
              class="h-8 w-8 rounded-full grid place-items-center text-white/60 hover:text-white hover:bg-white/10 transition"
              aria-label="ปิดแชท">
        <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M6 6l12 12M18 6L6 18" stroke-linecap="round"/>
        </svg>
      </button>
    </div>

    <!-- Messages -->
    <div id="kp-chat-messages" class="kp-chat-messages">
      <div class="kp-msg kp-msg-bot">
        <div class="kp-avatar">
          <span class="text-[10px] font-bold text-white">K</span>
        </div>
        <div class="kp-bubble kp-bubble-bot">
          สวัสดีครับ 👋 ผมคือ AI agent ของ KORP AI — ช่วยตอบคำถามเกี่ยวกับบริการของเราได้ทุกอย่าง สนใจเรื่องไหนเป็นพิเศษครับ?
        </div>
      </div>

      <!-- Quick reply chips (pre-loaded) -->
      <div class="kp-quickreplies" id="kp-quickreplies">
        <button type="button" class="kp-qr" data-reply="อยากได้ chatbot ตอบลูกค้า 24 ชม.">
          💬 Chatbot ตอบลูกค้า 24 ชม.
        </button>
        <button type="button" class="kp-qr" data-reply="สนใจ automation เชื่อมระบบภายใน">
          ⚡ Automation เชื่อมระบบ
        </button>
        <button type="button" class="kp-qr" data-reply="อยากได้ dashboard ดูยอดขาย">
          📊 Dashboard ดูข้อมูล
        </button>
        <button type="button" class="kp-qr" data-reply="อยากรู้ราคา เริ่มต้นเท่าไหร่">
          💰 ราคาเริ่มต้น
        </button>
      </div>
    </div>

    <!-- Input -->
    <form id="kp-chat-form" class="kp-chat-input">
      <input
        id="kp-chat-text"
        type="text"
        placeholder="พิมพ์ข้อความ... (กด Enter เพื่อส่ง)"
        autocomplete="off"
        class="flex-1 bg-transparent text-sm text-white placeholder:text-white/40 focus:outline-none"
      />
      <button type="submit" class="kp-chat-send" aria-label="ส่งข้อความ">
        <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="M2 21l21-9L2 3l0 7 15 2-15 2z" stroke-linejoin="round" stroke-linecap="round"/>
        </svg>
      </button>
    </form>

    <!-- Foot note -->
    <div class="kp-chat-foot">
      powered by <strong class="text-white">KORP AI</strong> · ปรึกษาฟรี 24/7
    </div>
  </div>
</div>

<style>
  .kp-chat-root {
    position: fixed;
    right: clamp(16px, 3vw, 24px);
    bottom: clamp(16px, 3vw, 24px);
    z-index: 60;
    font-family: inherit;
  }

  /* ---------- bubble ---------- */
  .kp-chat-bubble {
    position: relative;
    display: grid;
    place-items: center;
    width: 60px;
    height: 60px;
    border-radius: 9999px;
    color: white;
    background: linear-gradient(135deg, #3C7CFF 0%, #26D7F6 100%);
    box-shadow:
      0 10px 30px rgba(38, 215, 246, 0.35),
      0 4px 12px rgba(60, 124, 255, 0.25),
      inset 0 1px 0 rgba(255,255,255,0.25);
    cursor: pointer;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .kp-chat-bubble:hover {
    transform: translateY(-2px) scale(1.05);
    box-shadow:
      0 16px 40px rgba(38, 215, 246, 0.5),
      0 6px 16px rgba(60, 124, 255, 0.35),
      inset 0 1px 0 rgba(255,255,255,0.3);
  }
  .kp-chat-bubble:active { transform: translateY(0) scale(0.98); }

  .kp-chat-bubble-ring {
    position: absolute;
    inset: 0;
    border-radius: 9999px;
    border: 2px solid rgba(38, 215, 246, 0.45);
    animation: kp-ring 2.2s ease-out infinite;
    pointer-events: none;
  }
  .kp-chat-bubble-ring-2 { animation-delay: 1.1s; }
  @keyframes kp-ring {
    0%   { transform: scale(1);   opacity: 0.8; }
    100% { transform: scale(1.7); opacity: 0;   }
  }

  .kp-chat-bubble-badge {
    position: absolute;
    top: -4px;
    right: -4px;
    min-width: 20px;
    height: 20px;
    padding: 0 6px;
    border-radius: 9999px;
    background: #EF4444;
    color: white;
    font-size: 11px;
    font-weight: 700;
    display: grid;
    place-items: center;
    box-shadow: 0 4px 8px rgba(239, 68, 68, 0.4);
  }

  /* ---------- panel ---------- */
  .kp-chat-panel {
    position: absolute;
    bottom: 76px;
    right: 0;
    width: min(380px, calc(100vw - 32px));
    height: min(560px, calc(100vh - 120px));
    border-radius: 20px;
    background: linear-gradient(180deg, #0B1426 0%, #05070E 100%);
    border: 1px solid rgba(255, 255, 255, 0.08);
    box-shadow:
      0 20px 60px rgba(0, 0, 0, 0.6),
      0 0 0 1px rgba(38, 215, 246, 0.08),
      0 8px 32px rgba(60, 124, 255, 0.15);
    display: none;
    flex-direction: column;
    overflow: hidden;
    opacity: 0;
    transform: translateY(12px) scale(0.96);
    transition: opacity 0.25s ease, transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .kp-chat-panel.is-open {
    display: flex;
    opacity: 1;
    transform: translateY(0) scale(1);
  }

  /* ---------- header ---------- */
  .kp-chat-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 16px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    background: linear-gradient(90deg, rgba(60, 124, 255, 0.06), rgba(38, 215, 246, 0.04));
  }

  /* ---------- messages ---------- */
  .kp-chat-messages {
    flex: 1;
    overflow-y: auto;
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    scrollbar-width: thin;
    scrollbar-color: rgba(255,255,255,0.1) transparent;
  }
  .kp-chat-messages::-webkit-scrollbar { width: 6px; }
  .kp-chat-messages::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 3px; }

  .kp-msg {
    display: flex;
    gap: 8px;
    align-items: flex-end;
    animation: kp-msg-in 0.3s ease-out both;
  }
  @keyframes kp-msg-in {
    from { opacity: 0; transform: translateY(6px); }
    to   { opacity: 1; transform: none; }
  }
  .kp-msg-user { flex-direction: row-reverse; }
  .kp-avatar {
    width: 24px; height: 24px; border-radius: 9999px;
    background: linear-gradient(135deg, #3C7CFF, #26D7F6);
    display: grid; place-items: center;
    flex-shrink: 0;
  }
  .kp-msg-user .kp-avatar {
    background: linear-gradient(135deg, #64748B, #334155);
  }
  .kp-bubble {
    max-width: 76%;
    padding: 10px 14px;
    border-radius: 16px;
    font-size: 13.5px;
    line-height: 1.5;
    word-wrap: break-word;
  }
  .kp-bubble-bot {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.07);
    color: #E6EBF5;
    border-bottom-left-radius: 4px;
  }
  .kp-bubble-user {
    background: linear-gradient(135deg, #3C7CFF, #26D7F6);
    color: white;
    border-bottom-right-radius: 4px;
  }

  /* typing indicator */
  .kp-typing {
    display: inline-flex;
    gap: 4px;
    align-items: center;
    padding: 12px 14px;
  }
  .kp-typing span {
    width: 6px; height: 6px;
    border-radius: 9999px;
    background: #26D7F6;
    animation: kp-typing 1.2s ease-in-out infinite;
  }
  .kp-typing span:nth-child(2) { animation-delay: 0.15s; }
  .kp-typing span:nth-child(3) { animation-delay: 0.3s; }
  @keyframes kp-typing {
    0%, 80%, 100% { opacity: 0.3; transform: translateY(0); }
    40%           { opacity: 1;   transform: translateY(-3px); }
  }

  /* ---------- quick replies ---------- */
  .kp-quickreplies {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    padding-left: 32px;
    margin-top: 4px;
  }
  .kp-qr {
    font-size: 12px;
    padding: 6px 10px;
    border-radius: 9999px;
    background: rgba(38, 215, 246, 0.08);
    border: 1px solid rgba(38, 215, 246, 0.25);
    color: #7BE8FF;
    cursor: pointer;
    transition: all 0.15s ease;
  }
  .kp-qr:hover {
    background: rgba(38, 215, 246, 0.15);
    border-color: rgba(38, 215, 246, 0.5);
    color: white;
  }

  /* ---------- input ---------- */
  .kp-chat-input {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 12px 14px;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    background: rgba(0, 0, 0, 0.2);
  }
  .kp-chat-send {
    width: 36px; height: 36px;
    border-radius: 9999px;
    background: linear-gradient(135deg, #3C7CFF, #26D7F6);
    color: white;
    display: grid; place-items: center;
    cursor: pointer;
    transition: transform 0.15s ease;
    flex-shrink: 0;
  }
  .kp-chat-send:hover { transform: scale(1.08); }
  .kp-chat-send:active { transform: scale(0.95); }

  .kp-chat-foot {
    padding: 8px 14px 12px;
    font-size: 10.5px;
    text-align: center;
    color: rgba(138, 160, 197, 0.6);
    background: rgba(0, 0, 0, 0.2);
  }

  @media (max-width: 480px) {
    .kp-chat-panel {
      bottom: 72px;
      right: 0;
      left: 0;
      margin-inline: auto;
    }
  }
</style>

<script is:inline>
  (() => {
    const bubble = document.getElementById('kp-chat-bubble');
    const panel  = document.getElementById('kp-chat-panel');
    const closeBtn = document.getElementById('kp-chat-close');
    const messages = document.getElementById('kp-chat-messages');
    const form   = document.getElementById('kp-chat-form');
    const input  = document.getElementById('kp-chat-text');
    const qrWrap = document.getElementById('kp-quickreplies');
    const badge  = bubble?.querySelector('.kp-chat-bubble-badge');
    if (!bubble || !panel || !messages || !form || !input) return;

    const escapeHtml = (s) => String(s).replace(/[&<>"']/g, (c) => ({
      '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'
    }[c]));

    const open = () => {
      panel.classList.add('is-open');
      panel.setAttribute('aria-hidden', 'false');
      if (badge) badge.style.display = 'none';
      setTimeout(() => input.focus(), 250);
    };
    const close = () => {
      panel.classList.remove('is-open');
      panel.setAttribute('aria-hidden', 'true');
    };
    bubble.addEventListener('click', () => {
      panel.classList.contains('is-open') ? close() : open();
    });
    closeBtn?.addEventListener('click', close);

    const addUserMsg = (text) => {
      const el = document.createElement('div');
      el.className = 'kp-msg kp-msg-user';
      el.innerHTML = `
        <div class="kp-avatar"><span class="text-[10px] font-bold text-white">U</span></div>
        <div class="kp-bubble kp-bubble-user">${escapeHtml(text)}</div>
      `;
      messages.appendChild(el);
      messages.scrollTop = messages.scrollHeight;
    };

    const addBotMsg = (text) => {
      const el = document.createElement('div');
      el.className = 'kp-msg kp-msg-bot';
      el.innerHTML = `
        <div class="kp-avatar"><span class="text-[10px] font-bold text-white">K</span></div>
        <div class="kp-bubble kp-bubble-bot">${text}</div>
      `;
      messages.appendChild(el);
      messages.scrollTop = messages.scrollHeight;
    };

    const showTyping = () => {
      const el = document.createElement('div');
      el.className = 'kp-msg kp-msg-bot';
      el.id = 'kp-typing-msg';
      el.innerHTML = `
        <div class="kp-avatar"><span class="text-[10px] font-bold text-white">K</span></div>
        <div class="kp-bubble kp-bubble-bot" style="padding:0;">
          <div class="kp-typing"><span></span><span></span><span></span></div>
        </div>
      `;
      messages.appendChild(el);
      messages.scrollTop = messages.scrollHeight;
    };
    const hideTyping = () => {
      document.getElementById('kp-typing-msg')?.remove();
    };

    // Smart reply lookup
    const replyFor = (text) => {
      const t = text.toLowerCase();
      if (/chatbot|แชทบอท|line|ตอบลูกค้า|messenger/.test(t)) {
        return 'ได้เลยครับ — เราตั้งค่า chatbot บน LINE OA / Facebook / เว็บ ให้ตอบลูกค้า 24 ชม. คัดกรองแล้วส่งต่อทีมขายปิดงาน<br><br>เริ่มต้น <strong class="text-[#7BE8FF]">15,000 บาท</strong> ใช้เวลา 1–2 สัปดาห์ เริ่มลองดูไหมครับ? 💬';
      }
      if (/automation|workflow|n8n|zapier|make|เชื่อม|อัตโนมัติ/.test(t)) {
        return 'เราเชื่อมระบบต่าง ๆ ให้ทำงานเอง — ฟอร์ม → Sheet → CRM → แจ้งทีม ประหยัดเวลางานซ้ำ ๆ ได้ ~60%<br><br>เริ่มต้น <strong class="text-[#7BE8FF]">20,000 บาท</strong> ขึ้นกับความซับซ้อน ⚡';
      }
      if (/dashboard|แดชบอร์ด|กราฟ|ข้อมูล|รายงาน|ยอดขาย/.test(t)) {
        return 'Dashboard ดูยอดขาย / ลีด / KPI เรียลไทม์ ทำด้วย Metabase, Grafana หรือ React ได้ครับ<br><br>เริ่มต้น <strong class="text-[#7BE8FF]">25,000 บาท</strong> รวมเชื่อมฐานข้อมูลเดิม 📊';
      }
      if (/ราคา|price|เท่าไหร่|งบ|เริ่มต้น/.test(t)) {
        return 'ขึ้นกับสโคปครับ:<br>• Chatbot เริ่ม <strong class="text-[#7BE8FF]">15,000฿</strong><br>• Automation เริ่ม <strong class="text-[#7BE8FF]">20,000฿</strong><br>• Dashboard เริ่ม <strong class="text-[#7BE8FF]">25,000฿</strong><br><br>ปรึกษาฟรี ไม่บังคับใช้บริการ — เล่าโจทย์มาได้เลยครับ 🙏';
      }
      if (/สวัสดี|hello|hi|ทัก/.test(t)) {
        return 'สวัสดีครับ! ผมช่วยอะไรได้บ้างครับ? ลองเลือกจากตัวเลือกด้านบน หรือเล่าปัญหาในทีมมาเลยได้เลย 😊';
      }
      return 'ขอบคุณที่ติดต่อเข้ามาครับ 🙏 โจทย์แบบนี้เราทำได้ — ขอ LINE หรือเบอร์ติดต่อเพื่อคุยรายละเอียดเพิ่มเติมได้ไหมครับ?<br><br>หรือแอดไลน์ <a href="https://line.me/R/ti/p/@korpai" target="_blank" class="text-[#7BE8FF] underline">@korpai</a> ตอบภายใน 24 ชม.';
    };

    const handleSend = (text) => {
      if (!text.trim()) return;
      qrWrap?.remove();
      addUserMsg(text);
      input.value = '';
      showTyping();
      setTimeout(() => {
        hideTyping();
        addBotMsg(replyFor(text));
      }, 900 + Math.random() * 600);
    };

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      handleSend(input.value);
    });

    // Quick-reply buttons
    qrWrap?.addEventListener('click', (e) => {
      const btn = e.target.closest('.kp-qr');
      if (!btn) return;
      handleSend(btn.dataset.reply || btn.textContent || '');
    });

    // Close on ESC
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && panel.classList.contains('is-open')) close();
    });
  })();
</script>
