---
/**
 * ContactFloat — sticky bottom-right contact buttons.
 * แทนที่ ChatWidget เดิม (ปิดไปตามคำสั่งบอส 2026-04-24).
 * ลูกค้าทักผ่าน LINE/Facebook ตรง → รับโดย AI Sales (qualifier-handoff)
 * ที่ agents.korpai.co → บอสไผ่เข้ามาคุยปิดดีลใน LINE/FB เอง.
 */
const LINE_URL = 'https://lin.ee/Qt6Vri4';
const FB_URL   = 'https://m.me/korpaiix';
---

<div class="kp-contact-float" aria-label="ช่องทางติดต่อ">
  <a
    href={LINE_URL}
    target="_blank"
    rel="noopener"
    class="kp-cf-btn kp-cf-line"
    aria-label="ทักผ่าน LINE"
    data-cta="line"
  >
    <svg viewBox="0 0 24 24" class="kp-cf-icon" aria-hidden="true" fill="currentColor">
      <path d="M24 10.305C24 4.612 18.29 0 12 0 5.71 0 0 4.612 0 10.305c0 5.104 4.54 9.377 10.673 10.186.416.09.98.275 1.123.63.128.324.084.834.04 1.16l-.18 1.094c-.057.325-.26 1.27 1.113.693 1.374-.579 7.395-4.354 10.086-7.455C22.738 14.61 24 12.611 24 10.305"/>
    </svg>
    <span class="kp-cf-label">LINE</span>
  </a>

  <a
    href={FB_URL}
    target="_blank"
    rel="noopener"
    class="kp-cf-btn kp-cf-fb"
    aria-label="ทักผ่าน Facebook Messenger"
    data-cta="messenger"
  >
    <svg viewBox="0 0 24 24" class="kp-cf-icon" aria-hidden="true" fill="currentColor">
      <path d="M12 0C5.373 0 0 4.974 0 11.111c0 3.498 1.745 6.614 4.471 8.652V24l4.086-2.242c1.09.301 2.246.464 3.443.464 6.627 0 12-4.974 12-11.111S18.627 0 12 0zm1.193 14.963l-3.056-3.259-5.963 3.259L10.733 8l3.13 3.259L19.752 8l-6.559 6.963z"/>
    </svg>
    <span class="kp-cf-label">Messenger</span>
  </a>
</div>

<style>
  .kp-contact-float {
    position: fixed;
    right: 1rem;
    bottom: 1rem;
    z-index: 60;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    pointer-events: none;
  }
  .kp-cf-btn {
    pointer-events: auto;
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.7rem 1rem 0.7rem 0.85rem;
    border-radius: 999px;
    font-family: 'Inter', 'IBM Plex Sans Thai Looped', system-ui, sans-serif;
    font-weight: 600;
    font-size: 0.875rem;
    color: #fff;
    text-decoration: none;
    box-shadow:
      0 6px 20px -6px rgba(0, 0, 0, 0.45),
      0 2px 8px -2px rgba(0, 0, 0, 0.3),
      inset 0 1px 0 rgba(255, 255, 255, 0.15);
    transition: transform 180ms cubic-bezier(.2,.8,.2,1),
                box-shadow 180ms ease,
                filter 180ms ease;
    will-change: transform;
  }
  .kp-cf-btn:hover {
    transform: translateY(-2px) scale(1.03);
    filter: brightness(1.05);
    box-shadow:
      0 12px 28px -8px rgba(0, 0, 0, 0.55),
      0 4px 12px -2px rgba(0, 0, 0, 0.35),
      inset 0 1px 0 rgba(255, 255, 255, 0.2);
  }
  .kp-cf-btn:active { transform: translateY(0) scale(0.98); }

  .kp-cf-line {
    background: linear-gradient(135deg, #06C755 0%, #04A847 100%);
  }
  .kp-cf-fb {
    background: linear-gradient(135deg, #0084FF 0%, #1877F2 100%);
  }
  .kp-cf-icon {
    width: 1.1rem;
    height: 1.1rem;
    flex-shrink: 0;
  }
  .kp-cf-label {
    line-height: 1;
  }

  /* Mobile: keep label visible — buttons remain readable */
  @media (max-width: 480px) {
    .kp-contact-float {
      right: 0.75rem;
      bottom: 0.75rem;
      gap: 0.4rem;
    }
    .kp-cf-btn {
      padding: 0.6rem 0.9rem 0.6rem 0.75rem;
      font-size: 0.8rem;
    }
  }

  /* Reduced motion: no hover transform */
  @media (prefers-reduced-motion: reduce) {
    .kp-cf-btn,
    .kp-cf-btn:hover { transform: none; transition: none; }
  }
</style>
