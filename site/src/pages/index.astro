---
import Layout from '~/layouts/Layout.astro';
import Hero from '~/components/Hero.astro';
import ChatDemo from '~/components/ChatDemo.astro';
import Services from '~/components/Services.astro';
import Portfolio from '~/components/Portfolio.astro';
import Pricing from '~/components/Pricing.astro';
import About from '~/components/About.astro';
import FAQ from '~/components/FAQ.astro';
---

<Layout>
  <Hero />
  <ChatDemo />
  <Services />

  <!-- Process -->
  <section id="process" class="relative py-24 md:py-28 border-t kp-hairline">
    <div class="kp-container">
      <div class="max-w-2xl mx-auto text-center kp-reveal">
        <span class="kp-pill">ขั้นตอนการทำงาน</span>
        <h2 class="prose-kp mt-5">เริ่มเล็ก ส่งเร็ว ปรับจริง</h2>
        <p class="prose-kp mt-5">
          ออกแบบเป็นช่วงสั้น ๆ ส่งทุก 1–2 สัปดาห์ ทีมคุณเห็นผลเร็ว ตัดสินใจง่าย ไม่ต้องรอ 3 เดือนแล้วได้ของผิด
        </p>
      </div>

      <ol class="mt-14 grid gap-5 md:grid-cols-3">
        {[
          { n: '01', t: 'คุยโจทย์ + วาง flow', d: 'ฟังปัญหาจริงของทีม วาง user flow และเลือกเครื่องมือให้คุ้มงบ' },
          { n: '02', t: 'สร้าง prototype',     d: 'ส่งระบบทดลองภายใน 1–2 สัปดาห์ ทดสอบกับลูกค้าจริงทันที' },
          { n: '03', t: 'ส่งมอบ + ดูแล',       d: 'ส่งระบบที่ทีมใช้ต่อได้เอง พร้อมเอกสาร + dashboard ติดตามผล' },
        ].map((s, i) => (
          <li class="kp-card kp-reveal" style={`transition-delay:${i * 80}ms`}>
            <div class="text-[11px] font-mono tracking-[0.2em] text-brand-cyan-400">STEP {s.n}</div>
            <h3 class="prose-kp mt-3">{s.t}</h3>
            <p class="mt-2 text-sm leading-relaxed" style="color: #8AA0C5;">{s.d}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <Portfolio />
  <Pricing />
  <About />
  <FAQ />

  <!-- Contact CTA -->
  <section id="contact" class="relative py-28 md:py-32 border-t kp-hairline overflow-hidden">
    <!-- ambient beam glow -->
    <div aria-hidden="true" class="absolute inset-0 pointer-events-none">
      <div class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-[700px] h-[400px] rounded-full blur-3xl"
           style="background: radial-gradient(ellipse, rgba(38,215,246,0.18), rgba(60,124,255,0.10) 40%, transparent 70%);"></div>
    </div>

    <div class="kp-container relative">
      <div class="max-w-3xl mx-auto text-center kp-reveal">
        <span class="kp-pill">พร้อมเริ่มเลย?</span>
        <h2 class="prose-kp mt-5">ปรึกษาฟรี — ตอบกลับภายใน 24 ชม.</h2>
        <p class="prose-kp mt-5 mx-auto max-w-xl">
          ส่ง LINE หรือ Facebook มาเล่าโจทย์คร่าว ๆ — เราจะตอบกลับพร้อมไอเดียให้ดูก่อนว่าทำได้แค่ไหน
        </p>
        <div class="mt-9 flex flex-wrap items-center justify-center gap-4">
          <a href="https://lin.ee/Qt6Vri4" target="_blank" rel="noopener" class="kp-btn-line" aria-label="แชท LINE KORP AI">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M24 10.305C24 4.612 18.29 0 12 0 5.71 0 0 4.612 0 10.305c0 5.104 4.54 9.377 10.673 10.186.416.09.98.275 1.123.63.128.324.084.834.04 1.16l-.18 1.094c-.057.325-.26 1.27 1.113.693 1.374-.579 7.395-4.354 10.086-7.455C22.738 14.61 24 12.611 24 10.305M9.678 13.02a.23.23 0 0 1-.232.232H6.084a.23.23 0 0 1-.233-.232V8.028a.23.23 0 0 1 .233-.232h.84a.23.23 0 0 1 .233.232v3.918h2.289a.23.23 0 0 1 .232.233zm1.727 0a.23.23 0 0 1-.232.232h-.84a.23.23 0 0 1-.233-.232V8.028a.23.23 0 0 1 .233-.232h.84a.23.23 0 0 1 .232.232zm5.727 0a.23.23 0 0 1-.232.232h-.84a.24.24 0 0 1-.188-.094l-2.293-3.097v2.96a.23.23 0 0 1-.232.23h-.84a.23.23 0 0 1-.232-.23V8.027a.23.23 0 0 1 .232-.232h.857c.05 0 .138.02.196.102l2.284 3.084V8.028a.23.23 0 0 1 .232-.232h.84a.23.23 0 0 1 .232.232zm3.833-4.15a.23.23 0 0 1-.232.233h-2.29v.883h2.29a.23.23 0 0 1 .233.232v.84a.23.23 0 0 1-.232.232h-2.29v.884h2.29a.23.23 0 0 1 .232.232v.84a.23.23 0 0 1-.232.232h-3.362a.23.23 0 0 1-.233-.232V8.028a.23.23 0 0 1 .232-.232h3.362a.23.23 0 0 1 .233.232z"/>
            </svg>
            <span>Line KORP AI</span>
          </a>
          <a href="https://www.facebook.com/korpaiix" target="_blank" rel="noopener" class="kp-btn-fb" aria-label="Facebook Page KORPAIIX">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
            <span>Page : KORPAIIX</span>
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
