---
import '~/styles/global.css';
import Header from '~/components/Header.astro';
import Footer from '~/components/Footer.astro';
import ContactFloat from '~/components/ContactFloat.astro';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  image?: string;
}

const {
  title = 'KORP AI AUTOMATION — AI Agent & Automation สำหรับ SME ไทย',
  description = 'ทีม KORP AI ออกแบบ สร้าง และดูแลระบบ AI Chatbot, Automation, Dashboard ให้ธุรกิจ SME ไทยโตเร็วขึ้น ปรึกษาฟรี',
  canonical = 'https://korpai.co',
  image = 'https://korpai.co/og-default.png',
} = Astro.props;

const siteName = 'KORP AI AUTOMATION';
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': ['Organization', 'ProfessionalService'],
      '@id': 'https://korpai.co/#organization',
      name: siteName,
      alternateName: ['KORP AI', 'KORP AI Automation', 'คอร์ป เอไอ'],
      url: 'https://korpai.co',
      logo: {
        '@type': 'ImageObject',
        url: 'https://korpai.co/assets/logo-icon.png',
        width: 512,
        height: 512,
      },
      image: 'https://korpai.co/og-default.png',
      description,
      areaServed: [
        { '@type': 'Country', name: 'Thailand' },
        { '@type': 'Place', name: 'Southeast Asia' },
      ],
      knowsAbout: [
        'AI Chatbot',
        'Workflow Automation',
        'Business Dashboard',
        'RAG (Retrieval-Augmented Generation)',
        'Line Official Account',
        'Facebook Messenger Integration',
        'n8n Automation',
        'Claude API',
        'OpenAI API',
        'Gemini API',
        'PDPA Compliance',
        'Multi-LLM Gateway',
        'OpenRouter',
        'Model Context Protocol (MCP)',
      ],
      serviceType: ['AI Chatbot Development', 'Business Process Automation', 'Data Dashboard', 'Custom AI Integration'],
      sameAs: [
        'https://www.facebook.com/korpaiix',
        'https://lin.ee/Qt6Vri4',
      ],
      contactPoint: [
        {
          '@type': 'ContactPoint',
          contactType: 'customer service',
          availableLanguage: ['th', 'en'],
          areaServed: 'TH',
        },
      ],
    },
    {
      '@type': 'WebSite',
      '@id': 'https://korpai.co/#website',
      url: 'https://korpai.co',
      name: siteName,
      inLanguage: 'th-TH',
      publisher: { '@id': 'https://korpai.co/#organization' },
      potentialAction: {
        '@type': 'SearchAction',
        target: 'https://korpai.co/blog?q={search_term_string}',
        'query-input': 'required name=search_term_string',
      },
    },
  ],
};
---

<!DOCTYPE html>
<html lang="th">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#05070E" />

    <!-- Facebook domain verification (Meta Business Manager → Korpaii Kps) -->
    <meta name="facebook-domain-verification" content="g6n3ebsombzyiz1dzb5o2m678bc2zb" />

    <link rel="icon" type="image/png" sizes="32x32" href="/assets/favicon-32.png" />
    <link rel="alternate" type="application/rss+xml" title="KORP AI Blog RSS" href="/rss.xml" />
    <link rel="icon" type="image/png" sizes="512x512" href="/assets/logo-icon.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/assets/apple-touch-icon.png" />
    <link rel="canonical" href={canonical} />

    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- OpenGraph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={image} />
    <meta property="og:locale" content="th_TH" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />

    <!-- Fonts: Inter (Latin) + IBM Plex Sans Thai Looped (TH) + JetBrains Mono
         PERF: Async-load via media="print" + onload swap (non-blocking).
         Reduced weights to essentials only: Inter 400/600/800, Plex 400/600/700, Mono 600.
         Cuts ~6 font-file fetches and unblocks first paint on mobile (FCP 3.1s → ~1.3s). -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&family=IBM+Plex+Sans+Thai+Looped:wght@400;600;700&family=JetBrains+Mono:wght@600&display=swap"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&family=IBM+Plex+Sans+Thai+Looped:wght@400;600;700&family=JetBrains+Mono:wght@600&display=swap"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&family=IBM+Plex+Sans+Thai+Looped:wght@400;600;700&family=JetBrains+Mono:wght@600&display=swap"
      />
    </noscript>

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <!-- Google Analytics 4 (GA4) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-K7CN3N60TH"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-K7CN3N60TH');
    </script>
  </head>
  <body>
    <!-- Site-wide ambient backdrop: hero atmosphere on every section -->
    <div aria-hidden="true" class="kp-bg-ambient">
      <div class="kp-bg-orb kp-bg-orb-1"></div>
      <div class="kp-bg-orb kp-bg-orb-2"></div>
      <div class="kp-bg-orb kp-bg-orb-3"></div>
      <div class="kp-bg-halo"></div>
      <div class="kp-bg-rays">
        <span></span>
        <span></span>
        <span></span>
      </div>
    </div>

    <Header />
    <main>
      <slot />
    </main>
    <Footer />

    <ContactFloat />


    <script is:inline>
      (() => {
        if (typeof window === 'undefined') return;
        const els = document.querySelectorAll('.kp-reveal');

        // Soft reveal (uses CSS transition) — used by IO when the user
        // scrolls and the tab is visible.
        const reveal = (el) => el.classList.add('is-in');

        // Instant reveal (no transition) — required for hidden tabs and
        // backgrounded screenshots, where CSS transitions don't run and
        // would otherwise leave content stuck at opacity:0.
        const revealInstant = (el) => {
          el.style.transition = 'none';
          el.style.opacity = '1';
          el.style.transform = 'none';
          el.classList.add('is-in');
        };

        // No IO support: reveal everything immediately
        if (!('IntersectionObserver' in window)) {
          els.forEach(revealInstant);
          return;
        }

        // Eager pass: anything already in the viewport at script time
        // gets revealed instantly. This guarantees above-the-fold
        // content is visible even in background tabs.
        const vh = window.innerHeight || document.documentElement.clientHeight;
        const inView = (el) => {
          const r = el.getBoundingClientRect();
          return r.bottom > 0 && r.top < vh;
        };

        const io = new IntersectionObserver((entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) {
              reveal(e.target);
              io.unobserve(e.target);
            }
          });
        }, { threshold: 0.12 });

        els.forEach((el) => {
          if (inView(el)) {
            revealInstant(el);
          } else {
            io.observe(el);
          }
        });

        // Final safety net: 1.5s after page load, instant-reveal anything
        // still hidden (covers backgrounded tabs and slow IO callbacks).
        const fallback = () => {
          setTimeout(() => {
            els.forEach((el) => {
              if (!el.classList.contains('is-in')) revealInstant(el);
            });
          }, 1500);
        };
        if (document.readyState === 'complete') fallback();
        else window.addEventListener('load', fallback);
      })();
    </script>
  </body>
</html>
