---
const cases = [
  {
    client: 'พี่นิดแฟชั่น',
    industry: 'ร้านเสื้อผ้าออนไลน์',
    metric: '3x',
    metricLabel: 'ยอดขายเพิ่ม',
    note: 'ปิดการขายผ่าน AI บน Line OA · 2 เดือน',
    gradient: 'linear-gradient(135deg, #FF6B9D, #C94FFF)',
    emoji: '🛍️',
    img: 'https://images.unsplash.com/photo-1768127502130-bca3e208eba6?w=1200&auto=format&fit=crop&q=80',
  },
  {
    client: 'ครัวคุณยาย',
    industry: 'ร้านอาหารไทย',
    metric: '80%',
    metricLabel: 'จองโต๊ะผ่าน AI',
    note: 'จองโต๊ะอัตโนมัติ + จัดการคิวหน้าร้าน',
    gradient: 'linear-gradient(135deg, #FF9A3C, #FF3C3C)',
    emoji: '🍜',
    img: 'https://images.unsplash.com/photo-1758346970538-40d665b0afa0?w=1200&auto=format&fit=crop&q=80',
  },
  {
    client: 'Derma Clinic BKK',
    industry: 'คลินิกผิวหนัง',
    metric: '70%',
    metricLabel: 'ลดงาน admin',
    note: 'จองคิวหมอ + ส่งแผนที่ + เตือนก่อนวันนัด',
    gradient: 'linear-gradient(135deg, #26D7F6, #3C7CFF)',
    emoji: '🏥',
    img: 'https://images.unsplash.com/photo-1758691462123-8a17ae95d203?w=1200&auto=format&fit=crop&q=80',
  },
  {
    client: 'BKK Gadgets',
    industry: 'ร้าน IT Online',
    metric: '5x',
    metricLabel: 'ตอบลูกค้าเร็วขึ้น',
    note: 'AI ตอบสเปค + แนะนำสินค้า + เช็คสต็อก',
    gradient: 'linear-gradient(135deg, #7C5FFF, #3C7CFF)',
    emoji: '💻',
    img: 'https://images.unsplash.com/photo-1513258496099-48168024aec0?w=1200&auto=format&fit=crop&q=80',
  },
  {
    client: 'Pure Wellness',
    industry: 'สปา & Wellness',
    metric: '24/7',
    metricLabel: 'จองคิว auto',
    note: 'ลูกค้าจองได้ตอนร้านปิด · เพิ่มยอด 40%',
    gradient: 'linear-gradient(135deg, #22C55E, #26D7F6)',
    emoji: '🌿',
    img: 'https://images.unsplash.com/photo-1709755491926-f7aa83748967?w=1200&auto=format&fit=crop&q=80',
  },
  {
    client: 'Brew & Co',
    industry: 'ร้านกาแฟ Specialty',
    metric: '+25%',
    metricLabel: 'Upsell เมนู',
    note: 'AI แนะนำเมนูเด็ด + โปรมาคู่กับเค้ก',
    gradient: 'linear-gradient(135deg, #D4A574, #8B4513)',
    emoji: '☕',
    img: 'https://images.unsplash.com/photo-1774014045872-3cc2b5e7e816?w=1200&auto=format&fit=crop&q=80',
  },
];
---

<section id="portfolio" class="relative py-24 md:py-28 border-t kp-hairline">
  <div class="kp-container">
    <div class="max-w-2xl mx-auto text-center kp-reveal">
      <span class="kp-pill">ตัวอย่างโจทย์</span>
      <h2 class="prose-kp mt-5">โจทย์จริงที่เราออกแบบระบบให้ SME ไทย</h2>
      <p class="prose-kp mt-5">
        6 ตัวอย่างโจทย์ที่ทีม KORP เคยช่วย SME ออกแบบ · เปิดแบบไม่เผยชื่อลูกค้าจริง (เคารพ NDA) อยากดู demo สดทักมาคุยได้เลย
      </p>
    </div>

    <div class="mt-14 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
      {cases.map((c, i) => (
        <article class="kp-port-card kp-reveal" style={`transition-delay:${i * 60}ms`}>
          <div class="kp-port-cover" style={`background: ${c.gradient};`}>
            {c.img ? (
              <img src={c.img} alt={c.client} loading="lazy" />
            ) : (
              <div class="kp-port-placeholder">
                <span class="kp-port-emoji">{c.emoji}</span>
              </div>
            )}
            <div class="kp-port-metric">
              <div class="kp-port-metric-num">{c.metric}</div>
              <div class="kp-port-metric-label">{c.metricLabel}</div>
            </div>
          </div>
          <div class="kp-port-body">
            <div class="flex items-center justify-between">
              <h3 class="text-white text-lg font-semibold">{c.client}</h3>
              <span class="text-[11px]" style="color: #8AA0C5;">{c.industry}</span>
            </div>
            <p class="mt-2 text-sm leading-relaxed" style="color: #B8C5DE;">{c.note}</p>
          </div>
        </article>
      ))}
    </div>

    <!-- CTA -->
    <div class="mt-14 text-center kp-reveal">
      <p class="text-xs mb-5" style="color: #8AA0C5;">
        ชื่อและตัวเลขในตัวอย่างเป็น persona · ตัวเลขจริงของลูกค้าแต่ละรายแตกต่างกันตามโจทย์
      </p>
      <a href="#contact" class="kp-btn-secondary">
        ขอดู demo ระบบจริง
        <span aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</section>

<style>
  .kp-port-card {
    border-radius: 18px;
    background: rgba(15, 20, 32, 0.5);
    border: 1px solid rgba(255, 255, 255, 0.06);
    overflow: hidden;
    transition: transform 0.4s ease, border-color 0.3s ease, box-shadow 0.3s ease;
  }
  .kp-port-card:hover {
    transform: translateY(-4px);
    border-color: rgba(38, 215, 246, 0.25);
    box-shadow: 0 20px 50px rgba(0,0,0,0.4), 0 0 0 1px rgba(38,215,246,0.1);
  }

  .kp-port-cover {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
  }
  .kp-port-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s ease;
  }
  .kp-port-card:hover .kp-port-cover img {
    transform: scale(1.04);
  }
  /* Soft bottom vignette so the metric badge stays readable */
  .kp-port-cover::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(5,7,14,0) 45%, rgba(5,7,14,0.55) 100%);
    pointer-events: none;
  }
  .kp-port-placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background:
      radial-gradient(ellipse at top left, rgba(255,255,255,0.2), transparent 60%),
      radial-gradient(ellipse at bottom right, rgba(0,0,0,0.3), transparent 60%);
  }
  .kp-port-emoji {
    font-size: 72px;
    filter: drop-shadow(0 10px 20px rgba(0,0,0,0.3));
    transform: scale(1);
    transition: transform 0.4s ease;
  }
  .kp-port-card:hover .kp-port-emoji {
    transform: scale(1.1) rotate(-3deg);
  }

  /* Metric overlay */
  .kp-port-metric {
    position: absolute;
    left: 14px;
    bottom: 14px;
    padding: 10px 14px;
    background: rgba(0, 0, 0, 0.55);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-radius: 12px;
    border: 1px solid rgba(255, 255, 255, 0.15);
    z-index: 2;
  }
  .kp-port-metric-num {
    font-size: 22px;
    font-weight: 800;
    color: white;
    line-height: 1;
  }
  .kp-port-metric-label {
    font-size: 10px;
    color: rgba(255, 255, 255, 0.8);
    margin-top: 2px;
    font-weight: 600;
  }

  .kp-port-body {
    padding: 18px 20px 22px;
  }
</style>
