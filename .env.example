# =============================================================================
# KORP AI Landing — Environment Variables Template
# =============================================================================
# วิธีใช้:
#   1. copy ไฟล์นี้เป็น .env:  cp .env.example .env
#   2. กรอกค่าจริงที่ส่วนที่มี placeholder
#   3. ห้าม commit .env เข้า git (ถูก ignore แล้ว)
#
# กฎ:
#   - PUBLIC_* = ตัวแปรที่ Astro จะฝังลงใน client bundle (ผู้ใช้เว็บเห็นได้) — ห้ามใส่ secret
#   - ตัวแปรที่เหลือ = server-only, ห้ามให้หลุดไป client
# =============================================================================


# -----------------------------------------------------------------------------
# 1) Site meta (PUBLIC — จะ render ใน <meta> tags, canonical, sitemap)
# -----------------------------------------------------------------------------
PUBLIC_SITE_URL=https://korpai.co
PUBLIC_SITE_NAME=KORP AI AUTOMATION
PUBLIC_SITE_TAGLINE=AI Agent สำหรับธุรกิจไทย
PUBLIC_SITE_DESCRIPTION=ออกแบบและติดตั้งระบบ AI Agent, Chatbot, Automation และ Dashboard ให้ SME ไทย ปรึกษาฟรี
PUBLIC_SITE_LOCALE=th-TH
PUBLIC_SITE_LOGO=/logo.svg
PUBLIC_OG_IMAGE=/og-image.png


# -----------------------------------------------------------------------------
# 2) Contact / Handoff (PUBLIC — ใช้ใน CTA + chat agent handoff)
# -----------------------------------------------------------------------------
PUBLIC_LINE_OA_URL=https://line.me/R/ti/p/@korpai
PUBLIC_LINE_OA_ID=@korpai
PUBLIC_FB_PAGE_URL=https://m.me/korpai.automation
PUBLIC_FB_PAGE_NAME=KORP AI AUTOMATION
PUBLIC_PHONE=+66-XX-XXX-XXXX
PUBLIC_EMAIL=hello@korpai.co
PUBLIC_ADDRESS_CITY=Bangkok
PUBLIC_ADDRESS_COUNTRY=Thailand


# -----------------------------------------------------------------------------
# 3) AI Sales Agent — LLM routing via OpenRouter (server-only secret)
# -----------------------------------------------------------------------------
# สมัคร: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Fast model — ตอบทักทาย / FAQ / intent detection
OPENROUTER_MODEL_FAST=anthropic/claude-haiku-4.5

# Smart model — escalation เมื่อคำถามซับซ้อน (pricing inquiry, technical)
OPENROUTER_MODEL_SMART=anthropic/claude-sonnet-4.6

# Fallback model — เผื่อ rate limit
OPENROUTER_MODEL_FALLBACK=google/gemini-2.5-flash

# Max tokens / temperature
OPENROUTER_MAX_TOKENS=800
OPENROUTER_TEMPERATURE=0.4


# -----------------------------------------------------------------------------
# 4) Chat backend — FastAPI service (server-only)
# -----------------------------------------------------------------------------
CHAT_BACKEND_URL=http://127.0.0.1:8100
CHAT_BACKEND_SECRET=change-me-to-random-hex-64-chars

# Session / cookie
SESSION_SECRET=change-me-to-random-hex-64-chars
SESSION_COOKIE_NAME=korpai_chat_sid
SESSION_TTL_SECONDS=86400

# Redis (ใช้ container redis ที่รันอยู่บน VPS)
REDIS_URL=redis://127.0.0.1:6379/5


# -----------------------------------------------------------------------------
# 5) Rate limiting (anti-spam chat widget)
# -----------------------------------------------------------------------------
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=20
RATE_LIMIT_BAN_DURATION_SECONDS=600


# -----------------------------------------------------------------------------
# 6) Lead notifications (server-only, optional)
# -----------------------------------------------------------------------------
# เมื่อมี lead ใหม่ (คนขอ handoff ไป Line/FB) → ส่งแจ้งเตือน
SLACK_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Email notification (optional — ใช้ Resend / Sendgrid)
RESEND_API_KEY=
NOTIFY_EMAIL=korpaiix@gmail.com


# -----------------------------------------------------------------------------
# 7) Analytics (PUBLIC — tracking snippets)
# -----------------------------------------------------------------------------
# Google Analytics 4
PUBLIC_GA_ID=

# Umami (self-hosted alternative) — optional
PUBLIC_UMAMI_URL=
PUBLIC_UMAMI_WEBSITE_ID=

# Meta Pixel (Facebook Ads)
PUBLIC_META_PIXEL_ID=


# -----------------------------------------------------------------------------
# 8) SEO / GEO
# -----------------------------------------------------------------------------
PUBLIC_GOOGLE_SITE_VERIFICATION=
PUBLIC_BING_SITE_VERIFICATION=


# -----------------------------------------------------------------------------
# 9) Feature flags
# -----------------------------------------------------------------------------
PUBLIC_FEATURE_CHAT_WIDGET=true
PUBLIC_FEATURE_BLOG=true
PUBLIC_FEATURE_PORTFOLIO=true
PUBLIC_FEATURE_EN_LOCALE=false


# -----------------------------------------------------------------------------
# 10) Dev / debug
# -----------------------------------------------------------------------------
NODE_ENV=development
LOG_LEVEL=info
DEBUG_CHAT=false
