# ==========================================
# KORP AI Chat Backend — environment variables
# Copy this file to .env and fill in real values.
# ==========================================

# --- OpenRouter (LLM routing) ---------------------------
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Model routing
# Haiku = cheap/fast; Sonnet = pricing/technical depth
OPENROUTER_MODEL_FAST=anthropic/claude-haiku-4.5
OPENROUTER_MODEL_DEEP=anthropic/claude-sonnet-4.6

# Optional: sent as X-Title on OpenRouter so usage is labelled nicely
OPENROUTER_APP_TITLE=KORP AI Sales Agent
OPENROUTER_APP_URL=https://korpai.co

# --- Server ---------------------------------------------
CHAT_BIND_HOST=127.0.0.1
CHAT_BIND_PORT=8100
CHAT_CORS_ORIGINS=https://korpai.co,https://www.korpai.co

# --- Rate limiting (simple in-memory) -------------------
CHAT_RL_MAX_PER_MIN=20
CHAT_RL_MAX_PER_HOUR=120

# --- Session ------------------------------------------------
# IMPORTANT: do NOT put inline comments after values.
# systemd EnvironmentFile keeps everything after `=` literally,
# so "60   # comment" becomes the string "60   # comment" and
# Python's int() chokes. Always put comments on their own line.

# Prune sessions idle longer than this (minutes)
CHAT_SESSION_TTL_MIN=60
# Max user+assistant turns per session
CHAT_SESSION_MAX_TURNS=30
CHAT_COOKIE_NAME=korpai_chat_sid
# Set to false only for localhost dev
CHAT_COOKIE_SECURE=true

# --- Handoff notification (optional) --------------------
# If set, backend POSTs a JSON summary when user clicks handoff button.
# Slack-compatible incoming webhook works out of the box.
HANDOFF_WEBHOOK_URL=

# Line OA + Facebook Page deep-links (shown to user on handoff)
HANDOFF_LINE_URL=https://lin.ee/Qt6Vri4
HANDOFF_FB_URL=https://www.facebook.com/korpaiix

# --- Logging --------------------------------------------
LOG_LEVEL=INFO
