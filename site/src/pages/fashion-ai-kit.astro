        ['Product Description', 'Care note', 'เสื้อ knit', 'เพิ่มวิธีดูแลเพื่อลดปัญหาหลังขาย', 'เสื้อ knit สัมผัสนุ่ม ยืดหยุ่นกำลังดี แนะนำซักมือและตากพาดเพื่อรักษาทรง ไม่ควรแขวนตอนเปียก'],
      ],
    };
    let tab = 'faq';
    let item = 0;
    const setActive = () => {
      root.querySelectorAll('[data-demo-tab]').forEach((b) => b.classList.toggle('is-active', b.dataset.demoTab === tab));
      root.querySelectorAll('[data-demo-item]').forEach((b) => b.classList.toggle('is-active', Number(b.dataset.demoItem) === item));
      const row = data[tab][item];
      ['demoKind','demoMeta','demoTitle','demoBody','demoOutput'].forEach((id, i) => {
        const el = document.getElementById(id);
        if (el) el.textContent = row[i];
      });
    };
    root.querySelectorAll('[data-demo-tab]').forEach((b) => b.addEventListener('click', () => { tab = b.dataset.demoTab; item = 0; setActive(); }));
    root.querySelectorAll('[data-demo-item]').forEach((b) => b.addEventListener('click', () => { item = Number(b.dataset.demoItem); setActive(); }));
    root.querySelector('[data-copy-demo]')?.addEventListener('click', async (e) => {
      const btn = e.currentTarget;
      const text = document.getElementById('demoOutput')?.textContent || '';
      try { await navigator.clipboard.writeText(text); btn.textContent = 'Copied'; setTimeout(() => btn.textContent = 'Copy sample', 1200); } catch {}
