---
import '~/styles/global.css';
import Header from '~/components/Header.astro';
import Footer from '~/components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  image?: string;
}

const {
  title = 'KORP AI AUTOMATION — AI Agent & Automation สำหรับ SME ไทย',
  description = 'ทีม KORP AI ออกแบบ สร้าง และดูแลระบบ AI Chatbot, Automation, Dashboard ให้ธุรกิจ SME ไทยโตเร็วขึ้น ปรึกษาฟรี',
  canonical = 'https://korpai.co',
  image = 'https://korpai.co/og-default.png',
} = Astro.props;

const siteName = 'KORP AI AUTOMATION';
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: siteName,
  url: 'https://korpai.co',
  logo: 'https://korpai.co/assets/logo-icon.svg',
  description,
  sameAs: [],
  contactPoint: [
    { '@type': 'ContactPoint', contactType: 'customer service', availableLanguage: ['th', 'en'] },
  ],
};
---

<!DOCTYPE html>
<html lang="th">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#05070E" />
    <link rel="icon" type="image/svg+xml" href="/assets/logo-icon.svg" />
    <link rel="canonical" href={canonical} />

    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- OpenGraph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={image} />
    <meta property="og:locale" content="th_TH" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />

    <!-- Fonts: Inter (Latin) + IBM Plex Sans Thai Looped (TH) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=IBM+Plex+Sans+Thai+Looped:wght@300;400;500;600;700&display=swap"
    />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />

    <script is:inline>
      (() => {
        if (typeof window === 'undefined') return;
        const els = document.querySelectorAll('.kp-reveal');
        const reveal = (el) => el.classList.add('is-in');

        // No IO support: reveal everything immediately
        if (!('IntersectionObserver' in window)) {
          els.forEach(reveal);
          return;
        }

        // Eager reveal: anything already in the viewport at script time.
        // This guarantees above-the-fold content is visible even when the
        // tab is in the background (IntersectionObserver doesn't fire for
        // hidden tabs).
        const vh = window.innerHeight || document.documentElement.clientHeight;
        const inView = (el) => {
          const r = el.getBoundingClientRect();
          return r.bottom > 0 && r.top < vh;
        };

        const io = new IntersectionObserver((entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) {
              reveal(e.target);
              io.unobserve(e.target);
            }
          });
        }, { threshold: 0.12 });

        els.forEach((el) => {
          if (inView(el)) reveal(el);
          io.observe(el);
        });

        // Final safety net: 1.5s after page load, reveal anything still
        // hidden (covers backgrounded tabs and slow IO callbacks).
        const fallback = () => {
          setTimeout(() => {
            els.forEach((el) => {
              if (!el.classList.contains('is-in')) reveal(el);
            });
          }, 1500);
        };
        if (document.readyState === 'complete') fallback();
        else window.addEventListener('load', fallback);
      })();
    </script>
  </body>
</html>
