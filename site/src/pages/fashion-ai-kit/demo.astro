---
import Layout from '~/layouts/Layout.astro';
---
<Layout title="Mockup: Fashion AI Sales Automation Dashboard | KORP AI" description="Mockup หน้าตาระบบ AI Sales Automation สำหรับร้านเสื้อผ้าออนไลน์" canonical="https://korpai.co/fashion-ai-kit/demo">
  <section class="mock-shell">
    <aside class="app-sidebar">
      <a href="/fashion-ai-kit" class="back">← กลับหน้าแพ็กเกจ</a>
      <div class="app-brand"><div class="brand-logo">LS</div><div><b>Linn Studio</b><span>AI Sales Automation</span></div></div>
      <nav>
        <a class="active" href="#overview">Overview</a>
        <a href="#inbox">AI Inbox</a>
        <a href="#products">Products</a>
        <a href="#automation">Automation</a>
        <a href="#insights">Insights</a>
        <a href="#content">Content AI</a>
      </nav>
      <div class="agent-status"><small>AI Agent</small><strong>Online</strong><p>ตอบจากสินค้า 128 SKU + FAQ 84 ข้อ</p></div>
    </aside>

    <main class="app-main">
      <header class="app-topbar">
        <div><span class="crumb">Dashboard / Fashion Store</span><h1>AI Sales Automation Dashboard</h1></div>
        <div class="top-actions"><button>Export Report</button><a href="https://lin.ee/Qt6Vri4" target="_blank" rel="noopener">ขอระบบแบบนี้</a></div>
      </header>

      <section id="overview" class="kpi-grid">
        <article><small>AI handled today</small><b>186</b><span>+32% จากเมื่อวาน</span></article>
        <article><small>Handoff to admin</small><b>14</b><span>เฉพาะเคสเสี่ยง</span></article>
        <article><small>Hot SKU</small><b>Linen Dress</b><span>42 conversations</span></article>
        <article><small>Revenue assist</small><b>฿38,420</b><span>จากแชทที่ AI ช่วยปิด</span></article>
      </section>

      <section class="workspace-grid">
        <section id="inbox" class="panel inbox-panel">
          <div class="panel-head"><div><small>AI INBOX</small><h2>แชทลูกค้าแบบ real-time</h2></div><span class="live-dot">Live</span></div>
          <div class="inbox-layout">
            <div class="conversation-list">
              <button class="active"><b>คุณมายด์</b><span>ถามไซซ์เดรส Ivory</span><em>AI replying</em></button>
              <button><b>คุณแพรว</b><span>ขอส่งด่วน กทม.</span><em>Need admin</em></button>
              <button><b>คุณนัท</b><span>ถามกางเกงเอวสูง</span><em>Resolved</em></button>
              <button><b>คุณบี</b><span>ถามโปรซื้อ 2 ชิ้น</span><em>AI replying</em></button>
            </div>
            <div class="chat-window">
              <div class="chat-meta"><b>คุณมายด์</b><span>Intent: size recommendation · Confidence 91%</span></div>
              <div class="bubble customer">สูง 160 อก 36 เอว 28 เดรส Linen Straight สีครีมควรใส่ไซซ์ไหนดีคะ?</div>
              <div class="bubble ai">แนะนำไซซ์ L ค่ะ รุ่นนี้ทรงตรง ถ้าอก 36 จะใส่สบายกว่า M และยังได้ทรงสวย ไม่รัดช่วงอกนะคะ</div>
              <div class="bubble customer">ส่งวันนี้ได้ไหมคะ</div>
              <div class="bubble ai">ถ้าชำระก่อน 14:00 น. ร้านจัดส่งรอบวันนี้ได้ค่ะ ต้องการให้แอดมินส่งลิงก์ชำระเงินให้ไหมคะ?</div>
              <div class="ai-tools"><span>Used: Product DB</span><span>Used: Shipping Policy</span><span>Next: Send payment link</span></div>
            </div>
          </div>
        </section>

        <aside class="panel right-stack">
          <div class="panel-head compact"><div><small>AI DECISION</small><h2>เหตุผลที่ AI ใช้ตอบ</h2></div></div>
          <div class="decision-card"><small>Matched product</small><b>Linen Straight Dress — Ivory</b><p>Stock: M 4, L 8 · Length 112cm · Fit: straight / relaxed</p></div>
          <div class="decision-card"><small>Size rule</small><b>อก 36 → แนะนำ L</b><p>ถ้าลูกค้าชอบพอดีตัวให้เสนอ M เป็นทางเลือก แต่ default คือ L</p></div>
          <div class="decision-card warn"><small>Escalation rule</small><b>ส่งด่วน/ส่วนลด → ส่งต่อแอดมิน</b><p>AI ไม่อนุมัติส่วนลดหรือรับประกันส่งด่วนเอง</p></div>
        </aside>
      </section>

      <section class="lower-grid">
        <section id="products" class="panel product-panel">
          <div class="panel-head"><div><small>PRODUCT KNOWLEDGE</small><h2>ฐานข้อมูลสินค้าที่ AI ใช้อ้างอิง</h2></div><button>+ Add SKU</button></div>
          <div class="product-table">
            <div class="row head"><span>SKU</span><span>Stock</span><span>AI notes</span><span>Status</span></div>
            <div class="row"><b>Linen Straight Dress</b><span>M:4 / L:8</span><p>แนะนำ L เมื่ออก 36+, ทรงตรงไม่รัดเอว</p><em>Active</em></div>
            <div class="row"><b>Soft Tailored Pants</b><span>S:2 / M:9</span><p>เอวสูง ช่วยพรางสะโพก เหมาะกับ office look</p><em>Active</em></div>
            <div class="row"><b>Knit Relax Top</b><span>Free size</span><p>ต้องแจ้งวิธีซัก ห้ามแขวนตอนเปียก</p><em>Need photo</em></div>
          </div>
        </section>

        <section id="automation" class="panel automation-panel">
          <div class="panel-head"><div><small>AUTOMATION FLOW</small><h2>กฎการทำงานอัตโนมัติ</h2></div></div>
          <div class="flow-board">
            <div><small>Trigger</small><b>ลูกค้าถามไซซ์</b><p>ถามส่วนสูง/อก/เอวเพิ่มถ้ายังไม่ครบ</p></div>
            <span>→</span>
            <div><small>AI Action</small><b>แนะนำไซซ์</b><p>ตอบจาก fit rule + ตารางไซซ์</p></div>
            <span>→</span>
            <div><small>System</small><b>Log Insight</b><p>บันทึกว่าสินค้านี้ถูกถามไซซ์</p></div>
          </div>
        </section>
      </section>

      <section class="lower-grid bottom">
        <section id="insights" class="panel insights-panel">
          <div class="panel-head"><div><small>INSIGHTS</small><h2>ข้อมูลจากแชทที่เอาไปแก้ร้านได้</h2></div></div>
          <div class="chart-wrap"><div class="bar" style="height:86%"><span>Size</span></div><div class="bar" style="height:62%"><span>Shipping</span></div><div class="bar" style="height:48%"><span>Fabric</span></div><div class="bar" style="height:34%"><span>Return</span></div><div class="bar" style="height:28%"><span>Promo</span></div></div>
        </section>
        <section id="content" class="panel content-panel">
          <div class="panel-head"><div><small>CONTENT AI</small><h2>โพสต์ที่ AI แนะนำจากคำถามจริง</h2></div><button>Generate</button></div>
          <div class="content-ideas"><article><small>Post idea</small><b>อก 36 ใส่ M หรือ L?</b><p>ทำ carousel เทียบไซซ์ M/L พร้อมภาพคนสูง 158–165</p></article><article><small>TikTok hook</small><b>3 จุดที่ทำให้เดรสทรงตรงไม่ตัน</b><p>ตอบ pain เรื่องความยาวและช่วงอกที่ถามซ้ำ 42 ครั้ง</p></article></div>
        </section>
      </section>
    </main>
  </section>
</Layout>

<style>
.mock-shell{display:grid;grid-template-columns:286px 1fr;min-height:100vh;background:#05070e}.app-sidebar{position:sticky;top:0;height:100vh;padding:22px;border-right:1px solid rgba(255,255,255,.08);background:rgba(3,7,18,.9);backdrop-filter:blur(18px)}.back{color:#8aa0c5;text-decoration:none;font-size:13px}.app-brand{display:flex;gap:12px;align-items:center;margin-top:24px;padding:14px;border:1px solid rgba(255,255,255,.09);border-radius:20px;background:rgba(255,255,255,.04)}.brand-logo{width:44px;height:44px;border-radius:15px;background:#26d7f6;color:#061018;display:grid;place-items:center;font-weight:950}.app-brand b,.app-brand span{display:block}.app-brand b{color:white}.app-brand span{color:#8aa0c5;font-size:12px;margin-top:2px}.app-sidebar nav{display:grid;gap:8px;margin-top:24px}.app-sidebar nav a{color:#9fb0d0;text-decoration:none;padding:12px 14px;border-radius:14px;font-weight:800;font-size:13px}.app-sidebar nav a.active,.app-sidebar nav a:hover{color:white;background:rgba(38,215,246,.11);border:1px solid rgba(38,215,246,.20)}.agent-status{position:absolute;left:22px;right:22px;bottom:22px;border:1px solid rgba(16,185,129,.20);border-radius:20px;background:rgba(16,185,129,.08);padding:16px}.agent-status small{color:#a7f3d0;font-weight:900}.agent-status strong{display:block;color:white;margin-top:6px}.agent-status p{color:#8aa0c5;font-size:12px;line-height:1.5;margin-top:7px}.app-main{padding:26px clamp(18px,3vw,42px) 60px;max-width:1500px}.app-topbar{display:flex;justify-content:space-between;align-items:center;gap:20px}.crumb{color:#8aa0c5;font-size:13px}.app-topbar h1{color:white;font-size:34px;letter-spacing:-.035em;margin-top:4px}.top-actions{display:flex;gap:10px}.top-actions button,.top-actions a,.panel-head button{border:1px solid rgba(255,255,255,.12);border-radius:999px;background:rgba(255,255,255,.06);color:white;padding:10px 14px;text-decoration:none;font-weight:800}.top-actions a,.panel-head button{background:#26d7f6;color:#061018}.kpi-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-top:22px}.kpi-grid article,.panel{border:1px solid rgba(255,255,255,.09);border-radius:24px;background:linear-gradient(180deg,rgba(255,255,255,.065),rgba(255,255,255,.025));box-shadow:0 20px 60px rgba(0,0,0,.18)}.kpi-grid article{padding:18px}.kpi-grid small,.panel-head small,.decision-card small,.flow-board small,.content-ideas small{color:#26d7f6;font-weight:950;letter-spacing:.08em}.kpi-grid b{display:block;color:white;font-size:28px;margin-top:8px}.kpi-grid span{display:block;color:#a7f3d0;font-size:12px;margin-top:7px}.workspace-grid{display:grid;grid-template-columns:1fr 360px;gap:14px;margin-top:14px}.panel{padding:18px}.panel-head{display:flex;justify-content:space-between;align-items:flex-start;gap:12px;margin-bottom:16px}.panel-head h2{color:white;font-size:22px;margin-top:5px}.live-dot{color:#a7f3d0;background:rgba(16,185,129,.1);border:1px solid rgba(16,185,129,.22);border-radius:999px;padding:6px 10px;font-size:12px}.inbox-layout{display:grid;grid-template-columns:260px 1fr;gap:14px}.conversation-list{display:grid;gap:9px}.conversation-list button{text-align:left;border:1px solid rgba(255,255,255,.08);border-radius:16px;background:rgba(255,255,255,.035);padding:12px;color:white}.conversation-list button.active{border-color:rgba(38,215,246,.35);background:rgba(38,215,246,.09)}.conversation-list b,.conversation-list span,.conversation-list em{display:block}.conversation-list span{color:#8aa0c5;font-size:12px;margin-top:4px}.conversation-list em{color:#a7f3d0;font-style:normal;font-size:11px;margin-top:8px}.chat-window{border:1px solid rgba(255,255,255,.08);border-radius:22px;background:rgba(0,0,0,.18);padding:16px}.chat-meta{display:flex;justify-content:space-between;color:#8aa0c5;font-size:12px;margin-bottom:14px}.chat-meta b{color:white}.bubble{max-width:78%;border-radius:18px;padding:12px 14px;font-size:14px;line-height:1.6;margin-top:10px}.customer{background:rgba(255,255,255,.08);color:#dbe6fa}.ai{margin-left:auto;background:rgba(38,215,246,.15);border:1px solid rgba(38,215,246,.22);color:#effcff}.ai-tools{display:flex;flex-wrap:wrap;gap:8px;margin-top:14px}.ai-tools span{color:#9beeff;border:1px solid rgba(38,215,246,.18);border-radius:999px;padding:6px 9px;font-size:11px}.right-stack{display:grid;align-content:start;gap:12px}.decision-card{border:1px solid rgba(255,255,255,.08);border-radius:18px;background:rgba(255,255,255,.035);padding:14px}.decision-card.warn{border-color:rgba(251,191,36,.24);background:rgba(251,191,36,.06)}.decision-card b{display:block;color:white;margin-top:7px}.decision-card p{color:#8aa0c5;font-size:12px;line-height:1.55;margin-top:6px}.lower-grid{display:grid;grid-template-columns:1.2fr .8fr;gap:14px;margin-top:14px}.bottom{grid-template-columns:.8fr 1.2fr}.product-table{border:1px solid rgba(255,255,255,.08);border-radius:18px;overflow:hidden}.row{display:grid;grid-template-columns:1fr 120px 1.4fr 90px;gap:12px;padding:13px;border-top:1px solid rgba(255,255,255,.07);align-items:start}.row:first-child{border-top:0}.row.head{background:rgba(38,215,246,.1)}.row span,.row p,.row em{color:#aebddb;font-size:13px}.row b{color:white}.row em{color:#a7f3d0;font-style:normal}.flow-board{display:grid;grid-template-columns:1fr 24px 1fr 24px 1fr;gap:10px;align-items:center}.flow-board div{border:1px solid rgba(255,255,255,.08);border-radius:18px;padding:14px;background:rgba(255,255,255,.035)}.flow-board b{display:block;color:white;margin-top:7px}.flow-board p{color:#8aa0c5;font-size:12px;line-height:1.5;margin-top:6px}.flow-board>span{color:#26d7f6;text-align:center}.chart-wrap{height:260px;display:flex;align-items:end;gap:14px;padding:20px 8px 4px}.bar{flex:1;border-radius:14px 14px 8px 8px;background:linear-gradient(180deg,#26d7f6,rgba(38,215,246,.18));position:relative;min-height:50px}.bar span{position:absolute;bottom:-24px;color:#8aa0c5;font-size:12px;left:50%;transform:translateX(-50%)}.content-ideas{display:grid;grid-template-columns:1fr 1fr;gap:14px}.content-ideas article{border:1px solid rgba(255,255,255,.08);border-radius:18px;padding:16px;background:rgba(255,255,255,.035)}.content-ideas b{display:block;color:white;margin-top:8px}.content-ideas p{color:#aebddb;font-size:13px;line-height:1.6;margin-top:8px}@media(max-width:1100px){.mock-shell{grid-template-columns:1fr}.app-sidebar{position:relative;height:auto}.agent-status{position:static;margin-top:20px}.workspace-grid,.lower-grid,.bottom,.kpi-grid,.inbox-layout,.flow-board,.content-ideas{grid-template-columns:1fr}.flow-board>span{display:none}.app-topbar{display:block}.top-actions{margin-top:16px}.row{grid-template-columns:1fr}}
</style>
