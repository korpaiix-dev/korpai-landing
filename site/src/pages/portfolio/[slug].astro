---
import Layout from '~/layouts/Layout.astro';
import { portfolio, getCaseBySlug } from '~/data/portfolio';

export function getStaticPaths() {
  return portfolio.map((c) => ({ params: { slug: c.slug } }));
}

const { slug } = Astro.params;
const caseStudy = getCaseBySlug(slug!);
if (!caseStudy) {
  throw new Error(`Portfolio case not found: ${slug}`);
}

const pageTitle = `${caseStudy.client} · ${caseStudy.industry} — KORP AI`;
const canonical = `https://korpai.co/portfolio/${caseStudy.slug}`;
const ogImage = `https://korpai.co${caseStudy.img}`;

const otherCases = portfolio.filter((c) => c.slug !== caseStudy.slug).slice(0, 3);

// CreativeWork (Case Study) JSON-LD — answer-engine ready
const caseStudyJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CreativeWork',
  '@id': canonical,
  name: `${caseStudy.client} — ${caseStudy.industry}`,
  headline: caseStudy.tagline,
  description: caseStudy.seoDesc,
  url: canonical,
  image: ogImage,
  inLanguage: 'th-TH',
  about: caseStudy.industry,
  keywords: caseStudy.techUsed.join(', '),
  author: {
    '@type': 'Organization',
    name: 'KORP AI AUTOMATION',
    url: 'https://korpai.co',
  },
  publisher: {
    '@type': 'Organization',
    name: 'KORP AI AUTOMATION',
    url: 'https://korpai.co',
    logo: { '@type': 'ImageObject', url: 'https://korpai.co/assets/logo-icon.png' },
  },
  workExample: caseStudy.outcome.map((o) => ({
    '@type': 'Thing',
    name: o.label,
    description: `${o.metric} — ${o.detail}`,
  })),
};

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'หน้าแรก', item: 'https://korpai.co/' },
    { '@type': 'ListItem', position: 2, name: 'ผลงาน', item: 'https://korpai.co/#portfolio' },
    { '@type': 'ListItem', position: 3, name: caseStudy.client, item: canonical },
  ],
};
---

<Layout title={pageTitle} description={caseStudy.seoDesc} canonical={canonical} image={ogImage}>
  <script type="application/ld+json" set:html={JSON.stringify(caseStudyJsonLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />
  <article class="kp-detail">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="kp-container pt-28 md:pt-32">
      <ol class="kp-breadcrumb">
        <li><a href="/">หน้าแรก</a></li>
        <li aria-hidden="true">/</li>
        <li><a href="/#portfolio">ผลงาน</a></li>
        <li aria-hidden="true">/</li>
        <li aria-current="page">{caseStudy.client}</li>
      </ol>
    </nav>

    <!-- Hero -->
    <section class="kp-container pt-6 pb-12 md:pt-10 md:pb-16">
      <div class="grid gap-10 md:grid-cols-2 md:gap-12 items-center">
        <div class="kp-reveal">
          <span class="kp-eyebrow">Case · {caseStudy.industry}</span>
          <h1 class="prose-kp mt-5 text-4xl md:text-5xl lg:text-6xl font-extrabold tracking-tight text-white">
            {caseStudy.client}
          </h1>
          <p class="prose-kp mt-6 text-lg leading-relaxed" style="color: #B8C5DE;">
            {caseStudy.tagline}
          </p>
          <div class="mt-7 inline-flex items-baseline gap-3 px-5 py-3 rounded-2xl" style="background: rgba(38,215,246,0.08); border: 1px solid rgba(38,215,246,0.18);">
            <span class="text-4xl font-extrabold kp-grad">{caseStudy.metric}</span>
            <span class="text-sm" style="color: #B8C5DE;">{caseStudy.metricLabel}</span>
          </div>
          <div class="mt-8 flex flex-wrap gap-3">
            <a href="/#contact" class="kp-btn-primary">
              มีโจทย์คล้ายกัน? คุยฟรี
              <span aria-hidden="true">→</span>
            </a>
            <a href="https://lin.ee/Qt6Vri4" target="_blank" rel="noopener" class="kp-btn-secondary">
              ทักผ่าน Line
            </a>
          </div>
          <p class="mt-6 text-xs" style="color: #8AA0C5;">
            persona · ตัวเลขเป็นตัวอย่าง · ทำงานจริงเคารพ NDA ลูกค้า
          </p>
        </div>
        <div class="kp-reveal kp-detail-hero-img" style={`background: ${caseStudy.gradient};`}>
          <img src={caseStudy.img} alt={caseStudy.alt} loading="eager" />
          <div class="kp-detail-hero-tag">
            <span class="kp-detail-hero-tag-num">{caseStudy.metric}</span>
            <span class="kp-detail-hero-tag-label">{caseStudy.metricLabel}</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Challenge -->
    <section class="kp-container py-14 md:py-16 border-t kp-hairline">
      <div class="grid gap-10 md:grid-cols-[1fr_2fr] md:gap-14 items-start">
        <div class="kp-reveal">
          <span class="kp-eyebrow">Challenge</span>
          <h2 class="prose-kp mt-5 text-3xl md:text-4xl font-bold text-white">
            โจทย์ของลูกค้า
          </h2>
        </div>
        <p class="prose-kp text-lg leading-relaxed kp-reveal" style="color: #B8C5DE;">
          {caseStudy.challenge}
        </p>
      </div>
    </section>

    <!-- Approach -->
    <section class="kp-container py-14 md:py-16 border-t kp-hairline">
      <div class="max-w-3xl kp-reveal">
        <span class="kp-eyebrow">What we built</span>
        <h2 class="prose-kp mt-5 text-3xl md:text-4xl font-bold text-white">
          สิ่งที่เราทำให้
        </h2>
      </div>
      <ul class="mt-10 grid gap-4">
        {caseStudy.approach.map((a, i) => (
          <li class="kp-detail-step kp-reveal" style={`transition-delay:${i * 60}ms`}>
            <span class="kp-detail-step-num">{String(i + 1).padStart(2, '0')}</span>
            <div>
              <p class="text-base leading-relaxed" style="color: #D6DFF2;">{a}</p>
            </div>
          </li>
        ))}
      </ul>
    </section>

    <!-- Outcome -->
    <section class="kp-container py-14 md:py-16 border-t kp-hairline">
      <div class="max-w-3xl kp-reveal">
        <span class="kp-eyebrow">Outcome</span>
        <h2 class="prose-kp mt-5 text-3xl md:text-4xl font-bold text-white">
          ผลลัพธ์ที่เกิดขึ้น
        </h2>
        <p class="prose-kp mt-4" style="color: #8AA0C5;">
          ตัวเลขเป็นของ persona นี้ · ลูกค้าจริงแต่ละรายแตกต่างกันตามโจทย์และบริบท
        </p>
      </div>
      <div class="mt-10 grid gap-5 md:grid-cols-3">
        {caseStudy.outcome.map((o, i) => (
          <article class="kp-rc-card kp-outcome-card kp-reveal" style={`transition-delay:${i * 80}ms`}>
            <div class="kp-outcome-metric">{o.metric}</div>
            <div class="kp-outcome-label">{o.label}</div>
            <p class="mt-3 text-sm leading-relaxed" style="color: #B8C5DE;">{o.detail}</p>
          </article>
        ))}
      </div>
    </section>

    <!-- Tech + meta -->
    <section class="kp-container py-14 md:py-16 border-t kp-hairline">
      <div class="grid gap-12 md:grid-cols-2">
        <div class="kp-reveal">
          <span class="kp-eyebrow">Tech used</span>
          <h3 class="prose-kp mt-4 text-2xl font-bold text-white">เทคโนโลยีที่ใช้</h3>
          <div class="mt-6 flex flex-wrap gap-2.5">
            {caseStudy.techUsed.map((t) => (
              <span class="kp-tech-chip">{t}</span>
            ))}
          </div>
        </div>
        <div class="kp-reveal">
          <span class="kp-eyebrow">Project meta</span>
          <h3 class="prose-kp mt-4 text-2xl font-bold text-white">รายละเอียดโปรเจกต์</h3>
          <dl class="mt-6 space-y-4">
            <div>
              <dt class="text-xs uppercase tracking-wider" style="color: #8AA0C5;">Timeline</dt>
              <dd class="mt-1 text-base" style="color: #E8EEF9;">{caseStudy.timeline}</dd>
            </div>
            <div>
              <dt class="text-xs uppercase tracking-wider" style="color: #8AA0C5;">Handoff</dt>
              <dd class="mt-1 text-base leading-relaxed" style="color: #D6DFF2;">{caseStudy.handoff}</dd>
            </div>
            <div>
              <dt class="text-xs uppercase tracking-wider" style="color: #8AA0C5;">Industry</dt>
              <dd class="mt-1 text-base" style="color: #E8EEF9;">{caseStudy.industry}</dd>
            </div>
          </dl>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="kp-container py-16 md:py-20 border-t kp-hairline">
      <div class="kp-rc-card kp-detail-cta text-center kp-reveal">
        <span class="kp-eyebrow kp-eyebrow--cyan">Your turn</span>
        <h2 class="prose-kp mt-4 text-3xl md:text-4xl font-bold text-white">
          มีโจทย์คล้าย ๆ กันอยู่ใช่ไหม?
        </h2>
        <p class="prose-kp mt-4 max-w-2xl mx-auto" style="color: #B8C5DE;">
          ส่งรายละเอียดธุรกิจมาได้เลย — ฟรี 20-30 นาที เรา walk through demo ระบบจริงที่เราทำให้ลูกค้าอื่น แล้วประเมินให้ว่าเหมาะกับคุณไหม
        </p>
        <div class="mt-8 flex flex-wrap gap-3 justify-center">
          <a href="/#contact" class="kp-btn-primary">
            ปรึกษาฟรี
            <span aria-hidden="true">→</span>
          </a>
          <a href="https://lin.ee/Qt6Vri4" target="_blank" rel="noopener" class="kp-btn-secondary">
            Line OA
          </a>
        </div>
      </div>
    </section>

    <!-- Other cases -->
    <section class="kp-container py-14 md:py-16 border-t kp-hairline">
      <div class="max-w-3xl kp-reveal">
        <span class="kp-eyebrow">More cases</span>
        <h2 class="prose-kp mt-5 text-2xl md:text-3xl font-bold text-white">ตัวอย่างโจทย์อื่น ๆ</h2>
      </div>
      <div class="mt-8 grid gap-4 md:grid-cols-3">
        {otherCases.map((c) => (
          <a href={`/portfolio/${c.slug}`} class="kp-rc-card kp-other-card kp-reveal">
            <div class="kp-other-img" style={`background: ${c.gradient};`}>
              <img src={c.img} alt={c.alt} loading="lazy" />
            </div>
            <div class="kp-other-body">
              <div class="flex items-center justify-between">
                <span class="kp-rc-num">{c.metric}</span>
                <span class="text-[11px]" style="color: #8AA0C5;">{c.industry}</span>
              </div>
              <h3 class="mt-2 text-base font-semibold text-white">{c.client}</h3>
              <p class="mt-1 text-xs leading-relaxed" style="color: #8AA0C5;">{c.note}</p>
            </div>
          </a>
        ))}
      </div>
    </section>
  </article>
</Layout>

<style>
  .kp-breadcrumb {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 12px;
    color: #8AA0C5;
  }
  .kp-breadcrumb a {
    color: #8AA0C5;
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .kp-breadcrumb a:hover { color: #26D7F6; }
  .kp-breadcrumb [aria-current="page"] {
    color: #E8EEF9;
  }

  .kp-detail-hero-img {
    position: relative;
    border-radius: 20px;
    overflow: hidden;
    border: 1px solid rgba(255,255,255,0.06);
    aspect-ratio: 5 / 4;
    box-shadow:
      0 40px 80px -20px rgba(0,0,0,0.6),
      0 0 0 1px rgba(38,215,246,0.06);
  }
  .kp-detail-hero-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .kp-detail-hero-img::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(5,7,14,0) 55%, rgba(5,7,14,0.55) 100%);
    pointer-events: none;
  }
  .kp-detail-hero-tag {
    position: absolute;
    left: 18px;
    bottom: 18px;
    padding: 12px 16px;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-radius: 14px;
    border: 1px solid rgba(255, 255, 255, 0.15);
    z-index: 2;
  }
  .kp-detail-hero-tag-num {
    display: block;
    font-size: 28px;
    font-weight: 800;
    color: white;
    line-height: 1;
  }
  .kp-detail-hero-tag-label {
    display: block;
    margin-top: 4px;
    font-size: 11px;
    color: rgba(255, 255, 255, 0.85);
    font-weight: 600;
  }

  .kp-detail-step {
    display: flex;
    align-items: flex-start;
    gap: 18px;
    padding: 18px 22px;
    background: rgba(15, 20, 32, 0.4);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 14px;
    transition: border-color 0.3s ease, transform 0.3s ease;
  }
  .kp-detail-step:hover {
    border-color: rgba(124,95,255,0.28);
    transform: translateX(3px);
  }
  .kp-detail-step-num {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 16px;
    font-weight: 700;
    color: #7C5FFF;
    min-width: 38px;
    padding-top: 3px;
  }

  .kp-outcome-card {
    padding: 26px 24px;
    text-align: left;
    background:
      radial-gradient(ellipse at top right, rgba(38,215,246,0.06), transparent 60%),
      rgba(15, 20, 32, 0.55);
  }
  .kp-outcome-metric {
    font-family: 'Inter', sans-serif;
    font-size: 40px;
    font-weight: 800;
    line-height: 1;
    background: linear-gradient(135deg, #26D7F6, #7C5FFF);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .kp-outcome-label {
    margin-top: 8px;
    font-size: 13px;
    font-weight: 600;
    color: #E8EEF9;
    letter-spacing: 0.02em;
  }

  .kp-tech-chip {
    padding: 8px 14px;
    border-radius: 9999px;
    background: rgba(15,20,32,0.6);
    border: 1px solid rgba(255,255,255,0.08);
    color: #D6DFF2;
    font-size: 13px;
    font-weight: 500;
    transition: border-color 0.2s ease, background 0.2s ease;
  }
  .kp-tech-chip:hover {
    border-color: rgba(38,215,246,0.3);
    background: rgba(20,28,44,0.7);
  }

  .kp-detail-cta {
    padding: 48px 32px;
    background:
      radial-gradient(ellipse at top, rgba(38,215,246,0.08), transparent 55%),
      rgba(15, 20, 32, 0.55);
    border: 1px solid rgba(38,215,246,0.12);
  }

  .kp-other-card {
    padding: 0;
    display: block;
    text-decoration: none;
    color: inherit;
    overflow: hidden;
    transition: border-color 0.3s ease, transform 0.3s ease;
  }
  .kp-other-card:hover {
    border-color: rgba(38,215,246,0.25);
    transform: translateY(-3px);
  }
  .kp-other-img {
    aspect-ratio: 16 / 9;
    overflow: hidden;
  }
  .kp-other-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .kp-other-card:hover .kp-other-img img { transform: scale(1.04); }
  .kp-other-body { padding: 16px 18px 20px; }
</style>
