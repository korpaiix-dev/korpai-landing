[Unit]
Description=KORP AI Chat Backend (FastAPI + uvicorn)
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/korpai-chat
EnvironmentFile=/opt/korpai-chat/.env
ExecStart=/opt/korpai-chat/.venv/bin/uvicorn main:app --host 127.0.0.1 --port 8100 --log-level info
Restart=always
RestartSec=3
User=root
# Modest security hardening
NoNewPrivileges=true
ProtectSystem=strict
ReadWritePaths=/opt/korpai-chat
ProtectHome=true
PrivateTmp=true

[Install]
WantedBy=multi-user.target
