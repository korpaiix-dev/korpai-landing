a;font-size:11px;font-weight:900;margin-bottom:5px}.msg.customer{background:rgba(255,255,255,.08);color:#fff}.msg.ai{margin-left:auto;background:rgba(244,211,161,.12);border:1px solid rgba(244,211,161,.22);color:#fff7ec}.suggestion{border:1px solid rgba(244,211,161,.22);border-radius:20px;background:rgba(244,211,161,.08);padding:14px}.suggestion label{color:#f0c48a;font-weight:900;font-size:12px}.suggestion p{margin:8px 0 0;color:#fff;line-height:1.55}.suggestion div{display:flex;justify-content:flex-end;gap:8px;margin-top:12px}.composer{display:flex;gap:10px;margin-top:12px}.composer input{flex:1;min-width:0;border:1px solid rgba(255,255,255,.10);border-radius:999px;background:rgba(0,0,0,.22);color:#fff;padding:0 15px}.right-col{display:grid;align-content:start;gap:14px}.customer-card h3,.product-card h3{color:#fff;margin:12px 0 0}.customer-card p,.product-card p{color:#b9aa99;font-size:13px;line-height:1.55}.tags{display:flex;flex-wrap:wrap;gap:8px;margin-top:14px}.tags span{color:#f0c48a;border:1px solid rgba(244,211,161,.22);border-radius:999px;padding:6px 9px;font-size:11px}.product-img,.pic{height:145px;border-radius:18px;background:linear-gradient(135deg,rgba(244,211,161,.16),rgba(38,215,246,.10)),url('/assets/img/fashion-ai-kit/store-ops.png') center/cover;border:1px solid rgba(255,255,255,.10)}.product-card ul{margin-top:12px;padding-left:18px;color:#eadfd2;font-size:13px;line-height:1.8}.product-grid,.answer-list,.insight-grid,.order-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:14px}.product-grid article,.answer-list article{border:1px solid rgba(255,255,255,.10);border-radius:20px;padding:14px;background:rgba(255,255,255,.035)}.product-grid b,.answer-list b{display:block;margin-top:12px;color:#fff}.product-grid span{color:#f0c48a;font-size:12px}.product-grid p,.answer-list p,.insight-grid p,.insight-grid li{color:#cdbfaf;line-height:1.6}.pic.p2{background-image:linear-gradient(135deg,rgba(244,211,161,.16),rgba(38,215,246,.10)),url('/assets/im