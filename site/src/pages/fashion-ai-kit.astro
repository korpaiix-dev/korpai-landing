  .doc-content { margin-top:16px; }
  .real-table { border-radius:18px; border:1px solid rgba(255,255,255,.08); overflow:hidden; }
  .real-row { display:grid; grid-template-columns:76px 1.05fr 1.55fr; gap:12px; align-items:start; padding:12px 13px; border-top:1px solid rgba(255,255,255,.07); background:rgba(255,255,255,.025); }
  .real-row:first-child { border-top:0; }
  .real-head { background:rgba(38,215,246,.10); }
  .real-head span { color:#9beeff; font-size:11px; font-weight:950; letter-spacing:.08em; }
  .real-row span { color:#26d7f6; font-size:11px; font-weight:900; }
  .real-row b { color:white; font-size:13px; line-height:1.45; }
  .real-row p { margin:0; color:#b7c5df; font-size:12.5px; line-height:1.6; }
  .chat-thread { display:grid; gap:10px; }
  .bubble { max-width:88%; border-radius:18px; padding:12px 14px; font-size:13px; line-height:1.6; }
  .bubble.customer { background:rgba(255,255,255,.075); color:#d9e3f7; }
  .bubble.admin { margin-left:auto; background:rgba(38,215,246,.14); border:1px solid rgba(38,215,246,.22); color:#effcff; }
  .script-note { margin-top:12px; border-radius:16px; padding:13px; background:rgba(0,0,0,.22); color:#9fb0d0; font-size:12px; line-height:1.55; }
  .calendar-grid { display:grid; grid-template-columns:repeat(2,minmax(0,1fr)); gap:12px; }
  .content-card { border-radius:18px; border:1px solid rgba(255,255,255,.085); background:rgba(255,255,255,.04); padding:14px; }
  .content-card small { color:#26d7f6; font-weight:900; }
  .content-card b { display:block; margin-top:8px; color:white; font-size:14px; }
  .content-card p { margin-top:7px; color:#b7c5df; font-size:12.5px; line-height:1.6; }
  .hook-list { display:grid; gap:10px; }
  .hook-item { display:grid; grid-template-columns:38px 1fr; gap:12px; border-radius:17px; border:1px solid rgba(255,255,255,.08); background:rgba(255,255,255,.035); padding:13px; }
  .hook-item span { color:#26d7f6; font-family:ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace; font-size:12px; }
  .hook-item b { color:white; font-size:13px; }
  .hook-item p { margin-top:4px; color:#b7c5df; font-size:12.5px; line-height:1.55; }
  .sku-sheet { display:grid; grid-template-columns:.75fr 1.25fr; gap:12px; }
  .sku-photo { border-radius:20px; min-height:230px; background:linear-gradient(135deg, rgba(38,215,246,.18), rgba(124,95,255,.16)), url('/assets/img/fashion-ai-kit/hero.jpg') center/cover; border:1px solid rgba(255,255,255,.10); }
  .sku-fields { display:grid; gap:10px; }
  .field { border-radius:15px; background:rgba(255,255,255,.04); border:1px solid rgba(255,255,255,.08); padding:11px; }
  .field small { color:#26d7f6; font-weight:900; }
  .field p { margin-top:5px; color:#dce6f8; font-size:12.5px; line-height:1.55; }
  @media (max-width:760px) {
    .real-row, .sku-sheet { grid-template-columns:1fr; }
    .calendar-grid { grid-template-columns:1fr; }
    .sample-document { min-height:auto; }
  }
</style>

<script is:inline>
  (() => {
    const root = document.querySelector('[data-sample-workspace]');
    if (!root) return;
    const samples = {
      faq: {
        type: 'FAQ SHEET', title: 'FAQ พร้อมใช้สำหรับแอดมิน 60 ข้อ', count: 'Preview 3/60',
        html: `<div class="real-table">
          <div class="real-row real-head"><span>หมวด</span><span>คำถามลูกค้า</span><span>คำตอบที่แอดมินใช้ตอบได้ทันที</span></div>
          <div class="real-row"><span>ไซซ์</span><b>อก 36 ใส่ M ได้ไหม?</b><p>ถ้าชอบพอดีตัวใส่ M ได้ค่ะ แต่ถ้าชอบสบายช่วงอก แนะนำ L จะขยับง่ายกว่า เดี๋ยวแอดมินส่งตารางไซซ์ให้เทียบอีกครั้งนะคะ</p></div>
          <div class="real-row"><span>จัดส่ง</span><b>โอนแล้วส่งวันนี้ไหม?</b><p>ถ้าชำระก่อน 14:00 น. ร้านจัดส่งรอบวันนี้ได้ค่ะ หลังแพ็กเสร็จจะแจ้งเลขพัสดุให้ในแชทนี้นะคะ</p></div>
          <div class="real-row"><span>ดูแลผ้า</span><b>ผ้าลินินซักเครื่องได้ไหม?</b><p>ซักเครื่องได้โดยใส่ถุงถนอมผ้าและเลือกโหมดอ่อนโยนค่ะ แนะนำตากในที่ร่มเพื่อช่วยรักษาทรงและสีของผ้า</p></div>
        </div>`
      },
      chat: {
        type: 'CHAT SCRIPT', title: 'Template ตอบแชทแบบ conversation', count: 'Preview 1/60',
        html: `<div class="chat-thread">
          <div class="bubble customer">สูง 160 หนัก 52 อก 36 เอว 28 ใส่เดรสตัวนี้ไซซ์ไหนดีคะ?</div>
          <div class="bubble admin">จากสัดส่วนที่แจ้งมา แนะนำไซซ์ L ค่ะ ช่วงอกจะใส่สบายกว่า M และยังได้ทรงตรงสวย ไม่รัดช่วงเอวเกินไปนะคะ</div>
          <div class="bubble customer">ถ้าอยากใส่พอดีตัวล่ะคะ?</div>
          <div class="bubble admin">ถ้าชอบพอดีตัวมาก ๆ M ใส่ได้ค่ะ แต่แอดมินแนะนำ L มากกว่า เพราะผ้าทรงนี้เวลานั่ง/เดินจะขยับสบายกว่า เดี๋ยวส่งรูปเทียบความยาวให้ดูเพิ่มนะคะ</div>
          <div class="script-note"><b>ใช้เมื่อ:</b> ลูกค้าบอกสัดส่วนครบ · <b>ห้ามใช้เมื่อ:</b> ลูกค้ายังไม่บอกอก/เอว ต้องถามเพิ่มก่อน</div>
        </div>`
      },
      caption: {
        type: 'CONTENT CALENDAR', title: 'Caption พร้อมโพสต์ 30 วัน', count: 'Preview 4 posts',
        html: `<div class="calendar-grid">
          <div class="content-card"><small>DAY 01 · IG</small><b>New Linen Set</b><p>ลุคเรียบที่หยิบใส่ได้ทั้งวัน — เซ็ตผ้าลินินทรงสบาย ใส่ง่าย ถ่ายรูปขึ้น และแมตช์ได้หลายโอกาส 🤍</p></div>
          <div class="content-card"><small>DAY 03 · FB</small><b>Behind the fabric</b><p>ผ้าที่เลือกใช้ในคอลเลกชันนี้เน้นเบา ระบายอากาศดี และไม่แนบตัว เหมาะกับอากาศเมืองไทยจริง ๆ ค่ะ</p></div>
          <div class="content-card"><small>DAY 05 · TikTok</small><b>Try-on caption</b><p>ชุดเดียวที่ช่วยให้ “วันรีบ ๆ” ดูตั้งใจแต่งขึ้นทันที — อยากดูสีไหนคอมเมนต์ไว้ค่ะ</p></div>
          <div class="content-card"><small>DAY 07 · Sale</small><b>Soft CTA</b><p>ถ้ากำลังหาเดรสที่ใส่ทำงานได้และต่อด้วยดินเนอร์ได้เลย รุ่นนี้คือชิ้นที่ควรมีในตู้ค่ะ</p></div>
        </div>`
      },
      hook: {
        type: 'TIKTOK HOOKS', title: 'Hook คลิปสั้นพร้อมมุมถ่าย', count: 'Preview 5/40',
        html: `<div class="hook-list">
          <div class="hook-item"><span>01</span><div><b>หยุดก่อน ถ้าคุณกำลังหาเซ็ตทำงานที่ดูแพง แต่ไม่ต้องรีดนาน</b><p>มุมถ่าย: เปิดด้วย close-up เนื้อผ้า → zoom out full outfit</p></div></div>
          <div class="hook-item"><span>02</span><div><b>ชุดนี้ใส่ไปออฟฟิศได้ แต่หลังเลิกงานไปคาเฟ่ต่อก็ยังรอด</b><p>มุมถ่าย: transition จาก blazer → ถือกระเป๋าเล็ก</p></div></div>
          <div class="hook-item"><span>03</span><div><b>3 จุดที่ทำให้เดรสตัวนี้พรางหุ่นดีกว่าที่คิด</b><p>มุมถ่าย: ชี้ช่วงไหล่ เอว ความยาว พร้อม text overlay</p></div></div>
          <div class="hook-item"><span>04</span><div><b>ถ้าคุณไม่ชอบชุดรัด แต่ยังอยากดูมีทรง ลองดูตัวนี้</b><p>มุมถ่าย: เดิน/นั่งให้เห็นการขยับของผ้า</p></div></div>
        </div>`
      },
      sku: {
        type: 'SKU SHEET', title: 'Product Description พร้อมลง Marketplace', count: 'Preview 1/30 SKU',
        html: `<div class="sku-sheet">
          <div class="sku-photo" aria-hidden="true"></div>
          <div class="sku-fields">
            <div class="field"><small>ชื่อสินค้า</small><p>Linn Linen Straight Dress — Ivory</p></div>
            <div class="field"><small>คำอธิบายสั้น</small><p>เดรสลินินทรงตรง เนื้อผ้าเบา ระบายอากาศดี มีซับใน ใส่ง่ายทั้งวัน เหมาะกับลุคทำงาน คาเฟ่ หรือทริปวันหยุด</p></div>
            <div class="field"><small>จุดขาย</small><p>ทรงไม่รัดช่วงเอว · ผ้าเบาไม่แนบตัว · มีซับใน · แมตช์กับ blazer หรือ sandal ได้</p></div>
            <div class="field"><small>Care note</small><p>แนะนำซักมือหรือโหมดถนอมผ้า ตากในที่ร่ม และรีดไฟอ่อนจากด้านใน</p></div>
          </div>
        </div>`
      }
    };
    const render = (key) => {
      const s = samples[key] || samples.faq;
      root.querySelector('#sampleType').textContent = s.type;
      root.querySelector('#sampleTitle').textContent = s.title;
      root.querySelector('#sampleCount').textContent = s.count;
      root.querySelector('#sampleContent').innerHTML = s.html;
    };
    root.querySelectorAll('[data-sample]').forEach((btn) => btn.addEventListener('click', () => {
      root.querySelectorAll('[data-sample]').forEach((b) => b.classList.remove('is-active'));
      btn.classList.add('is-active');
      render(btn.dataset.sample);
    }));
  })();
</script>
