---
// Floating AI Sales Agent widget. Sits bottom-right on every page.
//
// Visual design — Messenger-style on a DARK panel (matches the ครัวคุณยาย
// mockup boss approved). Header with phone/video/menu, AI bubbles in light
// translucent grey on the left with a peach/violet avatar shown only on the
// first of a role-streak, user bubbles in brand violet on the right with no
// avatar, composer rail with mic / image / emoji / gif / Aa input / smile send.
//
// IMPORTANT: <style is:global> — Astro scopes styles by default which means
// elements created via JavaScript (bubbles, rows, avatar slots, typing) DO NOT
// receive scoped rules. Going global keeps the kp-chat-* selectors working on
// dynamic DOM. All class names are kp-chat-* prefixed to avoid leakage.

interface Props {
  apiBase?: string;
  lineUrl?: string;
  fbUrl?: string;
}

const {
  apiBase = '/api/chat',
  lineUrl = 'https://lin.ee/Qt6Vri4',
  fbUrl = 'https://www.facebook.com/korpaiix',
} = Astro.props;
---

<div
  id="kp-chat-root"
  class="kp-chat-root"
  data-api={apiBase}
  data-line={lineUrl}
  data-fb={fbUrl}
  aria-live="polite"
>
  <!-- Floating bubble -->
  <button
    id="kp-chat-toggle"
    class="kp-chat-toggle"
    type="button"
    aria-label="เปิดแชทกับ KORP AI"
    aria-expanded="false"
    aria-controls="kp-chat-panel"
  >
    <svg class="kp-chat-icon kp-chat-icon-open" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z" />
    </svg>
    <svg class="kp-chat-icon kp-chat-icon-close" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <line x1="18" y1="6" x2="6" y2="18" />
      <line x1="6" y1="6" x2="18" y2="18" />
    </svg>
    <span class="kp-chat-ping" aria-hidden="true"></span>
  </button>

  <!-- Panel -->
  <div id="kp-chat-panel" class="kp-chat-panel" role="dialog" aria-modal="false" aria-label="แชทกับ KORP AI">
    <!-- Header -->
    <header class="kp-chat-head">
      <div class="kp-chat-head-left">
        <div class="kp-chat-avatar" aria-hidden="true">
          <span>K</span>
          <span class="kp-chat-avatar-dot" aria-hidden="true"></span>
        </div>
        <div class="kp-chat-head-info">
          <div class="kp-chat-title">KORP AI</div>
          <div class="kp-chat-sub">Active now · ตอบภายใน 2 วินาที</div>
        </div>
      </div>
      <div class="kp-chat-head-actions">
        <button type="button" class="kp-chat-icon-btn" aria-label="โทรเสียง" disabled>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z"/></svg>
        </button>
        <button type="button" class="kp-chat-icon-btn" aria-label="วิดีโอคอล" disabled>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/></svg>
        </button>
        <button id="kp-chat-close" type="button" class="kp-chat-icon-btn" aria-label="ปิดแชท">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true"><circle cx="12" cy="12" r="1"/><circle cx="5" cy="12" r="1"/><circle cx="19" cy="12" r="1"/></svg>
        </button>
      </div>
    </header>

    <!-- Messages -->
    <div id="kp-chat-messages" class="kp-chat-messages" role="log" aria-live="polite"></div>

    <!-- Handoff CTA -->
    <div id="kp-chat-handoff" class="kp-chat-handoff" hidden>
      <p>อยากให้ทีมช่วยดูต่อมั้ยครับ? เลือกช่องทางที่สะดวก</p>
      <div class="kp-chat-handoff-btns">
        <a id="kp-chat-line" class="kp-chat-line" href={lineUrl} target="_blank" rel="noopener">
          <svg viewBox="0 0 24 24" aria-hidden="true" fill="currentColor"><path d="M24 10.305C24 4.612 18.29 0 12 0 5.71 0 0 4.612 0 10.305c0 5.104 4.54 9.377 10.673 10.186.416.09.98.275 1.123.63.128.324.084.834.04 1.16l-.18 1.094c-.057.325-.26 1.27 1.113.693 1.374-.579 7.395-4.354 10.086-7.455C22.738 14.61 24 12.611 24 10.305"/></svg>
          <span>คุยทาง LINE</span>
        </a>
        <a id="kp-chat-fb" class="kp-chat-fb" href={fbUrl} target="_blank" rel="noopener">
          <svg viewBox="0 0 24 24" aria-hidden="true" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          <span>Messenger</span>
        </a>
      </div>
    </div>

    <!-- Composer (Messenger-style action rail + pill input) -->
    <form id="kp-chat-form" class="kp-chat-form" autocomplete="off">
      <label class="sr-only" for="kp-chat-input">พิมพ์ข้อความ</label>
      <div class="kp-chat-actions" aria-hidden="true">
        <button type="button" class="kp-chat-icon-btn kp-chat-action" aria-label="บันทึกเสียง" disabled>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg>
        </button>
        <button type="button" class="kp-chat-icon-btn kp-chat-action" aria-label="แนบรูป" disabled>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
        </button>
        <button type="button" class="kp-chat-icon-btn kp-chat-action" aria-label="GIF" disabled>
          <svg width="22" height="14" viewBox="0 0 22 14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="0.8" y="0.8" width="20.4" height="12.4" rx="2.4" ry="2.4"/>
            <text x="3" y="10.6" font-family="ui-sans-serif, system-ui" font-size="7" font-weight="700" fill="currentColor" stroke="none">GIF</text>
          </svg>
        </button>
      </div>
      <div class="kp-chat-input-wrap">
        <textarea
          id="kp-chat-input"
          rows="1"
          placeholder="Aa"
          maxlength="2000"
          required
        ></textarea>
        <button id="kp-chat-emoji" type="button" class="kp-chat-emoji" aria-label="อิโมจิ" tabindex="-1" disabled>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="10"/>
            <path d="M8 14s1.5 2 4 2 4-2 4-2"/>
            <line x1="9" y1="9" x2="9.01" y2="9"/>
            <line x1="15" y1="9" x2="15.01" y2="9"/>
          </svg>
        </button>
      </div>
      <button id="kp-chat-send" type="submit" class="kp-chat-send" aria-label="ส่งข้อความ" disabled>
        <!-- Smile icon when idle, paper-plane when has text. We swap via CSS. -->
        <svg class="kp-chat-send-idle" width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 2a10 10 0 1 0 10 10A10 10 0 0 0 12 2zm-3.5 7a1.25 1.25 0 1 1 1.25 1.25A1.25 1.25 0 0 1 8.5 9zm7 0a1.25 1.25 0 1 1 1.25 1.25A1.25 1.25 0 0 1 15.5 9zm-3.5 9a5.5 5.5 0 0 1-4.95-3.06.75.75 0 0 1 1.34-.66 4 4 0 0 0 7.22 0 .75.75 0 0 1 1.34.66A5.5 5.5 0 0 1 12 18z"/>
        </svg>
        <svg class="kp-chat-send-go" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="22" y1="2" x2="11" y2="13"/>
          <polygon points="22 2 15 22 11 13 2 9 22 2"/>
        </svg>
      </button>
    </form>

    <div class="kp-chat-foot">
      AI-generated · ไม่ใช่คำปรึกษาทางการ · <a href="/privacy">privacy</a>
    </div>
  </div>
</div>

<style is:global>
  /* ==========================================================
   * KORP AI floating chat widget — dark Messenger-style
   * (Global styles so JS-created elements get them too.)
   *
   * Brand tokens:
   *   navy   #05070E
   *   panel  #15171F
   *   ink    #E7EAF3
   *   muted  #A4ADC2
   *   violet #7C5FFF
   *   cyan   #26D7F6
   * ========================================================== */
  .kp-chat-root {
    position: fixed;
    right: clamp(14px, 3vw, 28px);
    bottom: clamp(14px, 3vw, 28px);
    z-index: 90;
    font-family: inherit;
  }

  /* --- Toggle bubble --- */
  .kp-chat-toggle {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 58px;
    height: 58px;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.12);
    color: #fff;
    cursor: pointer;
    background:
      radial-gradient(120% 120% at 20% 15%, rgba(124, 95, 255, 0.55), transparent 60%),
      linear-gradient(135deg, #7C5FFF, #26D7F6);
    box-shadow:
      0 10px 30px rgba(124, 95, 255, 0.35),
      0 0 0 1px rgba(255, 255, 255, 0.06) inset;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }
  .kp-chat-toggle:hover {
    transform: translateY(-2px);
    box-shadow:
      0 14px 40px rgba(124, 95, 255, 0.45),
      0 0 0 1px rgba(255, 255, 255, 0.1) inset;
  }
  .kp-chat-icon-close { display: none; }
  .kp-chat-root.is-open .kp-chat-icon-open  { display: none; }
  .kp-chat-root.is-open .kp-chat-icon-close { display: block; }

  .kp-chat-ping {
    position: absolute;
    top: -3px;
    right: -3px;
    width: 14px;
    height: 14px;
    border-radius: 999px;
    background: #22C55E;
    box-shadow: 0 0 0 3px #05070E;
    animation: kp-chat-pulse 2s ease-in-out infinite;
  }
  .kp-chat-root.is-open .kp-chat-ping { display: none; }

  @keyframes kp-chat-pulse {
    0%, 100% { box-shadow: 0 0 0 3px #05070E, 0 0 0 0 rgba(34, 197, 94, 0.55); }
    50%      { box-shadow: 0 0 0 3px #05070E, 0 0 0 10px rgba(34, 197, 94, 0); }
  }

  /* --- Panel --- */
  .kp-chat-panel {
    position: absolute;
    right: 0;
    bottom: 76px;
    width: min(380px, calc(100vw - 28px));
    height: min(600px, calc(100vh - 120px));
    display: none;
    flex-direction: column;
    border-radius: 18px;
    overflow: hidden;
    background: #15171F;
    border: 1px solid rgba(255, 255, 255, 0.06);
    box-shadow:
      0 24px 80px rgba(0, 0, 0, 0.55),
      0 0 0 1px rgba(255, 255, 255, 0.04) inset;
    color: #E7EAF3;
  }
  .kp-chat-root.is-open .kp-chat-panel {
    display: flex;
    animation: kp-chat-pop 0.22s ease-out;
  }
  @keyframes kp-chat-pop {
    from { opacity: 0; transform: translateY(8px) scale(0.98); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
  }

  /* --- Header --- */
  .kp-chat-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 14px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    background: #15171F;
  }
  .kp-chat-head-left {
    display: flex;
    align-items: center;
    gap: 10px;
    min-width: 0;
  }
  .kp-chat-avatar {
    position: relative;
    width: 38px;
    height: 38px;
    border-radius: 999px;
    display: grid;
    place-items: center;
    color: #fff;
    font-weight: 800;
    font-size: 14px;
    background: linear-gradient(135deg, #7C5FFF 0%, #FF7A59 100%);
    box-shadow: 0 4px 14px rgba(255, 122, 89, 0.25);
    flex-shrink: 0;
  }
  .kp-chat-avatar-dot {
    position: absolute;
    bottom: -1px;
    right: -1px;
    width: 11px;
    height: 11px;
    border-radius: 999px;
    background: #22C55E;
    border: 2px solid #15171F;
  }
  .kp-chat-head-info { min-width: 0; }
  .kp-chat-title {
    color: #E7EAF3;
    font-weight: 700;
    font-size: 14.5px;
    line-height: 1.2;
    font-style: italic;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .kp-chat-sub {
    color: #A4ADC2;
    font-size: 11.5px;
    margin-top: 2px;
  }
  .kp-chat-head-actions {
    display: inline-flex;
    align-items: center;
    gap: 2px;
  }
  .kp-chat-icon-btn {
    background: transparent;
    border: 0;
    color: #7C5FFF;
    cursor: pointer;
    padding: 8px;
    border-radius: 999px;
    display: grid;
    place-items: center;
    transition: background 0.15s, color 0.15s;
  }
  .kp-chat-icon-btn:hover { background: rgba(124, 95, 255, 0.12); }
  .kp-chat-icon-btn:disabled {
    opacity: 0.55;
    cursor: default;
  }
  .kp-chat-icon-btn:disabled:hover { background: transparent; }

  /* --- Messages --- */
  .kp-chat-messages {
    flex: 1;
    overflow-y: auto;
    padding: 14px 12px 6px;
    display: flex;
    flex-direction: column;
    gap: 2px;
    scroll-behavior: smooth;
    background: #15171F;
  }
  .kp-chat-messages::-webkit-scrollbar { width: 6px; }
  .kp-chat-messages::-webkit-scrollbar-thumb {
    background: rgba(255, 255, 255, 0.12);
    border-radius: 999px;
  }

  /* date separator */
  .kp-chat-day {
    display: flex;
    justify-content: center;
    margin: 14px 0 6px;
  }
  .kp-chat-day span {
    color: #6B7592;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.02em;
  }

  /* row wrapper */
  .kp-chat-row {
    display: flex;
    align-items: flex-end;
    gap: 6px;
    max-width: 100%;
    margin-top: 2px;
  }
  .kp-chat-row.is-group-start { margin-top: 10px; }
  .kp-chat-row-assistant { justify-content: flex-start; }
  .kp-chat-row-user      { justify-content: flex-end; }
  .kp-chat-row-error     { justify-content: flex-start; }

  /* avatar slot — 28px column. Visible only on group-start of assistant/error. */
  .kp-chat-avatar-slot {
    flex-shrink: 0;
    width: 28px;
    height: 28px;
    border-radius: 999px;
    background: transparent;
  }
  .kp-chat-avatar-slot.is-visible {
    background: linear-gradient(135deg, #7C5FFF 0%, #FF7A59 100%);
    display: grid;
    place-items: center;
    color: #fff;
    font-size: 11px;
    font-weight: 800;
    box-shadow: 0 2px 8px rgba(255, 122, 89, 0.3);
  }
  .kp-chat-avatar-slot.is-error {
    background: #EF4444;
    display: grid;
    place-items: center;
    color: #fff;
    font-size: 12px;
    font-weight: 800;
  }
  .kp-chat-row-user .kp-chat-avatar-slot { display: none; }

  .kp-chat-bubble {
    max-width: calc(100% - 40px);
    padding: 9px 13px;
    border-radius: 18px;
    font-size: 14px;
    line-height: 1.45;
    white-space: pre-wrap;
    word-wrap: break-word;
    animation: kp-chat-in 0.18s ease-out;
  }
  @keyframes kp-chat-in {
    from { opacity: 0; transform: translateY(3px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* assistant: light translucent bubble on dark */
  .kp-chat-bubble.assistant {
    background: rgba(255, 255, 255, 0.08);
    color: #E7EAF3;
    border: 1px solid rgba(255, 255, 255, 0.04);
    border-radius: 18px 18px 18px 4px;
  }
  .kp-chat-bubble.assistant.is-group-mid                { border-radius: 4px 18px 18px 4px; }
  .kp-chat-bubble.assistant.is-group-end                { border-radius: 4px 18px 18px 4px; }
  .kp-chat-bubble.assistant.is-group-start              { border-radius: 18px 18px 18px 4px; }
  .kp-chat-bubble.assistant.is-group-start.is-group-end { border-radius: 18px 18px 18px 4px; }

  /* user: brand violet on right */
  .kp-chat-bubble.user {
    color: #fff;
    background: linear-gradient(135deg, #7C5FFF, #6049E0);
    border-radius: 18px 18px 4px 18px;
    box-shadow: 0 4px 12px rgba(124, 95, 255, 0.25);
  }
  .kp-chat-bubble.user.is-group-mid                { border-radius: 18px 4px 4px 18px; }
  .kp-chat-bubble.user.is-group-end                { border-radius: 18px 4px 4px 18px; }
  .kp-chat-bubble.user.is-group-start              { border-radius: 18px 18px 4px 18px; }
  .kp-chat-bubble.user.is-group-start.is-group-end { border-radius: 18px 18px 4px 18px; }

  .kp-chat-bubble.error {
    background: rgba(239, 68, 68, 0.12);
    color: #FCA5A5;
    border: 1px solid rgba(239, 68, 68, 0.25);
    border-radius: 18px 18px 18px 4px;
    font-size: 13px;
  }

  /* typing indicator inside an assistant bubble shape */
  .kp-chat-typing {
    padding: 12px 14px;
    border-radius: 18px 18px 18px 4px;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.04);
    display: inline-flex;
    gap: 4px;
    align-items: center;
  }
  .kp-chat-typing span {
    width: 6px;
    height: 6px;
    border-radius: 999px;
    background: #A4ADC2;
    animation: kp-chat-bounce 1.2s ease-in-out infinite;
  }
  .kp-chat-typing span:nth-child(2) { animation-delay: 0.15s; }
  .kp-chat-typing span:nth-child(3) { animation-delay: 0.3s; }
  @keyframes kp-chat-bounce {
    0%, 100% { opacity: 0.35; transform: translateY(0); }
    50%      { opacity: 1;    transform: translateY(-3px); }
  }

  /* --- Handoff panel --- */
  .kp-chat-handoff {
    margin: 0 14px 8px;
    padding: 12px;
    border-radius: 14px;
    background: rgba(124, 95, 255, 0.1);
    border: 1px solid rgba(124, 95, 255, 0.25);
  }
  .kp-chat-handoff p {
    color: #E7EAF3;
    font-size: 13px;
    margin: 0 0 10px;
  }
  .kp-chat-handoff-btns {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
  }
  .kp-chat-line, .kp-chat-fb {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 10px;
    border-radius: 10px;
    color: #fff;
    font-size: 13px;
    font-weight: 600;
    text-decoration: none;
    transition: filter 0.15s;
  }
  .kp-chat-line { background: #06C755; }
  .kp-chat-fb   { background: #0084FF; }
  .kp-chat-line svg, .kp-chat-fb svg { width: 16px; height: 16px; }
  .kp-chat-line:hover, .kp-chat-fb:hover { filter: brightness(1.1); }

  /* --- Composer rail --- */
  .kp-chat-form {
    display: flex;
    align-items: center;
    gap: 4px;
    padding: 10px 10px 4px;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    background: #15171F;
  }
  .kp-chat-actions {
    display: inline-flex;
    align-items: center;
    gap: 0;
  }
  .kp-chat-action {
    padding: 7px;
  }
  .kp-chat-input-wrap {
    position: relative;
    flex: 1;
    background: rgba(255, 255, 255, 0.06);
    border-radius: 22px;
    display: flex;
    align-items: center;
    padding-right: 4px;
    transition: background 0.15s, box-shadow 0.15s;
    min-width: 0;
  }
  .kp-chat-input-wrap:focus-within {
    background: rgba(255, 255, 255, 0.09);
    box-shadow: 0 0 0 1px rgba(124, 95, 255, 0.4);
  }
  .kp-chat-form textarea {
    flex: 1;
    min-width: 0;
    background: transparent;
    border: 0;
    color: #E7EAF3;
    padding: 9px 6px 9px 14px;
    font-size: 14px;
    line-height: 1.4;
    resize: none;
    max-height: 100px;
    outline: none;
    font-family: inherit;
  }
  .kp-chat-form textarea::placeholder { color: #6B7592; }
  .kp-chat-emoji {
    background: transparent;
    border: 0;
    color: #A4ADC2;
    cursor: default;
    padding: 6px;
    border-radius: 999px;
    display: grid;
    place-items: center;
    flex-shrink: 0;
  }
  .kp-chat-send {
    width: 38px;
    height: 38px;
    border: 0;
    border-radius: 999px;
    color: #7C5FFF;
    background: transparent;
    cursor: pointer;
    transition: background 0.15s, color 0.15s, transform 0.15s;
    flex-shrink: 0;
    display: grid;
    place-items: center;
  }
  .kp-chat-send:not(:disabled):hover { background: rgba(124, 95, 255, 0.15); transform: translateY(-1px); }
  .kp-chat-send:disabled { color: #7C5FFF; cursor: not-allowed; }

  /* swap smile ↔ paper-plane based on disabled state */
  .kp-chat-send-go { display: none; }
  .kp-chat-send:not(:disabled) .kp-chat-send-idle { display: none; }
  .kp-chat-send:not(:disabled) .kp-chat-send-go   { display: block; }

  .kp-chat-foot {
    font-size: 10.5px;
    color: #6B7592;
    text-align: center;
    padding: 0 12px 10px;
    background: #15171F;
  }
  .kp-chat-foot a {
    color: #A4ADC2;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .kp-chat-root .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0,0,0,0);
    border: 0;
  }

  /* --- Mobile: full-height sheet --- */
  @media (max-width: 480px) {
    .kp-chat-panel {
      right: -6px;
      bottom: 72px;
      width: calc(100vw - 20px);
      height: calc(100vh - 100px);
      max-height: 640px;
    }
  }
</style>

<script is:inline>
  (() => {
    if (typeof window === 'undefined') return;

    const root     = document.getElementById('kp-chat-root');
    if (!root) return;
    const toggle   = document.getElementById('kp-chat-toggle');
    const closeBtn = document.getElementById('kp-chat-close');
    const panel    = document.getElementById('kp-chat-panel');
    const msgs     = document.getElementById('kp-chat-messages');
    const form     = document.getElementById('kp-chat-form');
    const input    = document.getElementById('kp-chat-input');
    const sendBtn  = document.getElementById('kp-chat-send');
    const handoff  = document.getElementById('kp-chat-handoff');
    const lineBtn  = document.getElementById('kp-chat-line');
    const fbBtn    = document.getElementById('kp-chat-fb');

    const api  = root.dataset.api  || '/api/chat';
    const LINE = root.dataset.line || 'https://lin.ee/Qt6Vri4';
    const FB   = root.dataset.fb   || 'https://www.facebook.com/korpaiix';

    let started = false;
    let sending = false;
    let lastRole = null;
    let lastRowEl = null;

    const GREETING_FALLBACK =
      'สวัสดีครับ ทีม KORP AI 👋\n\nเล่าคร่าวๆ ว่าธุรกิจคุณทำอะไร และอยากแก้ปัญหาเรื่องไหน' +
      ' เดี๋ยวผมแนะนำแนวทาง AI / Automation ที่เหมาะให้ครับ';
    const GREETING_BACKEND_DOWN =
      'สวัสดีครับ 👋\n\nระบบ AI กำลังตั้งค่า ช่วงนี้ทักทีมเราตรงทาง LINE OA หรือ Messenger สะดวกสุด' +
      ' — ตอบเร็วภายใน 1 ชม. ในเวลาทำการ (9-21 น.) ครับ';

    // ---- Group-aware bubble rendering (Messenger-style) ----
    const tagBubble = (bubble, isStart, isEnd) => {
      bubble.classList.toggle('is-group-start', isStart);
      bubble.classList.toggle('is-group-end',   isEnd);
      bubble.classList.toggle('is-group-mid',   !isStart && !isEnd);
    };
    const demotePreviousEnd = () => {
      if (!lastRowEl) return;
      const prev = lastRowEl.querySelector('.kp-chat-bubble');
      if (!prev) return;
      const wasStart = prev.classList.contains('is-group-start');
      tagBubble(prev, wasStart, false);
    };

    const addRow = (role) => {
      const isGroupStart = role !== lastRole;
      if (!isGroupStart) demotePreviousEnd();

      const row = document.createElement('div');
      row.className = 'kp-chat-row kp-chat-row-' + role;
      if (isGroupStart) row.classList.add('is-group-start');

      const avatar = document.createElement('div');
      avatar.className = 'kp-chat-avatar-slot';
      avatar.setAttribute('aria-hidden', 'true');
      if (isGroupStart && role === 'assistant') {
        avatar.classList.add('is-visible');
        avatar.textContent = 'K';
      } else if (isGroupStart && role === 'error') {
        avatar.classList.add('is-error');
        avatar.textContent = '!';
      }
      row.appendChild(avatar);

      lastRole = role;
      lastRowEl = row;
      return { row, isGroupStart };
    };

    const addBubble = (role, text) => {
      const { row, isGroupStart } = addRow(role);
      const bubble = document.createElement('div');
      bubble.className = 'kp-chat-bubble ' + role;
      bubble.textContent = text;
      tagBubble(bubble, isGroupStart, true);
      row.appendChild(bubble);
      msgs.appendChild(row);
      msgs.scrollTop = msgs.scrollHeight;
      return bubble;
    };

    const addTyping = () => {
      const { row } = addRow('assistant');
      const el = document.createElement('div');
      el.className = 'kp-chat-typing';
      el.setAttribute('aria-label', 'AI กำลังพิมพ์');
      el.innerHTML = '<span></span><span></span><span></span>';
      row.appendChild(el);
      msgs.appendChild(row);
      msgs.scrollTop = msgs.scrollHeight;
      return row;
    };

    const addDateSeparator = (label) => {
      const sep = document.createElement('div');
      sep.className = 'kp-chat-day';
      const span = document.createElement('span');
      span.textContent = label;
      sep.appendChild(span);
      msgs.appendChild(sep);
      lastRole = null;
      lastRowEl = null;
    };

    const formatNow = () => {
      const d = new Date();
      let hh = d.getHours();
      const mm = String(d.getMinutes()).padStart(2, '0');
      const ampm = hh >= 12 ? 'PM' : 'AM';
      hh = hh % 12; if (hh === 0) hh = 12;
      // Thai-style: "วันนี้ · 18:47"
      return 'วันนี้ · ' + hh + ':' + mm + ' ' + ampm;
    };

    const showHandoff = () => { handoff.hidden = false; msgs.scrollTop = msgs.scrollHeight; };

    // ---- API ----
    const tryStartSession = async () => {
      addDateSeparator(formatNow());
      try {
        const r = await fetch(api + '/session', {
          method: 'POST',
          credentials: 'include',
        });
        if (r.ok) {
          const data = await r.json();
          addBubble('assistant', data.greeting || GREETING_FALLBACK);
          return true;
        }
      } catch (_) { /* fall through */ }
      addBubble('assistant', GREETING_BACKEND_DOWN);
      showHandoff();
      input.disabled = true;
      input.placeholder = 'AI ออฟไลน์ — กดปุ่ม LINE / Messenger ด้านบน';
      sendBtn.disabled = true;
      return false;
    };

    const sendMessage = async (text) => {
      const typingEl = addTyping();
      try {
        const r = await fetch(api + '/message', {
          method: 'POST',
          credentials: 'include',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ message: text }),
        });
        if (lastRowEl === typingEl) {
          lastRowEl = null;
          lastRole = null;
        }
        typingEl.remove();
        if (r.status === 429) {
          addBubble('error', 'ส่งถี่ไปหน่อยครับ รอสักครู่แล้วลองใหม่');
          return;
        }
        if (!r.ok) throw new Error('bad status ' + r.status);
        const data = await r.json();
        addBubble('assistant', data.reply || '...');
        if (data.handoff) showHandoff();
      } catch (err) {
        if (lastRowEl === typingEl) {
          lastRowEl = null;
          lastRole = null;
        }
        typingEl.remove();
        addBubble(
          'error',
          'เชื่อมต่อ AI ไม่ได้ชั่วคราว — คุยกับทีมเราตรงทาง LINE / Messenger ด้านล่างได้เลยครับ'
        );
        showHandoff();
      }
    };

    // ---- UI events ----
    const open = async () => {
      root.classList.add('is-open');
      toggle.setAttribute('aria-expanded', 'true');
      input.focus();
      if (!started) {
        started = true;
        await tryStartSession();
      }
    };
    const close = () => {
      root.classList.remove('is-open');
      toggle.setAttribute('aria-expanded', 'false');
    };

    toggle.addEventListener('click', () => {
      if (root.classList.contains('is-open')) close();
      else open();
    });
    closeBtn.addEventListener('click', close);
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && root.classList.contains('is-open')) close();
    });

    // Auto-grow textarea
    input.addEventListener('input', () => {
      input.style.height = 'auto';
      input.style.height = Math.min(input.scrollHeight, 100) + 'px';
      sendBtn.disabled = input.value.trim().length === 0 || sending;
    });

    // Enter to send, Shift+Enter for newline
    input.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' && !e.shiftKey) {
        e.preventDefault();
        form.requestSubmit();
      }
    });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const text = input.value.trim();
      if (!text || sending) return;
      sending = true;
      sendBtn.disabled = true;
      addBubble('user', text);
      input.value = '';
      input.style.height = 'auto';
      await sendMessage(text);
      sending = false;
      sendBtn.disabled = input.value.trim().length === 0;
      input.focus();
    });

    // Handoff click → log + open LINE/FB
    const logHandoff = (channel) => {
      fetch(api + '/handoff', {
        method: 'POST',
        credentials: 'include',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ channel }),
        keepalive: true,
      }).catch(() => { /* best effort */ });
      return true;
    };
    lineBtn.addEventListener('click', () => logHandoff('line'));
    fbBtn.addEventListener('click',   () => logHandoff('fb'));

    // Tiny nudge after 15s of idle browsing (first visit)
    let peeked = false;
    const peek = () => {
      if (peeked) return;
      peeked = true;
      toggle.animate(
        [
          { transform: 'translateY(0)' },
          { transform: 'translateY(-8px)' },
          { transform: 'translateY(0)' },
          { transform: 'translateY(-4px)' },
          { transform: 'translateY(0)' },
        ],
        { duration: 700, easing: 'ease-in-out' }
      );
    };
    window.addEventListener('load', () => { setTimeout(peek, 15000); }, { once: true });
  })();
</script>
