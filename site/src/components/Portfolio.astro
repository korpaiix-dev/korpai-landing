---
import { portfolio } from '~/data/portfolio';
---

<section id="portfolio" class="relative py-24 md:py-28 border-t kp-hairline">
  <div class="kp-container">
    <div class="max-w-2xl mx-auto text-center kp-reveal">
      <span class="kp-pill">ตัวอย่างโจทย์</span>
      <h2 class="prose-kp mt-5">โจทย์จริงที่เราออกแบบระบบให้ SME ไทย</h2>
      <p class="prose-kp mt-5">
        6 ตัวอย่างโจทย์ที่ทีม KORP เคยช่วย SME ออกแบบ · เปิดแบบไม่เผยชื่อลูกค้าจริง (เคารพ NDA) อยากดู demo สดทักมาคุยได้เลย
      </p>
    </div>

    <div class="mt-14 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
      {portfolio.map((c, i) => (
        <a
          href={`/portfolio/${c.slug}`}
          class="kp-port-card kp-reveal kp-port-link"
          style={`transition-delay:${i * 60}ms`}
        >
          <div class="kp-port-cover" style={`background: ${c.gradient};`}>
            {c.img ? (
              <img src={c.img} alt={c.alt ?? c.client} loading="lazy" />
            ) : (
              <div class="kp-port-placeholder">
                <span class="kp-port-emoji">{c.emoji}</span>
              </div>
            )}
            <div class="kp-port-metric">
              <div class="kp-port-metric-num">{c.metric}</div>
              <div class="kp-port-metric-label">{c.metricLabel}</div>
            </div>
          </div>
          <div class="kp-port-body">
            <div class="flex items-center justify-between">
              <h3 class="text-white text-lg font-semibold">{c.client}</h3>
              <span class="text-[11px]" style="color: #8AA0C5;">{c.industry}</span>
            </div>
            <p class="mt-2 text-sm leading-relaxed" style="color: #B8C5DE;">{c.note}</p>
            <span class="kp-port-readmore mt-4">
              ดูเคสเต็ม
              <span aria-hidden="true">→</span>
            </span>
          </div>
        </a>
      ))}
    </div>

    <!-- CTA -->
    <div class="mt-14 text-center kp-reveal">
      <p class="text-xs mb-5" style="color: #8AA0C5;">
        ชื่อและตัวเลขในตัวอย่างเป็น persona · ตัวเลขจริงของลูกค้าแต่ละรายแตกต่างกันตามโจทย์
      </p>
      <a href="#contact" class="kp-btn-secondary">
        ขอดู demo ระบบจริง
        <span aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</section>

<style>
  .kp-port-card {
    border-radius: 18px;
    background: rgba(15, 20, 32, 0.5);
    border: 1px solid rgba(255, 255, 255, 0.06);
    overflow: hidden;
    transition: transform 0.4s ease, border-color 0.3s ease, box-shadow 0.3s ease;
  }
  .kp-port-link { display: block; text-decoration: none; color: inherit; }
  .kp-port-card:hover {
    transform: translateY(-4px);
    border-color: rgba(38, 215, 246, 0.25);
    box-shadow: 0 20px 50px rgba(0,0,0,0.4), 0 0 0 1px rgba(38,215,246,0.1);
  }

  .kp-port-cover {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
  }
  .kp-port-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s ease;
  }
  .kp-port-card:hover .kp-port-cover img {
    transform: scale(1.04);
  }
  /* Soft bottom vignette so the metric badge stays readable */
  .kp-port-cover::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(5,7,14,0) 45%, rgba(5,7,14,0.55) 100%);
    pointer-events: none;
  }
  .kp-port-placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background:
      radial-gradient(ellipse at top left, rgba(255,255,255,0.2), transparent 60%),
      radial-gradient(ellipse at bottom right, rgba(0,0,0,0.3), transparent 60%);
  }
  .kp-port-emoji {
    font-size: 72px;
    filter: drop-shadow(0 10px 20px rgba(0,0,0,0.3));
    transform: scale(1);
    transition: transform 0.4s ease;
  }
  .kp-port-card:hover .kp-port-emoji {
    transform: scale(1.1) rotate(-3deg);
  }

  /* Metric overlay */
  .kp-port-metric {
    position: absolute;
    left: 14px;
    bottom: 14px;
    padding: 10px 14px;
    background: rgba(0, 0, 0, 0.55);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-radius: 12px;
    border: 1px solid rgba(255, 255, 255, 0.15);
    z-index: 2;
  }
  .kp-port-metric-num {
    font-size: 22px;
    font-weight: 800;
    color: white;
    line-height: 1;
  }
  .kp-port-metric-label {
    font-size: 10px;
    color: rgba(255, 255, 255, 0.8);
    margin-top: 2px;
    font-weight: 600;
  }

  .kp-port-body {
    padding: 18px 20px 22px;
  }

  .kp-port-readmore {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    font-weight: 600;
    color: #26D7F6;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    letter-spacing: 0.02em;
  }
  .kp-port-readmore span {
    transition: transform 0.3s ease;
  }
  .kp-port-card:hover .kp-port-readmore span {
    transform: translateX(3px);
  }
</style>
