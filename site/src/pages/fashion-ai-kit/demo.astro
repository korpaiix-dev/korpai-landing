<script is:inline>
const customers={
  mind:{name:'ลูกค้ามายด์',avatar:'M',topic:'กำลังดูสินค้า: Linen Straight Dress — สีครีม',note:'สนใจเดรสสีครีม · มีโอกาสซื้อสูง',tags:['ถามไซซ์','พร้อมซื้อ','ส่งวันนี้'],product:'Linen Straight Dress',stock:'สีครีม · M เหลือ 4 / L เหลือ 8',rules:['อก 36 → แนะนำ L','ความยาว 112 ซม.','ส่งวันนี้ได้ก่อน 14:00'],draft:'ได้เลยค่ะ เดี๋ยวแอดมินส่งลิงก์ชำระเงินให้ พร้อมสรุปไซซ์ L สีครีม 1 ตัวนะคะ',messages:[['customer','มีเดรสสีครีมไหมคะ สูง 160 อก 36 ใส่ไซซ์ไหนดี?'],['ai','AI ตอบจากข้อมูลสินค้า','มีค่ะ รุ่น Linen Straight สีครีมเหลือไซซ์ M/L จากอก 36 แนะนำ L จะใส่สบายกว่า และยังได้ทรงตรงสวยนะคะ'],['customer','ส่งวันนี้ได้ไหมคะ?'],['ai','AI ตอบจากนโยบายส่งของ','ถ้าชำระก่อน 14:00 น. ร้านจัดส่งรอบวันนี้ได้ค่ะ ต้องการให้แอดมินส่งลิงก์ชำระเงินให้ไหมคะ?']]},
  praew:{name:'ลูกค้าแพรว',avatar:'P',topic:'ต้องการส่งด่วนใน กทม.',note:'รีบใช้สินค้า · ต้องให้แอดมินยืนยันค่าส่ง',tags:['ส่งด่วน','รอแอดมิน','กทม.'],product:'Soft Knit Cardigan',stock:'สีฟ้า · Free size เหลือ 6',rules:['ส่งด่วนต้องเช็กเขตก่อน','ค่าส่งคิดตามระยะ','เคสนี้ส่งต่อแอดมิน'],draft:'เคสส่งด่วนเดี๋ยวแอดมินเช็กพื้นที่และค่าส่งให้นะคะ ขอเขต/แขวงปลายทางเพิ่มเติมได้ไหมคะ',messages:[['customer','วันนี้ส่งด่วนได้ไหมคะ อยู่พระราม 9'],['ai','AI ตรวจนโยบายแล้วส่งต่อ','ส่งด่วนมีค่ะ แต่ต้องให้แอดมินเช็กค่าส่งตามพื้นที่ก่อนนะคะ ขอเขต/แขวงปลายทางเพิ่มได้ไหมคะ']]},
  nut:{name:'ลูกค้านัท',avatar:'N',topic:'ถามกางเกงเอวสูงสีดำ',note:'ถามข้อมูลครบ · AI ตอบจบแล้ว',tags:['ตอบจบ','ถามเอว','สีดำ'],product:'High Waist Trousers',stock:'สีดำ · S/M/L พร้อมส่ง',rules:['เอว 27 → แนะนำ M','ทรงเอวสูง เก็บสะโพก','เปลี่ยนไซซ์ได้ภายใน 7 วัน'],draft:'ถ้าเอว 27 แนะนำ M ค่ะ รุ่นนี้เอวสูง ทรงเก็บสะโพก ใส่ทำงานได้เลยค่ะ',messages:[['customer','เอว 27 สะโพก 37 ใส่กางเกงตัวไหนดีคะ'],['ai','AI ตอบจากตารางไซซ์','แนะนำ High Waist Trousers ไซซ์ M ค่ะ รุ่นนี้เอวสูง ทรงเก็บสะโพกและมีสีดำพร้อมส่งค่ะ']]},
  bee:{name:'ลูกค้าบี',avatar:'B',topic:'ถามโปรซื้อ 2 ชิ้น',note:'สนใจโปร · มีโอกาส upsell',tags:['ถามโปร','upsell','AI ตอบอยู่'],product:'Linen Straight Dress + Cardigan',stock:'จับคู่โปรได้ · เหลือครบ',rules:['ซื้อ 2 ชิ้นลด 100','ส่งฟรีเมื่อครบ 1,500','AI แนะนำคู่สีได้'],draft:'ถ้ารับเดรสคู่กับ cardigan ร้านมีโปรลด 100 บาท และยอดครบส่งฟรีค่ะ อยากให้ช่วยจับคู่สีให้ไหมคะ',messages:[['customer','ถ้าซื้อเดรสกับเสื้อคลุมมีโปรไหมคะ'],['ai','AI ตอบจากโปรร้าน','มีค่ะ ซื้อ 2 ชิ้นลด 100 บาท และถ้ายอดครบ 1,500 ส่งฟรีค่ะ เดี๋ยวช่วยจับคู่สีให้ได้นะคะ']]}
};
const $=s=>document.querySelector(s); const $$=s=>[...document.querySelectorAll(s)];
function toast(t){const el=$('#toast');el.textContent=t;el.classList.add('show');setTimeout(()=>el.classList.remove('show'),1800)}
function renderCustomer(id){const c=customers[id];$('#customer-name').textContent=c.name;$('#customer-topic').textContent=c.topic;$('#avatar').textContent=c.avatar;$('#profile-name').textContent=c.name;$('#profile-note').textContent=c.note;$('#product-name').textContent=c.product;$('#product-stock').textContent=c.stock;$('#ai-draft').textContent=c.draft;$('#tags').innerHTML=c.tags.map(t=>`<span>${t}</span>`).join('');$('#product-rules').innerHTML=c.rules.map(r=>`<li>${r}</li>`).join('');$('#messages').innerHTML=c.messages.map(m=>m[0]==='customer'?`<div class="msg customer">${m[1]}</div>`:`<div class="msg ai"><small>${m[1]}</small>${m[2]}</div>`).join('');}
$$('.customer-row').forEach(b=>b.addEventListener('click',()=>{$$('.customer-row').forEach(x=>x.classList.remove('active'));b.classList.add('active');renderCustomer(b.dataset.customer);toast('เปลี่ยนเคสลูกค้าแล้ว')}));
$$('[data-view]').forEach(b=>b.addEventListener('click',()=>{$$('[data-view]').forEach(x=>x.classList.remove('active'));b.classList.add('active');$$('.view').forEach(v=>v.classList.remove('active'));$(`[data-panel="${b.dataset.view}"]`).classList.add('active');$('[data-title]').textContent=b.textContent.trim()==='กล่องแชท'?'กล่องแชทร้าน Linn Studio':b.textContent.trim();toast('เปิดเมนู '+b.textContent.trim())}));
$('#toggle-ai').addEventListener('click',e=>{e.currentTarget.textContent=e.currentTarget.textContent.includes('พัก')?'เปิด AI อีกครั้ง':'พัก AI ชั่วคราว';toast(e.currentTarget.textContent.includes('เปิด')?'พัก AI แล้ว':'เปิด AI แล้ว')});
$('#handoff-btn').addEventListener('click',()=>toast('ส่งต่อแอดมินพร้อมสรุปแชทแล้ว'));
$('#edit-answer').addEventListener('click',()=>{$('#composer').value=$('#ai-draft').textContent;toast('ดึงคำตอบลงช่องแก้แล้ว')});
$('#send-answer').addEventListener('click',()=>toast('ส่งข้อความตัวอย่างแล้ว'));
$('#composer-send').addEventListener('click',()=>toast('ส่งข้อความตัวอย่างแล้ว'));
$$('[data-demo-toast]').forEach(b=>b.addEventListener('click',()=>toast(b.dataset.demoToast)));
renderCustomer('mind');
</script>

