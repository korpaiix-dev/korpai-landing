    padding:18px;
    min-height:390px;
  }
  .doc-head {
    display:flex;
    align-items:flex-start;
    justify-content:space-between;
    gap:14px;
    padding-bottom:14px;
    border-bottom:1px solid rgba(255,255,255,.08);
  }
  .doc-type { color:#26d7f6; font-size:11px; font-weight:950; letter-spacing:.18em; }
  .doc-head h3 { margin-top:7px; color:white; font-size:24px; line-height:1.22; letter-spacing:-.035em; }
