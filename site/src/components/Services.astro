---
import { services } from '~/data/services';
---

<section id="services" class="relative py-24 md:py-32 overflow-hidden">
  <!-- Raycast-feel ambient beams behind section -->
  <div aria-hidden="true" class="kp-section-beam kp-section-beam--cyan"></div>

  <div class="kp-container relative">
    <div class="max-w-3xl mx-auto text-center kp-reveal">
      <span class="kp-eyebrow">Services · บริการของเรา</span>
      <h2 class="prose-kp mt-6">
        AI ที่คุ้มกับ <span class="kp-grad">ขนาดธุรกิจ</span> คุณ
      </h2>
      <p class="prose-kp mt-5">
        ไม่ใช่แค่ติดตั้ง chatbot สำเร็จรูป — เราคุยกับทีมคุณก่อน แล้วส่งระบบที่ทีมใช้ต่อได้เอง
      </p>
    </div>

    <div class="mt-16 grid gap-6 md:grid-cols-2">
      {services.map((s, i) => (
        <a
          href={`/services/${s.slug}`}
          class="kp-rc-card kp-svc-card-v2 kp-reveal kp-svc-link"
          style={`transition-delay:${i * 80}ms`}
        >
          <div class="kp-svc-visual-v2">
            <img src={s.img} alt={s.alt} loading="lazy" />
            <div class="kp-svc-visual-shade" aria-hidden="true"></div>
            <span class="kp-rc-num kp-svc-num">{String(i + 1).padStart(2, '0')} · {s.tag}</span>
          </div>
          <div class="kp-svc-body-v2">
            <h3 class="text-xl font-semibold text-white tracking-tight">{s.title}</h3>
            <p class="mt-2.5 text-sm leading-relaxed" style="color: #8AA0C5;">
              {s.shortDesc}
            </p>
            <span class="kp-rc-cta mt-5">
              ดูรายละเอียด
              <span class="kp-rc-arrow" aria-hidden="true">→</span>
            </span>
          </div>
        </a>
      ))}
    </div>

    <div class="mt-12 text-center kp-reveal">
      <a href="#contact" class="kp-btn-secondary">
        คุยโจทย์ฟรี · ประเมินให้ทันที
        <span aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</section>

<style>
  .kp-svc-card-v2 { padding: 0; }
  .kp-svc-link { display: block; text-decoration: none; color: inherit; }
  .kp-svc-link:hover .kp-rc-arrow { transform: translateX(3px); }

  .kp-svc-visual-v2 {
    position: relative;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    background: #0A0F1C;
  }
  .kp-svc-visual-v2 img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.7s cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  .kp-svc-card-v2:hover .kp-svc-visual-v2 img {
    transform: scale(1.04);
  }

  /* Darker vignette + cyan wash on top edge (Raycast-esque) */
  .kp-svc-visual-shade {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(8,12,24,0.35) 0%, rgba(8,12,24,0) 35%),
      linear-gradient(180deg, rgba(5,7,14,0) 45%, rgba(5,7,14,0.7) 100%);
    pointer-events: none;
  }

  /* Number pill floats over bottom-left of image */
  .kp-svc-num {
    position: absolute;
    left: 14px;
    bottom: 12px;
    padding: 5px 10px;
    border-radius: 9999px;
    background: rgba(5,7,14,0.65);
    border: 1px solid rgba(38,215,246,0.25);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    z-index: 2;
  }

  .kp-svc-body-v2 {
    padding: 22px 24px 24px;
  }

  .kp-rc-arrow {
    display: inline-block;
    transition: transform 0.3s ease;
  }
</style>
