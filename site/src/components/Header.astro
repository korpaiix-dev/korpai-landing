---
const nav = [
  { href: '#services',  label: 'บริการ' },
  { href: '#portfolio', label: 'ผลงาน' },
  { href: '#pricing',   label: 'ราคา' },
  { href: '#about',     label: 'เกี่ยวกับ' },
  { href: '#faq',       label: 'คำถาม' },
  { href: '#contact',   label: 'ติดต่อ' },
];
---

<header class="sticky top-4 z-40">
  <div class="kp-container">
    <div class="kp-nav-pill justify-between">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 pl-1 pr-3 py-1 rounded-full transition hover:bg-white/5" aria-label="KORP AI AUTOMATION">
        <img
          src="/assets/logo-icon.png"
          alt=""
          width="28"
          height="28"
          class="h-7 w-7"
          loading="eager"
          decoding="async"
        />
        <span class="hidden sm:inline text-sm font-semibold tracking-tight text-white">
          Korp<span class="text-brand-cyan-400"> AI</span>
        </span>
      </a>

      <!-- Nav links -->
      <nav class="hidden md:flex items-center gap-0.5" aria-label="Primary">
        {nav.map(item => (
          <a href={item.href} class="kp-nav-link">{item.label}</a>
        ))}
      </nav>

      <!-- Right side -->
      <div class="flex items-center gap-1.5">
        <div
          class="hidden sm:inline-flex items-center rounded-full p-0.5 text-xs font-medium"
          style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08);"
          role="group"
          aria-label="Language"
        >
          <button type="button" class="rounded-full bg-white text-brand-navy-900 px-2.5 py-1" aria-pressed="true">TH</button>
          <button type="button" class="rounded-full px-2.5 py-1 text-brand-ink-400 hover:text-white" aria-pressed="false">EN</button>
        </div>

        <a
          href="#contact"
          class="inline-flex items-center gap-1.5 rounded-full bg-white px-4 py-2 text-sm font-semibold text-brand-navy-900 transition hover:bg-brand-ink-50"
        >
          ปรึกษาฟรี
          <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </div>
</header>
