---
const year = new Date().getFullYear();
---

<footer class="mt-0 border-t kp-hairline" style="background: rgba(5,7,14,0.6); backdrop-filter: blur(10px);">
  <div class="kp-container py-10 flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
    <div class="flex items-center gap-2 text-sm" style="color: #8AA0C5;">
      <img src="/assets/logo-icon.png" alt="" width="24" height="24" class="h-6 w-6" loading="lazy" />
      <span>KORP AI AUTOMATION — AI Agency for Thai SMEs</span>
    </div>
    <div class="text-xs flex items-center gap-3" style="color: #6B7FA0;">
      <span>© {year} KORP AI · korpai.co · ปรึกษาฟรีเสมอ</span>
      <span aria-hidden="true" style="color: #2A3654;">·</span>
      <a href="/privacy" class="underline-offset-2 hover:text-white transition-colors" style="text-decoration-color: rgba(38,215,246,0.4);">Privacy</a>
      <span aria-hidden="true" style="color: #2A3654;">·</span>
      <a href="/press" class="underline-offset-2 hover:text-white transition-colors" style="text-decoration-color: rgba(38,215,246,0.4);">Press</a>
      <span aria-hidden="true" style="color: #2A3654;">·</span>
      <a href="/blog" class="underline-offset-2 hover:text-white transition-colors" style="text-decoration-color: rgba(38,215,246,0.4);">Blog</a>
    </div>
  </div>
</footer>
