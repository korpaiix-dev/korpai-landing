---
---

<section id="hero" class="relative overflow-hidden isolate min-h-[92vh] flex items-center">
  <!-- Subtle starfield dots -->
  <div aria-hidden="true" class="absolute inset-0 kp-dots z-[0]"></div>

  <!-- Floating color orbs (WOW factor) -->
  <div aria-hidden="true" class="kp-orb kp-orb-1"></div>
  <div aria-hidden="true" class="kp-orb kp-orb-2"></div>
  <div aria-hidden="true" class="kp-orb kp-orb-3"></div>

  <!-- Big pulsing halo glow -->
  <div aria-hidden="true" class="kp-halo kp-halo-pulse"></div>

  <!-- Raycast-style diagonal beams (parallax) -->
  <div aria-hidden="true" id="kp-beams" class="kp-beams">
    <span class="kp-beam kp-beam-1"></span>
    <span class="kp-beam kp-beam-2"></span>
    <span class="kp-beam kp-beam-3"></span>
    <span class="kp-beam kp-beam-4"></span>
    <span class="kp-beam kp-beam-5"></span>
    <span class="kp-ray kp-ray-1"></span>
    <span class="kp-ray kp-ray-2"></span>
    <span class="kp-ray kp-ray-3"></span>
  </div>

  <!-- Cursor spotlight -->
  <div aria-hidden="true" id="kp-spotlight" class="kp-spotlight"></div>

  <!-- Content -->
  <div class="kp-container relative z-10 py-20 md:py-28 w-full">
    <div class="mx-auto max-w-5xl text-center">
      <span class="kp-pill kp-reveal">
        <span class="h-1.5 w-1.5 rounded-full bg-brand-cyan-400" style="box-shadow: 0 0 12px #26D7F6;"></span>
        เปิดรับโปรเจกต์ใหม่ · ตอบภายใน 24 ชม.
      </span>

      <h1 class="prose-kp mt-7 kp-reveal" style="transition-delay:60ms">
        <span class="block">AI Agent &amp; Automation</span>
        <span class="block kp-grad">สำหรับ SME ไทย.</span>
      </h1>

      <p class="prose-kp mt-7 mx-auto max-w-2xl kp-reveal" style="transition-delay:120ms">
        ทีม KORP AI ออกแบบ สร้าง และดูแลระบบ Chatbot · Automation · Dashboard ให้ธุรกิจคุณ
        ตอบลูกค้าเร็วขึ้น ปิดการขายง่ายขึ้น และลดงานมือซ้ำ ๆ ของทีม
      </p>

      <div class="mt-10 flex flex-wrap items-center justify-center gap-3 kp-reveal" style="transition-delay:180ms">
        <a href="#contact" class="kp-btn-primary group">
          ปรึกษาฟรี
          <span aria-hidden="true" class="transition-transform group-hover:translate-x-0.5">→</span>
        </a>
        <a href="#services" class="kp-btn-secondary">
          ดูบริการทั้งหมด
        </a>
      </div>

      <!-- Social proof stats row -->
      <div class="mt-8 flex justify-center kp-reveal" style="transition-delay:240ms">
        <div class="kp-stat-row">
          <div class="kp-stat">
            <div class="kp-stat-num"><span class="kp-grad-inline">50+</span></div>
            <div class="kp-stat-label">SME ไทยใช้งาน</div>
          </div>
          <div class="kp-stat-divider"></div>
          <div class="kp-stat">
            <div class="kp-stat-num"><span class="kp-grad-inline">24/7</span></div>
            <div class="kp-stat-label">AI ไม่หลับ</div>
          </div>
          <div class="kp-stat-divider"></div>
          <div class="kp-stat">
            <div class="kp-stat-num">&lt; <span class="kp-grad-inline">2 วิ</span></div>
            <div class="kp-stat-label">Response time</div>
          </div>
        </div>
      </div>

      <!-- Line + Facebook chips -->
      <div class="mt-7 flex items-center justify-center gap-2 text-xs text-brand-ink-400 kp-reveal" style="transition-delay:300ms">
        <span class="text-brand-ink-500">หรือแชทได้ที่:</span>
        <a href="https://lin.ee/Qt6Vri4" target="_blank" rel="noopener" class="kp-chip hover:!border-[#06C755]/50 hover:!text-[#06C755]">
          <svg viewBox="0 0 24 24" class="h-3.5 w-3.5" aria-hidden="true" fill="currentColor">
            <path d="M24 10.305C24 4.612 18.29 0 12 0 5.71 0 0 4.612 0 10.305c0 5.104 4.54 9.377 10.673 10.186.416.09.98.275 1.123.63.128.324.084.834.04 1.16l-.18 1.094c-.057.325-.26 1.27 1.113.693 1.374-.579 7.395-4.354 10.086-7.455C22.738 14.61 24 12.611 24 10.305"/>
          </svg>
          <span>LINE</span>
        </a>
        <a href="https://www.facebook.com/korpaiix" target="_blank" rel="noopener" class="kp-chip hover:!border-[#1877F2]/50 hover:!text-[#4AA0FF]">
          <svg viewBox="0 0 24 24" class="h-3.5 w-3.5" aria-hidden="true" fill="currentColor">
            <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
          </svg>
          <span>Facebook</span>
        </a>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <a href="#chat-demo" class="kp-scroll-hint" aria-label="เลื่อนลงดูต่อ">
    <span>SCROLL</span>
    <span class="kp-mouse"></span>
  </a>
</section>

<script is:inline>
  // Mouse parallax + spotlight
  (() => {
    const hero  = document.getElementById('hero');
    const beams = document.getElementById('kp-beams');
    const spot  = document.getElementById('kp-spotlight');
    if (!hero || !beams || !spot) return;

    const reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    let tx = 0, ty = 0, cx = 0, cy = 0, raf = 0;

    const onMove = (e) => {
      const r = hero.getBoundingClientRect();
      const px = (e.clientX - r.left) / r.width;
      const py = (e.clientY - r.top)  / r.height;
      spot.style.setProperty('--mx', (px * 100).toFixed(2) + '%');
      spot.style.setProperty('--my', (py * 100).toFixed(2) + '%');
      tx = (px - 0.5) * 50;
      ty = (py - 0.5) * 30;
      if (!raf && !reduce) raf = requestAnimationFrame(tick);
    };

    const tick = () => {
      cx += (tx - cx) * 0.07;
      cy += (ty - cy) * 0.07;
      beams.style.transform = `translate3d(${cx.toFixed(2)}px, ${cy.toFixed(2)}px, 0)`;
      if (Math.abs(tx - cx) > 0.1 || Math.abs(ty - cy) > 0.1) {
        raf = requestAnimationFrame(tick);
      } else { raf = 0; }
    };

    hero.addEventListener('mousemove', onMove, { passive: true });
    hero.addEventListener('mouseleave', () => {
      tx = 0; ty = 0;
      if (!raf && !reduce) raf = requestAnimationFrame(tick);
      spot.style.setProperty('--mx', '50%');
      spot.style.setProperty('--my', '40%');
    });
  })();
</script>
