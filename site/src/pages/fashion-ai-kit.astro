---
import Layout from '~/layouts/Layout.astro';

const packages = [
  {
    name: 'Basic Kit',
    price: '9,900',
    tag: 'ร้านเริ่มต้น',
    items: ['FAQ สินค้า 30 ข้อ', 'Template ตอบแชท 30 แบบ', 'Caption 20 ชิ้น', 'Hook TikTok/Reels 20 ชิ้น', 'Product Description 15 SKU', 'Mini Audit 3 หน้า'],
  },
  {
    name: 'Pro Kit',
    price: '24,000',
    tag: 'แนะนำ',
    highlight: true,
    items: ['FAQ สินค้า 60 ข้อ', 'Template ตอบแชท 60 แบบ', 'Caption 40 ชิ้น', 'Hook TikTok/Reels 40 ชิ้น', 'Product Description 30 SKU', 'Mini Audit 6 หน้า + Roadmap'],
  },
  {
    name: 'Premium Kit',
    price: '39,000',
    tag: 'แบรนด์โตเร็ว',
    items: ['FAQ 120 ข้อ + แบ่งหมวด', 'Template 100 แบบ + Tone Matrix', 'Caption 80 ชิ้น + Calendar', 'Hook 80 ชิ้น', 'Description 60 SKU + SEO', 'Strategy Session 1 ชม.'],
  },
];

const demoFaq = [
  ['ไซซ์ M อก 36 ใส่ได้ไหม?', 'ถ้าชอบพอดีตัว ใส่ M ได้ค่ะ แต่ถ้าชอบสบายช่วงอก แนะนำ L เพื่อให้ขยับง่ายขึ้นค่ะ'],
  ['ส่งของกี่วัน?', 'หลังชำระเงิน ร้านจะจัดส่งภายใน 1–2 วันทำการ และเลขพัสดุจะแจ้งในแชทค่ะ'],
  ['ผ้าหดไหม?', 'ขึ้นกับวิธีซักและชนิดผ้าค่ะ เราจะแนะนำวิธีดูแลผ้าให้ในหน้าสินค้า เพื่อให้ทรงอยู่ได้นานที่สุด'],
];

const deliverables = [
  ['FAQ Library', 'รวมคำถามซ้ำเรื่องไซซ์ สี ผ้า ส่งของ คืนสินค้า พร้อมคำตอบที่เข้ากับแบรนด์'],
  ['Chat Templates', 'ประโยคตอบลูกค้าก่อนขาย หลังขาย ต่อรองราคา เคลมสินค้า และ upsell'],
  ['Content Pack', 'Caption, Hook TikTok/Reels, ไอเดียโพสต์ และ content calendar สำหรับ 30 วัน'],
  ['Product Description', 'คำอธิบายสินค้าแบบขายได้จริง อ่านง่าย ใช้ลงเว็บ Shopee Lazada หรือ Facebook ได้'],
  ['Mini Audit', 'ชี้จุดรั่วบนหน้าร้าน/คอนเทนต์ พร้อมแผนแก้ 30 วัน'],
  ['Prompt Pack', 'ชุด prompt ให้ทีมร้านใช้ AI ต่อเอง โดยยังคุม tone แบรนด์ได้'],
];

const timeline = [
  ['Day 1', 'รับ brief + ดูร้าน + สรุป Brand Voice'],
  ['Day 2–4', 'ผลิต FAQ, Template, Caption, Hook และ Description'],
  ['Day 5–7', 'QC งาน + ส่ง Demo Kit + แนะนำวิธีใช้จริงกับทีมแอดมิน'],
];
---

<Layout
  title="AI Content + FAQ Kit สำหรับร้านเสื้อผ้าออนไลน์ | KORP AI"
  description="KORP AI ช่วยร้านเสื้อผ้าออนไลน์ทำ FAQ, Template ตอบแชท, Caption, Hook TikTok และ Product Description พร้อมใช้ภายใน 7-14 วัน"
  canonical="https://korpai.co/fashion-ai-kit"
  image="https://korpai.co/assets/img/fashion-ai-kit/hero.jpg"
>
  <section class="relative overflow-hidden pt-28 pb-16 md:pt-36 md:pb-24">
    <div class="kp-container grid gap-10 lg:grid-cols-[0.82fr_1.18fr] lg:items-center">
      <div class="kp-reveal">
        <span class="kp-pill">Fashion AI Kit · พร้อมใช้ใน 7–14 วัน</span>
        <h1 class="mt-6 max-w-3xl text-5xl font-bold tracking-[-0.045em] text-white md:text-6xl lg:text-7xl leading-[1.12] md:leading-[1.08] lg:leading-[1.06]">
          คลังตอบแชท + คอนเทนต์สำหรับร้านเสื้อผ้า
        </h1>
        <p class="mt-6 max-w-xl text-lg leading-relaxed text-slate-400">
          ทำ FAQ, template ตอบลูกค้า, caption, hook TikTok และคำอธิบายสินค้า ให้ทีมร้านก็อปไปใช้ได้ทันที
        </p>
        <div class="mt-7 flex flex-wrap gap-4">
          <a class="kp-btn-primary" href="https://lin.ee/Qt6Vri4" target="_blank" rel="noopener">ขอ Audit ตัวอย่างฟรี</a>
          <a class="kp-btn-secondary" href="#demo-kit">ลองกดดู Demo</a>
        </div>
        <div class="mt-7 grid max-w-xl grid-cols-3 gap-3 text-center">
          <div class="kp-card p-4"><div class="text-2xl font-bold text-white">30–120</div><div class="mt-1 text-xs text-slate-400">FAQ พร้อมใช้</div></div>
          <div class="kp-card p-4"><div class="text-2xl font-bold text-white">7–14</div><div class="mt-1 text-xs text-slate-400">วันส่งงาน</div></div>
          <div class="kp-card p-4"><div class="text-2xl font-bold text-white">100%</div><div class="mt-1 text-xs text-slate-400">ปรับตามแบรนด์</div></div>
        </div>
      </div>

      <div class="kp-reveal" style="transition-delay:90ms">
        <div class="sample-workspace" data-sample-workspace>
          <div class="sample-topbar">
            <div>
              <div class="sample-kicker">ตัวอย่างไฟล์ส่งมอบจริง</div>
              <div class="sample-client">Linn Studio · Pro Kit</div>
            </div>
            <div class="sample-badge">Client-ready</div>
          </div>

          <div class="sample-tabs" role="tablist" aria-label="ตัวอย่างงานจริงที่ลูกค้าจะได้รับ">
            <button class="is-active" type="button" data-sample="faq">FAQ Sheet</button>
            <button type="button" data-sample="chat">Chat Script</button>
            <button type="button" data-sample="caption">Content Calendar</button>
            <button type="button" data-sample="hook">TikTok Hooks</button>
            <button type="button" data-sample="sku">SKU Sheet</button>
          </div>

          <section class="sample-document" aria-live="polite">
            <div class="doc-head">
              <div>
                <div id="sampleType" class="doc-type">FAQ SHEET</div>
                <h3 id="sampleTitle">FAQ พร้อมใช้สำหรับแอดมิน 60 ข้อ</h3>
              </div>
              <span id="sampleCount">Preview 3/60</span>
            </div>

            <div id="sampleContent" class="doc-content">
              <div class="real-table">
                <div class="real-row real-head"><span>หมวด</span><span>คำถามลูกค้า</span><span>คำตอบที่แอดมินใช้ตอบได้ทันที</span></div>
                <div class="real-row"><span>ไซซ์</span><b>อก 36 ใส่ M ได้ไหม?</b><p>ถ้าชอบพอดีตัวใส่ M ได้ค่ะ แต่ถ้าชอบสบายช่วงอก แนะนำ L จะขยับง่ายกว่า เดี๋ยวแอดมินส่งตารางไซซ์ให้เทียบอีกครั้งนะคะ</p></div>
                <div class="real-row"><span>จัดส่ง</span><b>โอนแล้วส่งวันนี้ไหม?</b><p>ถ้าชำระก่อน 14:00 น. ร้านจัดส่งรอบวันนี้ได้ค่ะ หลังแพ็กเสร็จจะแจ้งเลขพัสดุให้ในแชทนี้นะคะ</p></div>
                <div class="real-row"><span>ดูแลผ้า</span><b>ผ้าลินินซักเครื่องได้ไหม?</b><p>ซักเครื่องได้โดยใส่ถุงถนอมผ้าและเลือกโหมดอ่อนโยนค่ะ แนะนำตากในที่ร่มเพื่อช่วยรักษาทรงและสีของผ้า</p></div>
              </div>
            </div>
          </section>
        </div>
      </div>
    </div>
  </section>

  <section class="relative border-t kp-hairline py-20 md:py-24">
    <div class="kp-container">
      <div class="mx-auto max-w-3xl text-center kp-reveal">
        <span class="kp-pill">Pain ที่แก้ให้</span>
        <h2 class="prose-kp mt-5">ร้านเสื้อผ้าไม่ได้ขาดสินค้า แต่ขาดระบบตอบและระบบคอนเทนต์</h2>
      </div>
      <div class="mt-12 grid gap-5 md:grid-cols-3">
        {[
          ['แอดมินตอบไซซ์/สี/ส่งของซ้ำทุกวัน', 'คำถามเดิมกินเวลาทีม และลูกค้าที่รอคำตอบนานมักหลุดก่อนตัดสินใจซื้อ'],
          ['ต้องโพสต์ทุกวันแต่คิด caption ไม่ทัน', 'คอลเลกชันเปลี่ยนเร็ว แต่ทีมไม่มีคลังคอนเทนต์ที่พร้อมใช้ต่อเนื่อง'],
          ['ข้อมูลสินค้าไม่ครบจนลูกค้าถามวน', 'รายละเอียดผ้า ทรง การดูแล และขนาด ถ้าไม่ชัด จะกลายเป็นภาระแชททันที'],
        ].map((item, i) => (
          <article class="kp-card kp-reveal" style={`transition-delay:${i * 70}ms`}>
            <h3 class="prose-kp">{item[0]}</h3>
            <p class="mt-3 text-sm leading-relaxed text-slate-400">{item[1]}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section id="demo-kit" class="relative border-t kp-hairline py-20 md:py-24 overflow-hidden">
    <div class="kp-container">
      <div class="mx-auto max-w-3xl text-center kp-reveal">
        <span class="kp-pill">Interactive Demo</span>
        <h2 class="prose-kp mt-5">กดดูตัวอย่างงานจริงในแต่ละหมวด</h2>
        <p class="prose-kp mt-5">ลูกค้าไม่ได้เห็นแค่ภาพสวย แต่เห็นตัวอย่าง output ที่จะได้จริง: FAQ, แชท, caption, hook และคำอธิบายสินค้า</p>
      </div>

      <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {[
          ['FAQ Library', 'Q: ไซซ์ M อก 36 ใส่ได้ไหม?', 'A: ถ้าชอบพอดีตัวใส่ M ได้ค่ะ แต่ถ้าอยากขยับสบาย แนะนำ L พร้อมเทียบตารางไซซ์ก่อนสั่งค่ะ'],
          ['Chat Template', 'ลูกค้าถามว่าส่งวันนี้ได้ไหม', 'ถ้าชำระก่อน 14:00 น. ร้านจัดส่งรอบวันนี้ได้ค่ะ หลังจากนั้นจะเป็นรอบวันทำการถัดไปนะคะ'],
          ['Caption', 'New drop: linen set', 'ลุคเรียบที่หยิบใส่ได้ทั้งวัน — เซ็ตผ้าลินินทรงสบาย ใส่ง่าย ถ่ายรูปขึ้น และแมตช์ได้หลายโอกาส'],
          ['TikTok Hook', '3 วิแรกสำหรับคลิป', 'หยุดก่อน ถ้าคุณกำลังหาเซ็ตทำงานที่ใส่แล้วดูแพง แต่ไม่ต้องรีดนาน'],
          ['Product Description', 'เดรสผ้าไหมอิตาลี', 'เดรสทรงตรงผ้าสัมผัสนุ่ม มีซับใน ใส่ออกงานหรือดินเนอร์ได้ เหมาะกับคนที่ชอบลุค minimal luxury'],
          ['Mini Audit', 'จุดรั่วบนหน้าร้าน', 'หน้าสินค้ามีรูปสวยแล้ว แต่ยังขาดตารางไซซ์และคำแนะนำทรง ทำให้ลูกค้าต้องทักถามก่อนซื้อ'],
        ].map((card, i) => (
          <article class="kp-card kp-reveal" style={`transition-delay:${i * 55}ms`}>
            <div class="text-xs font-mono tracking-[0.18em] text-cyan-300">{card[0]}</div>
            <h3 class="mt-4 text-lg font-semibold text-white">{card[1]}</h3>
            <p class="mt-3 text-sm leading-relaxed text-slate-400">{card[2]}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="relative border-t kp-hairline py-20 md:py-24">
    <div class="kp-container">
      <div class="max-w-3xl kp-reveal">
        <span class="kp-pill">Deliverables</span>
        <h2 class="prose-kp mt-5">1 Kit ครอบคลุมทั้งแชท คอนเทนต์ และหน้าสินค้า</h2>
      </div>
      <div class="mt-12 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
        {deliverables.map((d, i) => (
          <article class="kp-card kp-reveal" style={`transition-delay:${i * 50}ms`}>
            <div class="mb-4 inline-flex h-10 w-10 items-center justify-center rounded-2xl bg-cyan-400/10 text-sm font-bold text-cyan-300">{String(i + 1).padStart(2, '0')}</div>
            <h3 class="prose-kp">{d[0]}</h3>
            <p class="mt-3 text-sm leading-relaxed text-slate-400">{d[1]}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="relative border-t kp-hairline py-20 md:py-24">
    <div class="kp-container">
      <div class="mx-auto max-w-3xl text-center kp-reveal">
        <span class="kp-pill">Packages</span>
        <h2 class="prose-kp mt-5">เลือกแพ็กเกจตามขนาดร้าน</h2>
        <p class="prose-kp mt-5">ราคาไม่รวม VAT 7% และสามารถต่อยอดเป็น retainer รายเดือนได้หลังส่งงานชุดแรก</p>
      </div>
      <div class="mt-12 grid gap-5 lg:grid-cols-3">
        {packages.map((p, i) => (
          <article class={`kp-card kp-reveal relative ${p.highlight ? 'border-cyan-300/40 bg-cyan-400/[0.06]' : ''}`} style={`transition-delay:${i * 80}ms`}>
            {p.highlight && <div class="absolute right-5 top-5 rounded-full bg-cyan-300 px-3 py-1 text-xs font-bold text-slate-950">ขายดีที่สุด</div>}
            <div class="text-sm text-cyan-300">{p.tag}</div>
            <h3 class="mt-3 text-2xl font-bold text-white">{p.name}</h3>
            <div class="mt-5 flex items-end gap-1"><span class="text-4xl font-extrabold text-white">฿{p.price}</span><span class="pb-1 text-sm text-slate-400">/ครั้ง</span></div>
            <ul class="mt-7 space-y-3">
              {p.items.map((it) => <li class="flex gap-3 text-sm leading-relaxed text-slate-300"><span class="mt-1 h-2 w-2 shrink-0 rounded-full bg-cyan-300"></span>{it}</li>)}
            </ul>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="relative border-t kp-hairline py-20 md:py-24">
    <div class="kp-container grid gap-10 lg:grid-cols-[0.85fr_1.15fr] lg:items-start">
      <div class="kp-reveal">
        <span class="kp-pill">Process</span>
        <h2 class="prose-kp mt-5">ส่งงานเร็ว แต่มี QC ทุกขั้น</h2>
        <p class="prose-kp mt-5">งานเกี่ยวกับไซซ์ ราคา นโยบายคืนสินค้า และขนส่ง ห้ามมั่ว เราจึงเริ่มจากข้อมูลจริงของร้าน แล้วตรวจทุกชิ้นก่อนส่ง</p>
      </div>
      <div class="grid gap-4">
        {timeline.map((t, i) => (
          <div class="kp-card kp-reveal flex gap-5" style={`transition-delay:${i * 70}ms`}>
            <div class="min-w-20 text-sm font-mono text-cyan-300">{t[0]}</div>
            <div><h3 class="font-semibold text-white">{t[1]}</h3><p class="mt-1 text-sm text-slate-400">เหมาะกับทีมที่อยากเริ่มใช้ AI แบบปลอดภัย ไม่เสี่ยงเอาข้อความผิดไปตอบลูกค้า</p></div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="relative border-t kp-hairline py-20 md:py-24">
    <div class="kp-container">
      <div class="kp-card kp-reveal overflow-hidden p-8 md:p-12">
        <div class="grid gap-10 lg:grid-cols-[1fr_0.8fr] lg:items-center">
          <div>
            <span class="kp-pill">Free Sample</span>
            <h2 class="prose-kp mt-5">อยากเห็นก่อนว่าร้านคุณจะได้อะไร?</h2>
            <p class="prose-kp mt-5">ส่งชื่อร้าน/ลิงก์เพจ/ช่องทางขายมาให้เรา เราจะดูร้านและทำตัวอย่าง audit สั้น ๆ ให้ก่อน ถ้าเห็นภาพค่อยเริ่มแพ็กเกจจริง</p>
            <div class="mt-8 flex flex-wrap gap-4">
              <a class="kp-btn-line" href="https://lin.ee/Qt6Vri4" target="_blank" rel="noopener">ทัก LINE เพื่อขอตัวอย่าง</a>
              <a class="kp-btn-fb" href="https://www.facebook.com/korpaiix" target="_blank" rel="noopener">ทัก Facebook Page</a>
            </div>
          </div>
          <div class="rounded-3xl border border-white/10 bg-black/20 p-5">
            <div class="text-sm font-semibold text-white">ข้อมูลที่ส่งมาได้เลย</div>
            <ul class="mt-4 space-y-3 text-sm text-slate-300">
              <li>• ลิงก์ร้าน / Facebook / IG / TikTok / Shopee</li>
              <li>• สินค้าหลักที่ขาย และช่วงราคา</li>
              <li>• ปัญหาหนักสุดตอนนี้: ตอบแชท / คอนเทนต์ / หน้าสินค้า</li>
              <li>• จำนวน SKU หรือจำนวนแชทโดยประมาณต่อวัน</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .sample-workspace {
    position: relative;
    overflow: hidden;
    border-radius: 30px;
    border: 1px solid rgba(255,255,255,0.12);
    background:
      radial-gradient(circle at 18% 12%, rgba(38,215,246,0.16), transparent 34%),
      radial-gradient(circle at 92% 90%, rgba(124,95,255,0.16), transparent 42%),
      rgba(7, 12, 24, 0.92);
    box-shadow: 0 28px 90px rgba(0,0,0,0.48), 0 0 70px rgba(38,215,246,0.10);
    padding: 18px;
  }
  .sample-topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 4px 2px 16px;
  }
  .sample-kicker { color:#26d7f6; font-size:12px; font-weight:900; letter-spacing:.08em; }
  .sample-client { margin-top:3px; color:white; font-size:15px; font-weight:800; }
  .sample-badge {
    border-radius:999px;
    border:1px solid rgba(16,185,129,.25);
    background:rgba(16,185,129,.12);
    color:#a7f3d0;
    padding:7px 12px;
    font-size:12px;
    font-weight:900;
    white-space:nowrap;
  }
  .sample-tabs {
    display:flex;
    gap:8px;
    overflow-x:auto;
    padding:6px;
    border-radius:999px;
    border:1px solid rgba(255,255,255,.08);
    background:rgba(255,255,255,.045);
  }
  .sample-tabs button {
    flex:1 0 auto;
    border:0;
    border-radius:999px;
    padding:10px 13px;
    background:transparent;
    color:#9fb0d0;
    font-size:12px;
    font-weight:900;
    cursor:pointer;
    transition:.18s ease;
  }
  .sample-tabs button.is-active,
  .sample-tabs button:hover { background:#26d7f6; color:#041018; }
  .sample-document {
    margin-top:14px;
    border-radius:24px;
    border:1px solid rgba(255,255,255,.10);
