---
import Layout from '~/layouts/Layout.astro';
const faqRows = [
  ['ไซซ์','อก 36 เอว 28 ใส่ไซซ์ไหนดี?','แนะนำไซซ์ L ค่ะ ช่วงอกจะใส่สบายกว่า M และยังได้ทรงตรงสวย ไม่รัดช่วงเอวเกินไปนะคะ','Pre-sale'],
  ['ไซซ์','สูง 160 เดรสจะยาวประมาณไหน?','ความยาวจะอยู่ประมาณช่วงน่องบนค่ะ ถ้าต้องการ แอดมินส่งรูปเทียบกับนางแบบสูงใกล้เคียงให้ดูได้ค่ะ','Pre-sale'],
  ['ผ้า','ผ้าลินินยับง่ายไหม?','ลินินมี texture ยับธรรมชาติเล็กน้อยค่ะ แต่เป็นลุคที่ดูแพงและระบายอากาศดี เหมาะกับอากาศเมืองไทยค่ะ','Product'],
  ['จัดส่ง','โอนแล้วส่งวันนี้ได้ไหม?','ถ้าชำระก่อน 14:00 น. ร้านจัดส่งรอบวันนี้ได้ค่ะ หลังแพ็กเสร็จจะแจ้งเลขพัสดุให้ในแชทนี้นะคะ','Post-sale'],
  ['คืนสินค้า','เปลี่ยนไซซ์ได้ไหม?','เปลี่ยนไซซ์ได้ภายใน 3 วันหลังได้รับสินค้า หากสินค้ายังไม่ผ่านการใช้งาน/ซัก และป้ายสินค้ายังครบค่ะ','Policy'],
];
const captions = [
  ['Day 01','IG','New Linen Set','ลุคเรียบที่หยิบใส่ได้ทั้งวัน — เซ็ตผ้าลินินทรงสบาย ใส่ง่าย ถ่ายรูปขึ้น และแมตช์ได้หลายโอกาส 🤍 #minimalstyle #linenset'],
  ['Day 03','Facebook','Behind the fabric','ผ้าที่เลือกใช้ในคอลเลกชันนี้เน้นเบา ระบายอากาศดี และไม่แนบตัว เหมาะกับอากาศเมืองไทยจริง ๆ ค่ะ'],
  ['Day 05','TikTok','Try-on clip','ชุดเดียวที่ช่วยให้ “วันรีบ ๆ” ดูตั้งใจแต่งขึ้นทันที — อยากดูสีไหนคอมเมนต์ไว้ค่ะ'],
  ['Day 07','Facebook','Soft CTA','ถ้ากำลังหาเดรสที่ใส่ทำงานได้และต่อด้วยดินเนอร์ได้เลย รุ่นนี้คือชิ้นที่ควรมีในตู้ค่ะ'],
];
const hooks = [
  ['01','หยุดก่อน ถ้าคุณกำลังหาเซ็ตทำงานที่ดูแพง แต่ไม่ต้องรีดนาน','เปิดด้วย close-up เนื้อผ้า → zoom out full outfit'],
  ['02','ชุดนี้ใส่ไปออฟฟิศได้ แต่หลังเลิกงานไปคาเฟ่ต่อก็ยังรอด','transition จาก blazer → ถือกระเป๋าเล็ก'],
  ['03','3 จุดที่ทำให้เดรสตัวนี้พรางหุ่นดีกว่าที่คิด','ชี้ช่วงไหล่ เอว ความยาว พร้อม text overlay'],
  ['04','ถ้าคุณไม่ชอบชุดรัด แต่ยังอยากดูมีทรง ลองดูตัวนี้','เดิน/นั่งให้เห็นการขยับของผ้า'],
];
---
<Layout title="Demo: AI Content + FAQ Kit | KORP AI" description="หน้า demo ใช้งานจริงของ AI Content + FAQ Kit สำหรับร้านเสื้อผ้าออนไลน์" canonical="https://korpai.co/fashion-ai-kit/demo">
  <section class="demo-app">
    <aside class="demo-sidebar">
      <a href="/fashion-ai-kit" class="back-link">← กลับหน้าแพ็กเกจ</a>
      <div class="brand-card"><div class="brand-dot">LS</div><div><b>Linn Studio</b><span>AI Content + FAQ Kit</span></div></div>
      <nav class="demo-nav"><a href="#faq" class="is-active">FAQ Sheet</a><a href="#chat">Chat Scripts</a><a href="#calendar">Content Calendar</a><a href="#hooks">TikTok Hooks</a><a href="#sku">SKU Sheet</a><a href="#audit">Mini Audit</a></nav>
      <div class="summary-card"><small>Pro Kit Preview</small><strong>60 FAQ · 60 Chat · 40 Caption · 30 SKU</strong><p>ตัวอย่างหน้าส่งมอบที่ลูกค้าจะได้รับหลังทำงานกับ KORP AI</p></div>
    </aside>
    <main class="demo-main">
      <header class="demo-header"><div><span class="kp-pill">Interactive client demo</span><h1>ตัวอย่างงานจริงที่ร้านเสื้อผ้าจะได้รับ</h1><p>กดดูแต่ละหมวดเหมือนเปิด workspace ลูกค้าจริง — ไม่ใช่ภาพ mockup และไม่ใช่คำอธิบายลอย ๆ</p></div><a class="kp-btn-primary" href="https://lin.ee/Qt6Vri4" target="_blank" rel="noopener">ขอทำตัวอย่างร้านคุณ</a></header>
      <section id="faq" class="demo-panel"><div class="panel-head"><div><small>01 / FAQ SHEET</small><h2>FAQ สำหรับแอดมินตอบลูกค้า</h2></div><span>Preview 5/60</span></div><div class="data-table"><div class="data-row data-head"><span>หมวด</span><span>คำถามลูกค้า</span><span>คำตอบพร้อมใช้</span><span>Tag</span></div>{faqRows.map((r)=><div class="data-row"><span>{r[0]}</span><b>{r[1]}</b><p>{r[2]}</p><em>{r[3]}</em></div>)}</div></section>
      <section id="chat" class="demo-panel"><div class="panel-head"><div><small>02 / CHAT SCRIPT</small><h2>บทสนทนาที่แอดมินก็อปไปใช้ได้</h2></div><span>Preview 2/60</span></div><div class="chat-grid"><article class="script-card"><b>แนะนำไซซ์แบบไม่เดา</b><span>ใช้เมื่อลูกค้าบอกสัดส่วนมาแล้ว</span><div class="chat-thread"><div class="bubble customer">สูง 160 หนัก 52 อก 36 เอว 28 ใส่เดรสตัวนี้ไซซ์ไหนดีคะ?</div><div class="bubble admin">จากสัดส่วนที่แจ้งมา แนะนำไซซ์ L ค่ะ ช่วงอกจะใส่สบายกว่า M และยังได้ทรงตรงสวย ไม่รัดช่วงเอวเกินไปนะคะ</div><div class="bubble customer">ถ้าอยากใส่พอดีตัวล่ะคะ?</div><div class="bubble admin">ถ้าชอบพอดีตัวมาก ๆ M ใส่ได้ค่ะ แต่แนะนำ L มากกว่า เพราะเวลานั่ง/เดินจะขยับสบายกว่า</div></div></article><article class="script-card"><b>ลูกค้าขอเลขพัสดุ</b><span>ใช้หลังลูกค้าชำระเงินแล้ว</span><div class="chat-thread"><div class="bubble customer">ขอเลขพัสดุหน่อยค่ะ</div><div class="bubble admin">เลขพัสดุของคุณลูกค้าคือ [TRACKING] ค่ะ เช็กสถานะได้ที่ [LINK] นะคะ ถ้าขนส่งอัปเดตช้า แอดมินช่วยตามให้ได้ค่ะ</div></div></article></div></section>
      <section id="calendar" class="demo-panel"><div class="panel-head"><div><small>03 / CONTENT CALENDAR</small><h2>Caption และแผนโพสต์ 30 วัน</h2></div><span>Preview 4/40</span></div><div class="calendar-grid">{captions.map((c)=><article class="content-card"><small>{c[0]} · {c[1]}</small><h3>{c[2]}</h3><p>{c[3]}</p></article>)}</div></section>
      <section id="hooks" class="demo-panel"><div class="panel-head"><div><small>04 / TIKTOK HOOKS</small><h2>Hook คลิปสั้นพร้อมมุมถ่าย</h2></div><span>Preview 4/40</span></div><div class="hook-list">{hooks.map((h)=><article class="hook-item"><span>{h[0]}</span><div><b>{h[1]}</b><p>{h[2]}</p></div></article>)}</div></section>
      <section id="sku" class="demo-panel"><div class="panel-head"><div><small>05 / SKU SHEET</small><h2>Product Description พร้อมลง Marketplace</h2></div><span>Preview 1/30</span></div><article class="sku-card"><div class="sku-photo"></div><div class="sku-fields"><div><small>ชื่อสินค้า</small><p>Linn Linen Straight Dress — Ivory</p></div><div><small>คำอธิบายสั้น</small><p>เดรสลินินทรงตรง เนื้อผ้าเบา ระบายอากาศดี มีซับใน ใส่ง่ายทั้งวัน เหมาะกับลุคทำงาน คาเฟ่ หรือทริปวันหยุด</p></div><div><small>จุดขาย</small><p>ทรงไม่รัดช่วงเอว · ผ้าเบาไม่แนบตัว · มีซับใน · แมตช์กับ blazer หรือ sandal ได้</p></div><div><small>Care note</small><p>แนะนำซักมือหรือโหมดถนอมผ้า ตากในที่ร่ม และรีดไฟอ่อนจากด้านใน</p></div></div></article></section>
      <section id="audit" class="demo-panel"><div class="panel-head"><div><small>06 / MINI AUDIT</small><h2>จุดรั่วที่ควรแก้ก่อนยิงคอนเทนต์</h2></div><span>Preview</span></div><div class="audit-grid"><article class="audit-card"><small>หน้าสินค้า</small><h3>มีรูปสวยแล้ว แต่ยังขาดตารางไซซ์และคำแนะนำทรง</h3><p>เพิ่ม size guide + note “รุ่นนี้ทรงตรง/ไม่รัดเอว” ใต้รูปสินค้า</p></article><article class="audit-card"><small>แชท</small><h3>แอดมินตอบไซซ์ด้วยประสบการณ์ส่วนตัว ทำให้คำตอบไม่สม่ำเสมอ</h3><p>ใช้ template แนะนำไซซ์ตามอก/เอว/ความสูง พร้อมถามข้อมูลเพิ่มก่อนฟันธง</p></article></div></section>
    </main>
  </section>
</Layout>
<style>
.demo-app{display:grid;grid-template-columns:290px 1fr;min-height:100vh}.demo-sidebar{position:sticky;top:0;height:100vh;padding:24px;border-right:1px solid rgba(255,255,255,.08);background:rgba(3,7,18,.82);backdrop-filter:blur(14px)}.back-link{color:#8aa0c5;font-size:13px;text-decoration:none}.brand-card{margin-top:24px;display:flex;align-items:center;gap:12px;border:1px solid rgba(255,255,255,.09);background:rgba(255,255,255,.045);border-radius:20px;padding:14px}.brand-dot{width:42px;height:42px;border-radius:14px;display:grid;place-items:center;color:#061018;background:#26d7f6;font-weight:950}.brand-card b,.brand-card span{display:block}.brand-card b{color:white}.brand-card span{color:#8aa0c5;font-size:12px;margin-top:2px}.demo-nav{display:grid;gap:8px;margin-top:24px}.demo-nav a{padding:12px 14px;border-radius:14px;color:#9fb0d0;text-decoration:none;font-weight:800;font-size:13px}.demo-nav a:hover,.demo-nav a.is-active{color:white;background:rgba(38,215,246,.10);border:1px solid rgba(38,215,246,.18)}.summary-card{position:absolute;left:24px;right:24px;bottom:24px;border:1px solid rgba(255,255,255,.09);background:rgba(255,255,255,.045);border-radius:20px;padding:16px}.summary-card small{color:#26d7f6;font-weight:900}.summary-card strong{display:block;color:white;margin-top:7px;line-height:1.4}.summary-card p{color:#8aa0c5;font-size:12px;line-height:1.55;margin-top:8px}.demo-main{padding:34px clamp(20px,4vw,56px) 70px;max-width:1240px;width:100%}.demo-header{display:flex;align-items:flex-start;justify-content:space-between;gap:24px;margin-bottom:28px}.demo-header h1{color:white;margin-top:18px;font-size:clamp(2.2rem,5vw,4.8rem);line-height:1.08;letter-spacing:-.055em;max-width:820px}.demo-header p{color:#8aa0c5;max-width:690px;margin-top:16px;font-size:18px;line-height:1.7}.demo-panel{scroll-margin-top:24px;margin-top:22px;border:1px solid rgba(255,255,255,.10);border-radius:28px;background:linear-gradient(180deg,rgba(255,255,255,.065),rgba(255,255,255,.025));padding:22px}.panel-head{display:flex;align-items:flex-start;justify-content:space-between;gap:16px;padding-bottom:16px;border-bottom:1px solid rgba(255,255,255,.08)}.panel-head small{color:#26d7f6;font-weight:950;letter-spacing:.16em}.panel-head h2{color:white;margin-top:8px;font-size:28px;letter-spacing:-.035em}.panel-head span{color:#8aa0c5;font-size:13px}.data-table{margin-top:18px;border-radius:18px;overflow:hidden;border:1px solid rgba(255,255,255,.08)}.data-row{display:grid;grid-template-columns:90px 1fr 1.7fr 90px;gap:14px;padding:14px;border-top:1px solid rgba(255,255,255,.07);align-items:start;background:rgba(255,255,255,.025)}.data-row:first-child{border-top:0}.data-head{background:rgba(38,215,246,.10)}.data-head span{color:#9beeff;font-size:11px;font-weight:950;letter-spacing:.08em}.data-row span{color:#26d7f6;font-weight:900;font-size:12px}.data-row b{color:white;font-size:14px;line-height:1.5}.data-row p{color:#b7c5df;font-size:13px;line-height:1.65;margin:0}.data-row em{color:#a7f3d0;font-style:normal;font-size:12px}.chat-grid,.calendar-grid,.audit-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:16px;margin-top:18px}.script-card,.content-card,.hook-item,.sku-card,.audit-card{border:1px solid rgba(255,255,255,.085);background:rgba(255,255,255,.035);border-radius:20px;padding:16px}.script-card b,.content-card h3,.audit-card h3,.hook-item b{color:white}.script-card span,.content-card p,.audit-card p,.hook-item p{color:#b7c5df;font-size:13px;line-height:1.65}.chat-thread{display:grid;gap:10px;margin-top:14px}.bubble{max-width:88%;border-radius:18px;padding:12px 14px;font-size:13px;line-height:1.65}.bubble.customer{background:rgba(255,255,255,.075);color:#d9e3f7}.bubble.admin{margin-left:auto;background:rgba(38,215,246,.14);border:1px solid rgba(38,215,246,.22);color:#effcff}.content-card small,.audit-card small{color:#26d7f6;font-weight:900}.hook-list{display:grid;gap:12px;margin-top:18px}.hook-item{display:grid;grid-template-columns:44px 1fr;gap:12px}.hook-item span{color:#26d7f6;font-family:ui-monospace,monospace}.sku-card{display:grid;grid-template-columns:260px 1fr;gap:16px;margin-top:18px}.sku-photo{border-radius:18px;min-height:220px;background:linear-gradient(135deg,rgba(38,215,246,.15),rgba(124,95,255,.18)),url('/assets/img/fashion-ai-kit/hero.jpg') center/cover;border:1px solid rgba(255,255,255,.10)}.sku-fields{display:grid;gap:10px}.sku-fields div{border-radius:14px;background:rgba(0,0,0,.20);padding:12px}.sku-fields small{color:#26d7f6;font-weight:900}.sku-fields p{color:#dce6f8;margin-top:5px;font-size:13px;line-height:1.6}@media(max-width:980px){.demo-app{grid-template-columns:1fr}.demo-sidebar{position:relative;height:auto}.summary-card{position:static;margin-top:20px}.demo-header{display:block}.demo-header .kp-btn-primary{margin-top:20px}.chat-grid,.calendar-grid,.audit-grid{grid-template-columns:1fr}.data-row,.sku-card{grid-template-columns:1fr}}
</style>
