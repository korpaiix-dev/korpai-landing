# KORP AI — ตัวอย่าง .env สำหรับ n8n production (คัดลอกเป็น .env แล้วแก้ค่า)
# สร้างรหัสสุ่ม: openssl rand -hex 24
POSTGRES_USER=n8n
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=n8n

# ⚠️ สำคัญสุด — ตั้งเองและสำรองคีย์นี้แยกไว้นอกเครื่อง
# ถ้าคีย์นี้หาย credentials ทุกอันที่เข้ารหัสไว้จะถอดไม่ได้
N8N_ENCRYPTION_KEY=CHANGE_ME_run_openssl_rand_hex_24

# โดเมนจริงของคุณ (ต้องตรงกับใน Caddyfile)
N8N_HOST=n8n.yourcompany.com
