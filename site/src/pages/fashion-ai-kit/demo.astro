---
import Layout from '~/layouts/Layout.astro';
---
<Layout title="ตัวอย่างหน้าระบบช่วยตอบแชทร้านเสื้อผ้า | KORP AI" description="Mockup หน้าจอใช้งานจริงของระบบ AI ช่วยตอบแชทและช่วยขายสำหรับร้านเสื้อผ้าออนไลน์" canonical="https://korpai.co/fashion-ai-kit/demo">
  <section class="work-app">
    <aside class="leftbar">
      <a class="back" href="/fashion-ai-kit">← กลับ</a>
      <div class="shop"><div>LS</div><b>Linn Studio</b><span>ระบบช่วยตอบแชท</span></div>
      <nav><a class="active">กล่องแชท</a><a>สินค้า</a><a>คำตอบ AI</a><a>งานที่ต้องทำ</a><a>ตั้งค่าร้าน</a></nav>
      <div class="ai-switch"><span></span><div><b>AI เปิดอยู่</b><small>ช่วยตอบแชทอัตโนมัติ</small></div></div>
    </aside>

    <main class="work-main">
      <header class="work-top">
        <div><a class="mobile-back" href="/fashion-ai-kit">← กลับหน้าแพ็กเกจ</a><small>ตัวอย่างหน้าระบบใช้งานจริง</small><h1>กล่องแชทร้าน Linn Studio</h1></div>
        <div class="top-buttons"><button>พัก AI ชั่วคราว</button><a href="https://lin.ee/Qt6Vri4" target="_blank" rel="noopener">อยากได้ระบบนี้</a></div>
      </header>

      <div class="work-grid">
        <section class="chat-list panel">
          <div class="panel-title"><b>ลูกค้าที่ทักมา</b><span>วันนี้ 24 แชท</span></div>
          <button class="active"><div><b>ลูกค้ามายด์</b><p>ถามไซซ์เดรสสีครีม</p></div><em>AI ตอบอยู่</em></button>
          <button><div><b>ลูกค้าแพรว</b><p>ขอส่งด่วนใน กทม.</p></div><em class="warn">รอแอดมิน</em></button>
          <button><div><b>ลูกค้านัท</b><p>ถามกางเกงเอวสูง</p></div><em>ตอบจบแล้ว</em></button>
          <button><div><b>ลูกค้าบี</b><p>ถามโปรซื้อ 2 ชิ้น</p></div><em>AI ตอบอยู่</em></button>
        </section>

        <section class="chat-room panel">
          <div class="room-head"><div><b>ลูกค้ามายด์</b><span>กำลังดูสินค้า: Linen Straight Dress — สีครีม</span></div><button>ส่งต่อแอดมิน</button></div>
          <div class="messages">
            <div class="msg customer">มีเดรสสีครีมไหมคะ สูง 160 อก 36 ใส่ไซซ์ไหนดี?</div>
            <div class="msg ai"><small>AI ตอบจากข้อมูลสินค้า</small>มีค่ะ รุ่น Linen Straight สีครีมเหลือไซซ์ M/L จากอก 36 แนะนำ L จะใส่สบายกว่า และยังได้ทรงตรงสวยนะคะ</div>
            <div class="msg customer">ส่งวันนี้ได้ไหมคะ?</div>
            <div class="msg ai"><small>AI ตอบจากนโยบายส่งของ</small>ถ้าชำระก่อน 14:00 น. ร้านจัดส่งรอบวันนี้ได้ค่ะ ต้องการให้แอดมินส่งลิงก์ชำระเงินให้ไหมคะ?</div>
          </div>
          <div class="suggestion">
            <label>คำตอบที่ AI เตรียมไว้</label>
            <p>ได้เลยค่ะ เดี๋ยวแอดมินส่งลิงก์ชำระเงินให้ พร้อมสรุปไซซ์ L สีครีม 1 ตัวนะคะ</p>
            <div><button>แก้คำตอบ</button><button class="primary">ส่งข้อความ</button></div>
          </div>
          <div class="composer"><input placeholder="พิมพ์ตอบเอง หรือให้ AI ช่วยร่างคำตอบ..."/><button>ส่ง</button></div>
        </section>

        <aside class="right-panel">
          <section class="panel customer-card"><div class="panel-title"><b>ข้อมูลลูกค้า</b></div><div class="avatar">M</div><h3>ลูกค้ามายด์</h3><p>สนใจเดรสสีครีม · มีโอกาสซื้อสูง</p><div class="tags"><span>ถามไซซ์</span><span>พร้อมซื้อ</span><span>ส่งวันนี้</span></div></section>
          <section class="panel product-card"><div class="panel-title"><b>สินค้าที่เกี่ยวข้อง</b><span>ในสต็อก</span></div><div class="product-img"></div><h3>Linen Straight Dress</h3><p>สีครีม · M เหลือ 4 / L เหลือ 8</p><ul><li>อก 36 → แนะนำ L</li><li>ความยาว 112 ซม.</li><li>ส่งวันนี้ได้ก่อน 14:00</li></ul></section>
          <section class="panel task-card"><div class="panel-title"><b>ระบบบันทึกให้แล้ว</b></div><label><input type="checkbox" checked/> ลูกค้าถามเรื่องไซซ์</label><label><input type="checkbox" checked/> สินค้านี้ถูกถามบ่อย</label><label><input type="checkbox"/> ถามแอดมินเรื่องส่งลิงก์จ่ายเงิน</label></section>
        </aside>
      </div>
    </main>
  </section>
</Layout>

<style>
.work-app{min-height:100vh;display:grid;grid-template-columns:250px 1fr;background:#05070e;color:#e6ebf5}.leftbar{position:sticky;top:0;height:100vh;padding:20px;border-right:1px solid rgba(255,255,255,.08);background:rgba(3,7,18,.9)}.back{color:#8aa0c5;text-decoration:none;font-size:13px}.shop{margin-top:22px;padding:14px;border:1px solid rgba(255,255,255,.09);border-radius:20px;background:rgba(255,255,255,.04)}.shop div{width:44px;height:44px;border-radius:15px;background:#26d7f6;color:#061018;display:grid;place-items:center;font-weight:950}.shop b,.shop span{display:block}.shop b{margin-top:10px;color:white}.shop span{color:#8aa0c5;font-size:12px;margin-top:3px}.leftbar nav{display:grid;gap:8px;margin-top:24px}.leftbar nav a{padding:12px 14px;border-radius:14px;color:#9fb0d0;font-weight:800;font-size:13px}.leftbar nav a.active,.leftbar nav a:hover{background:rgba(38,215,246,.11);color:white}.ai-switch{position:absolute;left:20px;right:20px;bottom:20px;display:flex;gap:10px;align-items:center;border:1px solid rgba(16,185,129,.22);border-radius:18px;background:rgba(16,185,129,.08);padding:13px}.ai-switch>span{width:10px;height:10px;border-radius:99px;background:#34d399;box-shadow:0 0 18px #34d399}.ai-switch b,.ai-switch small{display:block}.ai-switch small{color:#8aa0c5}.work-main{padding:24px;min-width:0}.work-top{display:flex;justify-content:space-between;gap:18px;align-items:center}.work-top small{color:#26d7f6;font-weight:900}.work-top h1{color:white;font-size:30px;letter-spacing:-.035em}.top-buttons{display:flex;gap:10px}.top-buttons button,.top-buttons a,.room-head button,.suggestion button,.composer button{border:1px solid rgba(255,255,255,.12);border-radius:999px;background:rgba(255,255,255,.06);color:white;padding:10px 14px;font-weight:850;text-decoration:none}.top-buttons a,.suggestion .primary,.composer button{background:#26d7f6;color:#061018;border:0}.work-grid{display:grid;grid-template-columns:280px minmax(420px,1fr) 320px;gap:14px;margin-top:20px}.panel{border:1px solid rgba(255,255,255,.09);border-radius:24px;background:linear-gradient(180deg,rgba(255,255,255,.065),rgba(255,255,255,.025));padding:16px;box-shadow:0 20px 60px rgba(0,0,0,.18)}.panel-title{display:flex;justify-content:space-between;gap:12px;align-items:center;margin-bottom:13px}.panel-title b{color:white}.panel-title span{color:#8aa0c5;font-size:12px}.chat-list{display:grid;align-content:start;gap:10px}.chat-list button{text-align:left;border:1px solid rgba(255,255,255,.08);border-radius:18px;background:rgba(255,255,255,.035);padding:13px;color:white;display:flex;justify-content:space-between;gap:10px}.chat-list button.active{border-color:rgba(38,215,246,.36);background:rgba(38,215,246,.10)}.chat-list p{color:#8aa0c5;font-size:12px;margin-top:4px}.chat-list em{color:#a7f3d0;font-size:11px;font-style:normal;white-space:nowrap}.chat-list em.warn{color:#fbbf24}.chat-room{display:grid;grid-template-rows:auto 1fr auto auto;min-height:720px}.room-head{display:flex;justify-content:space-between;gap:12px;border-bottom:1px solid rgba(255,255,255,.08);padding-bottom:14px}.room-head b,.room-head span{display:block}.room-head span{color:#8aa0c5;font-size:12px;margin-top:4px}.messages{padding:18px 4px;display:grid;align-content:start;gap:12px}.msg{max-width:78%;border-radius:18px;padding:13px 15px;line-height:1.6;font-size:14px}.msg small{display:block;color:#9beeff;font-size:11px;font-weight:900;margin-bottom:5px}.customer{background:rgba(255,255,255,.08);color:#dbe6fa}.ai{margin-left:auto;background:rgba(38,215,246,.15);border:1px solid rgba(38,215,246,.22);color:#effcff}.suggestion{border:1px solid rgba(38,215,246,.18);border-radius:20px;background:rgba(38,215,246,.06);padding:14px}.suggestion label{color:#26d7f6;font-weight:900;font-size:12px}.suggestion p{margin-top:8px;color:#e6ebf5;line-height:1.55}.suggestion div{display:flex;justify-content:flex-end;gap:8px;margin-top:12px}.composer{display:flex;gap:10px;margin-top:12px}.composer input{flex:1;border:1px solid rgba(255,255,255,.10);border-radius:999px;background:rgba(0,0,0,.22);color:white;padding:0 15px}.right-panel{display:grid;align-content:start;gap:14px}.avatar{width:58px;height:58px;border-radius:20px;background:#26d7f6;color:#061018;display:grid;place-items:center;font-weight:950;font-size:24px}.customer-card h3,.product-card h3{color:white;margin-top:12px}.customer-card p,.product-card p,.task-card label{color:#aebddb;font-size:13px;line-height:1.55}.tags{display:flex;flex-wrap:wrap;gap:8px;margin-top:14px}.tags span{color:#9beeff;border:1px solid rgba(38,215,246,.18);border-radius:999px;padding:6px 9px;font-size:11px}.product-img{height:145px;border-radius:18px;background:linear-gradient(135deg,rgba(38,215,246,.14),rgba(124,95,255,.16)),url('/assets/img/fashion-ai-kit/store-ops.png') center/cover;border:1px solid rgba(255,255,255,.10)}.product-card ul{margin-top:12px;padding-left:18px;color:#c8d5ec;font-size:13px;line-height:1.8}.task-card{display:grid;gap:10px}.task-card label{display:flex;gap:8px;align-items:center}@media(max-width:1120px){.work-app{grid-template-columns:1fr}.leftbar{position:relative;height:auto}.ai-switch{position:static;margin-top:20px}.work-grid{grid-template-columns:1fr}.chat-room{min-height:auto}.work-top{display:block}.top-buttons{margin-top:14px}.composer input{min-height:44px}}
</style>

<style>
  /* Demo page should feel like a real app, not a normal marketing page */
  :global(body > header), :global(body > footer), :global(.kp-contact-float) { display: none !important; }
  .work-app { padding-top: 0 !important; }
</style>


<style>
  /* Boutique app theme + mobile: show real workspace first */
  .work-app { background:linear-gradient(135deg,#080706 0%, #10141b 45%, #241811 100%) !important; }
  .leftbar, .panel { background:rgba(22,18,16,.72) !important; border-color:rgba(244,211,161,.13) !important; }
  .shop div, .avatar, .composer button, .suggestion .primary, .top-buttons a { background:#f4d3a1 !important; color:#17110b !important; }
  .leftbar nav a.active, .chat-list button.active { background:rgba(244,211,161,.12) !important; border-color:rgba(244,211,161,.28) !important; }
  .work-top small, .suggestion label, .msg small, .tags span { color:#f0c48a !important; }
  .msg.ai, .suggestion { background:rgba(244,211,161,.12) !important; border-color:rgba(244,211,161,.22) !important; color:#fff7ec !important; }
  .product-img { background:linear-gradient(135deg,rgba(244,211,161,.16),rgba(38,215,246,.10)), url('/assets/img/fashion-ai-kit/store-ops.png') center/cover !important; }
  .mobile-back { display:none; color:#c3b8ad; text-decoration:none; margin-bottom:12px; font-size:13px; }
  @media(max-width:1120px){
    .leftbar { display:none !important; }
    .mobile-back { display:inline-block; }
    .work-main { padding:18px 14px 40px !important; }
    .work-top h1 { font-size:28px !important; line-height:1.12; }
    .work-grid { margin-top:16px; }
    .chat-list { order:2; }
    .chat-room { order:1; }
    .right-panel { order:3; }
    .msg { max-width:90%; }
  }
</style>

<style>
  :global(html), :global(body) { overflow-x: hidden; }
  .work-main, .work-grid, .chat-room, .right-panel, .panel, .messages, .suggestion { min-width: 0; max-width: 100%; }
  .msg, .suggestion p { overflow-wrap: anywhere; }
  @media(max-width:1120px){
    .work-main { max-width:100vw; overflow:hidden; }
    .room-head, .suggestion div, .top-buttons { flex-wrap: wrap; }
    .room-head button, .suggestion button, .top-buttons a, .top-buttons button { white-space: normal; }
    .msg { max-width: 86% !important; }
    .chat-room { padding: 14px !important; }
  }
</style>

<style>
  * { box-sizing: border-box; }
  @media(max-width:1120px){
    .work-app { width:100vw !important; max-width:100vw !important; overflow-x:hidden !important; display:block !important; }
    .work-main { width:100vw !important; max-width:100vw !important; padding:16px 14px 36px !important; overflow-x:hidden !important; }
    .work-grid { display:flex !important; flex-direction:column !important; width:100% !important; max-width:100% !important; gap:14px !important; }
    .panel, .chat-room, .chat-list, .right-panel { width:100% !important; max-width:100% !important; overflow:hidden !important; }
    .room-head button { display:none !important; }
    .messages { width:100% !important; max-width:100% !important; overflow:hidden !important; }
    .msg { max-width:82% !important; font-size:13px !important; line-height:1.55 !important; }
    .suggestion { width:100% !important; }
    .suggestion div { display:grid !important; grid-template-columns:1fr 1fr; gap:8px; }
    .suggestion button { width:100% !important; padding-left:8px !important; padding-right:8px !important; }
    .composer { width:100% !important; }
    .composer input { min-width:0 !important; width:100% !important; }
    .top-buttons { display:grid !important; grid-template-columns:1fr 1fr; }
    .top-buttons button, .top-buttons a { text-align:center; padding-left:8px !important; padding-right:8px !important; }
  }
</style>
