---
import Layout from '~/layouts/Layout.astro';
---

<Layout title="ตัวอย่างหน้าระบบช่วยตอบแชทร้านเสื้อผ้า | KORP AI" description="Mockup หน้าจอใช้งานจริงของระบบ AI ช่วยตอบแชท ลดงานแอดมิน และช่วยขายสำหรับร้านเสื้อผ้าออนไลน์" canonical="https://korpai.co/fashion-ai-kit/demo">
  <section class="app-shell">
    <aside class="sidebar">
      <a class="back" href="/fashion-ai-kit">← กลับหน้าแพ็กเกจ</a>
      <div class="shop-card">
        <div class="logo">LS</div>
        <b>Linn Studio</b>
        <span>AI Sales Automation</span>
      </div>
      <nav class="side-nav" aria-label="เมนูระบบตัวอย่าง">
        <button class="active" data-view="inbox">กล่องแชท</button>
        <button data-view="products">สินค้า</button>
        <button data-view="answers">คำตอบ AI</button>
        <button data-view="orders">ออเดอร์/ยอดขาย</button>
        <button data-view="stock">เช็คสต็อก</button>
        <button data-view="tasks">งานที่ต้องทำ</button>
        <button data-view="insights">สรุปยอด/ลดต้นทุน</button>
      </nav>
      <div class="ai-status"><i></i><div><b>AI เปิดอยู่</b><small>ตอบคำถามซ้ำ + ส่งต่อเคสยาก</small></div></div>
    </aside>

    <main class="main">
      <header class="topbar">
        <div>
          <a class="mobile-back" href="/fashion-ai-kit">← กลับหน้าแพ็กเกจ</a>
          <small>Interactive mockup · กดเมนู/ลูกค้า/ปุ่มได้</small>
          <h1 data-title>กล่องแชทร้าน Linn Studio</h1>
        </div>
        <div class="top-actions">
          <button id="toggle-ai">พัก AI ชั่วคราว</button>
          <a href="https://lin.ee/Qt6Vri4" target="_blank" rel="noopener">อยากได้ระบบนี้</a>
        </div>
      </header>

      <section class="quick-stats">
        <article><span>แชทวันนี้</span><b>24</b><em>AI ช่วยตอบ 18</em></article>
        <article><span>ยอดที่ AI ช่วยปิด</span><b>฿8,740</b><em>จาก 6 ออเดอร์</em></article>
        <article><span>เวลาที่ประหยัด</span><b>3.6 ชม.</b><em>เทียบงานแอดมินซ้ำ</em></article>
        <article><span>คำถามฮิต</span><b>ไซซ์</b><em>ควรทำโพสต์/FAQ เพิ่ม</em></article>
      </section>

      <section class="view active" data-panel="inbox">
        <div class="work-grid">
          <section class="panel chat-list">
            <div class="panel-head"><b>ลูกค้าที่ทักมา</b><span>กดเพื่อเปลี่ยนเคส</span></div>
            <button class="customer-row active" data-customer="mind"><div><b>ลูกค้ามายด์</b><p>ถามไซซ์เดรสสีครีม</p></div><em>AI ตอบอยู่</em></button>
            <button class="customer-row" data-customer="praew"><div><b>ลูกค้าแพรว</b><p>ขอส่งด่วนใน กทม.</p></div><em class="warn">รอแอดมิน</em></button>
            <button class="customer-row" data-customer="nut"><div><b>ลูกค้านัท</b><p>ถามกางเกงเอวสูง</p></div><em>ตอบจบแล้ว</em></button>
            <button class="customer-row" data-customer="bee"><div><b>ลูกค้าบี</b><p>ถามโปรซื้อ 2 ชิ้น</p></div><em>AI ตอบอยู่</em></button>
          </section>

          <section class="panel chat-room">
            <div class="room-head"><div><b id="customer-name">ลูกค้ามายด์</b><span id="customer-topic">กำลังดูสินค้า: Linen Straight Dress — สีครีม</span></div><button id="handoff-btn">ส่งต่อแอดมิน</button></div>
            <div class="messages" id="messages"></div>
            <div class="suggestion">
              <label>คำตอบที่ AI เตรียมไว้</label>
              <p id="ai-draft">ได้เลยค่ะ เดี๋ยวแอดมินส่งลิงก์ชำระเงินให้ พร้อมสรุปไซซ์ L สีครีม 1 ตัวนะคะ</p>
              <div><button id="edit-answer">แก้คำตอบ</button><button class="primary" id="send-answer">ส่งข้อความ</button></div>
            </div>
            <div class="composer"><input id="composer" placeholder="พิมพ์ตอบเอง หรือให้ AI ช่วยร่างคำตอบ..."/><button id="composer-send">ส่ง</button></div>
          </section>

          <aside class="right-col">
            <section class="panel customer-card"><div class="panel-head"><b>ข้อมูลลูกค้า</b></div><div class="avatar" id="avatar">M</div><h3 id="profile-name">ลูกค้ามายด์</h3><p id="profile-note">สนใจเดรสสีครีม · มีโอกาสซื้อสูง</p><div class="tags" id="tags"><span>ถามไซซ์</span><span>พร้อมซื้อ</span><span>ส่งวันนี้</span></div></section>
            <section class="panel product-card"><div class="panel-head"><b>สินค้าที่ AI ใช้ตอบ</b><span>ในสต็อก</span></div><div class="product-img"></div><h3 id="product-name">Linen Straight Dress</h3><p id="product-stock">สีครีม · M เหลือ 4 / L เหลือ 8</p><ul id="product-rules"><li>อก 36 → แนะนำ L</li><li>ความยาว 112 ซม.</li><li>ส่งวันนี้ได้ก่อน 14:00</li></ul></section>
          </aside>
        </div>
      </section>

      <section class="view" data-panel="products">
        <div class="panel products-view">
          <div class="panel-head"><b>ฐานข้อมูลสินค้า</b><span>AI ใช้อ้างอิง ไม่ตอบมั่ว</span></div>
          <div class="product-grid">
            <article><div class="pic"></div><b>Linen Straight Dress</b><span>ครีม · M/L</span><p>ทรงตรง ผ้าลินินผสม แนะนำ L สำหรับอก 36</p><button data-demo-toast="อัปเดตสินค้าแล้ว">แก้ข้อมูล</button></article>
            <article><div class="pic p2"></div><b>High Waist Trousers</b><span>ดำ/เบจ · S/M/L</span><p>เอวสูง ทรงเก็บสะโพก เหมาะกับลูกค้าสูง 155–170</p><button data-demo-toast="เปิด size guide แล้ว">ดูไซซ์</button></article>
            <article><div class="pic p3"></div><b>Soft Knit Cardigan</b><span>ฟ้า/เทา · Free size</span><p>สินค้าถูกถามบ่อยเรื่องสีจริงและความหนา</p><button data-demo-toast="เพิ่ม FAQ ให้ AI แล้ว">เพิ่ม FAQ</button></article>
          </div>
        </div>
      </section>

      <section class="view" data-panel="answers">
        <div class="panel answers-view">
          <div class="panel-head"><b>คำตอบ AI ที่ร้านควบคุมได้</b><span>แก้ tone / เงื่อนไข / ความเสี่ยง</span></div>
          <div class="answer-list">
            <article><b>ถามไซซ์</b><p>AI ต้องถามส่วนสูง/อก/เอวก่อน ถ้าข้อมูลไม่ครบ ห้ามฟันธงไซซ์</p><button data-demo-toast="บันทึกกฎคำตอบไซซ์แล้ว">บันทึก</button></article>
            <article><b>ถามส่งของ</b><p>ถ้าชำระก่อน 14:00 ส่งวันนี้ หลังจากนั้นส่งรอบถัดไป</p><button data-demo-toast="บันทึกกฎจัดส่งแล้ว">บันทึก</button></article>
            <article><b>คืน/เปลี่ยนสินค้า</b><p>เคสคืนเงิน/เปลี่ยนสินค้าให้ส่งต่อแอดมินเสมอ</p><button data-demo-toast="ตั้งค่า handoff แล้ว">เปิดส่งต่อ</button></article>
          </div>
        </div>
      </section>

      <section class="view" data-panel="orders">
        <div class="panel orders-view">
          <div class="panel-head"><b>ออเดอร์และยอดขายวันนี้</b><span>AI ช่วยสรุปจากแชท</span></div>
          <div class="order-grid">
            <article><span>ยอดขายวันนี้</span><b>฿18,420</b><p>12 ออเดอร์ · เฉลี่ย ฿1,535</p></article>
            <article><span>AI ช่วยปิด</span><b>฿8,740</b><p>ตอบไซซ์/ส่งลิงก์จ่ายเงิน/ติดตามลูกค้า</p></article>
            <article><span>รอชำระเงิน</span><b>฿3,180</b><p>3 ลูกค้า · ระบบตั้งเตือน follow-up แล้ว</p></article>
          </div>
          <div class="order-list">
            <div><b>#LS-1024 · ลูกค้ามายด์</b><span>Linen Straight Dress สีครีม L · ฿1,290 · รอชำระ</span><button data-demo-toast="ส่งลิงก์ชำระเงินให้ลูกค้ามายด์แล้ว">ส่งลิงก์จ่ายเงิน</button></div>
            <div><b>#LS-1023 · ลูกค้านัท</b><span>High Waist Trousers สีดำ M · ฿990 · ชำระแล้ว</span><button data-demo-toast="ตัดสต็อกแล้ว">ตัดสต็อก</button></div>
            <div><b>#LS-1022 · ลูกค้าบี</b><span>Dress + Cardigan · ฿1,890 · AI เสนอโปรคู่</span><button data-demo-toast="บันทึกยอดขายจาก AI แล้ว">บันทึกยอด</button></div>
          </div>
        </div>
      </section>

      <section class="view" data-panel="stock">
        <div class="panel stock-view">
          <div class="panel-head"><b>เช็คสต็อกสินค้า</b><span>ใช้ตอบลูกค้าและตัดหลังขาย</span></div>
          <div class="stock-table">
            <div class="head"><span>สินค้า</span><span>ไซซ์/สี</span><span>คงเหลือ</span><span>สถานะ</span></div>
            <div><span>Linen Straight Dress</span><span>ครีม · M</span><b>4</b><em>พร้อมขาย</em></div>
            <div><span>Linen Straight Dress</span><span>ครีม · L</span><b>8</b><em>พร้อมขาย</em></div>
            <div><span>High Waist Trousers</span><span>ดำ · M</span><b>2</b><em class="warn">ใกล้หมด</em></div>
            <div><span>Soft Knit Cardigan</span><span>ฟ้า · Free</span><b>6</b><em>พร้อมขาย</em></div>
          </div>
          <div class="stock-actions"><button data-demo-toast="AI จะไม่ขายสินค้าที่หมดสต็อก">กันขายสินค้าหมด</button><button data-demo-toast="แจ้งเตือนเติมสต็อกแล้ว">ตั้งเตือนเติมของ</button></div>
        </div>
      </section>

      <section class="view" data-panel="tasks">
        <div class="panel tasks-view">
          <div class="panel-head"><b>งานที่ระบบสร้างให้</b><span>จากแชทจริงวันนี้</span></div>
          <div class="task-list">
            <label><input type="checkbox" checked/> เพิ่มรูปเทียบความยาวเดรส Linen Straight</label>
            <label><input type="checkbox"/> ทำโพสต์ “สูง 160 ใส่ไซซ์อะไร”</label>
            <label><input type="checkbox"/> ให้แอดมินส่งลิงก์ชำระเงินให้ลูกค้ามายด์</label>
            <label><input type="checkbox"/> เพิ่ม FAQ เรื่องส่งด่วน กทม.</label>
          </div>
        </div>
      </section>

      <section class="view" data-panel="insights">
        <div class="insight-grid">
          <article class="panel"><div class="panel-head"><b>ยอดขายวันนี้</b><span>จากระบบ</span></div><div class="big">฿18,420</div><p>12 ออเดอร์ · AI ช่วยปิด 6 ออเดอร์</p></article>
          <article class="panel"><div class="panel-head"><b>ยอดที่ AI ช่วยปิด</b><span>วันนี้</span></div><div class="big">฿8,740</div><p>จากการตอบไซซ์ แนะนำสินค้า และ follow-up ลูกค้า</p></article>
          <article class="panel"><div class="panel-head"><b>โอกาสขาย</b><span>จากแชท</span></div><div class="bar"><i style="width:72%"></i></div><p>72% ของแชทวันนี้เกี่ยวกับสินค้า/ไซซ์ พร้อมปิดการขายได้</p></article>
          <article class="panel"><div class="panel-head"><b>สต็อกใกล้หมด</b><span>ต้องดูแล</span></div><div class="big">2 SKU</div><p>ระบบจะไม่แนะนำสินค้าที่หมด และแจ้งเตือนเติมของ</p></article>
          <article class="panel"><div class="panel-head"><b>สิ่งที่ควรทำต่อ</b></div><ul><li>ทำ size guide แบบรูปภาพ</li><li>ทำโพสต์ FAQ เรื่องส่งวันนี้</li><li>เพิ่มคำตอบเรื่องเปลี่ยนไซซ์</li></ul></article>
        </div>
      </section>
    </main>
  </section>
  <div class="toast" id="toast">บันทึกแล้ว</div>
</Layout>

<style>
:global(body>header),:global(body>footer),:global(.kp-contact-float){display:none!important}:global(html),:global(body){overflow-x:hidden}.app-shell{min-height:100vh;display:grid;grid-template-columns:260px 1fr;background:linear-gradient(135deg,#080706 0%,#10141b 45%,#241811 100%);color:#f7efe6}.sidebar{position:sticky;top:0;height:100vh;padding:20px;border-right:1px solid rgba(244,211,161,.13);background:rgba(13,10,9,.86)}.back,.mobile-back{color:#cdbfaf;text-decoration:none;font-size:13px}.shop-card{margin-top:22px;border:1px solid rgba(244,211,161,.15);border-radius:22px;padding:15px;background:rgba(255,255,255,.045)}.logo,.avatar{width:48px;height:48px;border-radius:16px;background:#f4d3a1;color:#17110b;display:grid;place-items:center;font-weight:950}.shop-card b,.shop-card span{display:block}.shop-card b{margin-top:10px}.shop-card span,.ai-status small{color:#b9aa99;font-size:12px}.side-nav{display:grid;gap:8px;margin-top:24px}.side-nav button{border:0;text-align:left;padding:12px 14px;border-radius:14px;background:transparent;color:#cdbfaf;font-weight:850;cursor:pointer}.side-nav button.active,.side-nav button:hover{background:rgba(244,211,161,.13);color:#fff}.ai-status{position:absolute;left:20px;right:20px;bottom:20px;display:flex;gap:10px;align-items:center;border:1px solid rgba(52,211,153,.24);border-radius:18px;background:rgba(52,211,153,.08);padding:13px}.ai-status i{width:10px;height:10px;border-radius:99px;background:#34d399;box-shadow:0 0 18px #34d399}.main{padding:24px;min-width:0}.topbar{display:flex;justify-content:space-between;align-items:center;gap:18px}.topbar small{color:#f0c48a;font-weight:900}.topbar h1{margin:3px 0 0;color:#fff;font-size:32px;letter-spacing:-.04em}.top-actions{display:flex;gap:10px}.top-actions button,.top-actions a,.room-head button,.suggestion button,.composer button,.product-grid button,.answer-list button{border:1px solid rgba(255,255,255,.14);border-radius:999px;background:rgba(255,255,255,.06);color:#fff;padding:10px 